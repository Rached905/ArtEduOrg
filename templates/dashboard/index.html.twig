{% extends 'base.html.twig' %}

{% block title %}Dashboard Administrateur{% endblock %}

{% block stylesheets %}
<style>
    .dashboard-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2rem;
        border-radius: 12px;
        margin-bottom: 2rem;
        box-shadow: 0 4px 20px rgba(102, 126, 234, 0.3);
    }


    .quick-action-card {
        border: none;
        border-radius: 12px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: block;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        color: white;
    }

    .quick-action-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
        color: white;
    }

    .quick-action-icon { font-size: 2.5rem; margin-bottom: 1rem; }

    .card-modern {
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }

    .card-modern .card-header {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border-bottom: 2px solid #e9ecef;
        padding: 1.25rem 1.5rem;
        font-weight: 600;
    }

    .activity-item {
        display: flex;
        align-items: start;
        padding: 1rem;
        border-bottom: 1px solid #f0f0f0;
        transition: background 0.2s;
    }

    .activity-item:hover { background: #f8f9fa; }
    .activity-item:last-child { border-bottom: none; }

    .activity-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 1rem;
        flex-shrink: 0;
    }

    .activity-icon.success { background: rgba(25, 135, 84, 0.1); color: #198754; }
    .activity-icon.info { background: rgba(13, 110, 253, 0.1); color: #0d6efd; }
    .activity-icon.warning { background: rgba(255, 193, 7, 0.1); color: #ffc107; }
    .activity-icon.danger { background: rgba(220, 53, 69, 0.1); color: #dc3545; }

    .user-avatar {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        margin-right: 0.75rem;
        font-size: 0.875rem;
    }

    .role-badge {
        padding: 0.375rem 0.75rem;
        border-radius: 0.25rem;
        font-weight: 500;
        font-size: 0.875rem;
        text-transform: uppercase;
        color: white;
    }

    .role-badge.admin { background-color: #dc3545; }
    .role-badge.client { background-color: #0d6efd; }
    .role-badge.vendor { background-color: #198754; }

    .progress-section {
        margin-top: 1.5rem;
    }

    .progress-item {
        margin-bottom: 1rem;
    }

    .progress-label {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
    }

    .progress {
        height: 8px;
        border-radius: 4px;
        background: #e9ecef;
    }

    .progress-bar {
        border-radius: 4px;
        transition: width 0.6s ease;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in {
        animation: fadeInUp 0.5s ease;
    }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <!-- Header -->
    <div class="dashboard-header mt-4 animate-fade-in">
        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <div>
                <h1><i class="fas fa-tachometer-alt me-2"></i>Tableau de Bord</h1>
                <p class="mb-0">Bienvenue{% if app.user %}, <strong>{{ app.user.fullname }}</strong>{% endif %} ! Voici un aperçu de votre système.</p>
            </div>
            <span class="badge bg-light text-dark px-3 py-2">
                <i class="far fa-calendar-alt me-2"></i>{{ "now"|date("d/m/Y") }}
            </span>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-stat-card stat-card-purple">
                <div class="card-body">
                    <div class="stat-icon"><i class="fas fa-calendar"></i></div>
                    <div class="stat-title">Événements à venir</div>
                    <div class="stat-value">{{ stats.upcoming_events|default(0) }}</div>
                    <a href="{{ path('app_event_index') }}" class="stat-button">Voir détails →</a>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-stat-card stat-card-purple">
                <div class="card-body">
                    <div class="stat-icon"><i class="fas fa-play-circle"></i></div>
                    <div class="stat-title">Événements en cours</div>
                    <div class="stat-value">{{ stats.ongoing_events|default(0) }}</div>
                    <a href="{{ path('app_event_index') }}" class="stat-button">Voir détails →</a>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-stat-card stat-card-purple">
                <div class="card-body">
                    <div class="stat-icon"><i class="fas fa-ticket-alt"></i></div>
                    <div class="stat-title">Billets vendus aujourd'hui</div>
                    <div class="stat-value">{{ stats.tickets_today|default(0) }}</div>
                    <a href="{{ path('app_ticket_index') }}" class="stat-button">Voir détails →</a>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-stat-card stat-card-purple">
                <div class="card-body">
                    <div class="stat-icon"><i class="fas fa-euro-sign"></i></div>
                    <div class="stat-title">Revenus totaux</div>
                    <div class="stat-value">{{ (stats.total_revenue|default(0))|number_format(2, ',', ' ') }} €</div>
                    <a href="{{ path('app_ticket_index') }}" class="stat-button">Voir détails →</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Sponsoring -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-stat-card stat-card-purple">
                <div class="card-body">
                    <div class="stat-icon"><i class="fas fa-handshake"></i></div>
                    <div class="stat-title">Sponsors</div>
                    <div class="stat-value">{{ stats.total_sponsors|default(0) }}</div>
                    <a href="{{ path('app_sponsor_index') }}" class="stat-button">Voir détails →</a>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-stat-card stat-card-green">
                <div class="card-body">
                    <div class="stat-icon"><i class="fas fa-file-contract"></i></div>
                    <div class="stat-title">Contrats</div>
                    <div class="stat-value">{{ stats.total_contracts|default(0) }}</div>
                    <a href="{{ path('app_sponsor_contract_index') }}" class="stat-button">Voir détails →</a>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-stat-card stat-card-cyan">
                <div class="card-body">
                    <div class="stat-icon"><i class="fas fa-gift"></i></div>
                    <div class="stat-title">Parrainages</div>
                    <div class="stat-value">{{ stats.total_sponsorships|default(0) }}</div>
                    <a href="{{ path('app_sponsorship_index') }}" class="stat-button">Voir détails →</a>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-stat-card stat-card-yellow">
                <div class="card-body">
                    <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                    <div class="stat-title">Total</div>
                    <div class="stat-value">{{ stats.total_sponsoring|default(0) }}</div>
                    <div class="stat-subtitle">Éléments totaux</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Derniers Sponsors, Contrats et Parrainages -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                    <h5 class="mb-0"><i class="fas fa-handshake me-2"></i>Derniers Sponsors</h5>
                </div>
                <div class="card-body">
                    {% if recent_sponsors is not empty %}
                        {% for sponsor in recent_sponsors %}
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <strong>{{ sponsor.name }}</strong><br>
                                    <small class="text-muted">{{ sponsor.email }}</small>
                                </div>
                                <a href="{{ path('app_sponsor_show', {'id': sponsor.id}) }}" class="btn btn-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">Voir</a>
                            </div>
                        {% endfor %}
                    {% else %}
                        <p class="text-muted mb-0">Aucun sponsor</p>
                    {% endif %}
                    <a href="{{ path('app_sponsor_index') }}" class="btn w-100 mt-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">Voir tous les sponsors</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white;">
                    <h5 class="mb-0"><i class="fas fa-file-contract me-2"></i>Derniers Contrats</h5>
                </div>
                <div class="card-body">
                    {% if recent_contracts is not empty %}
                        {% for contract in recent_contracts %}
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <strong>{{ contract.contractNumber }}</strong><br>
                                    <small class="text-muted">{{ contract.sponsor.name }}</small>
                                </div>
                                <a href="{{ path('app_sponsor_contract_show', {'id': contract.id}) }}" class="btn btn-sm" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white;">Voir</a>
                            </div>
                        {% endfor %}
                    {% else %}
                        <p class="text-muted mb-0">Aucun contrat</p>
                    {% endif %}
                    <a href="{{ path('app_sponsor_contract_index') }}" class="btn w-100 mt-3" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white;">Voir tous les contrats</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header" style="background: linear-gradient(135deg, #00c9ff 0%, #92fe9d 100%); color: white;">
                    <h5 class="mb-0"><i class="fas fa-gift me-2"></i>Derniers Parrainages</h5>
                </div>
                <div class="card-body">
                    {% if recent_sponsorships is not empty %}
                        {% for sponsorship in recent_sponsorships %}
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <strong>{{ sponsorship.sponsor.name }}</strong><br>
                                    <small class="text-muted">{{ sponsorship.amount|number_format(2, ',', ' ') }} €</small>
                                </div>
                                <a href="{{ path('app_sponsorship_show', {'id': sponsorship.id}) }}" class="btn btn-sm" style="background: linear-gradient(135deg, #00c9ff 0%, #92fe9d 100%); color: white;">Voir</a>
                            </div>
                        {% endfor %}
                    {% else %}
                        <p class="text-muted mb-0">Aucun parrainage</p>
                    {% endif %}
                    <a href="{{ path('app_sponsorship_index') }}" class="btn w-100 mt-3" style="background: linear-gradient(135deg, #00c9ff 0%, #92fe9d 100%); color: white;">Voir tous les parrainages</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Derniers événements -->
    <div class="card card-modern mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-primary"><i class="fas fa-calendar-alt me-2"></i>Derniers événements</h5>
            <a href="{{ path('app_event_index') }}" class="btn btn-sm btn-primary">Voir tout</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Date</th>
                            <th>Lieu</th>
                            <th>Statut</th>
                            <th>Places restantes</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if recent_events is not empty %}
                            {% for event in recent_events %}
                                <tr>
                                    <td><strong>{{ event.title }}</strong></td>
                                    <td>{{ event.startDate|date('d/m/Y H:i') }}</td>
                                    <td>{{ event.location }}</td>
                                    <td>
                                        {% if event.startDate > now %}
                                            <span class="badge bg-info">À venir</span>
                                        {% elseif event.endDate >= now %}
                                            <span class="badge bg-success">En cours</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Terminé</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ event.capacity - event.ticketsSold }}</td>
                                    <td>
                                        <a href="{{ path('app_event_show', {'id': event.id}) }}" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> Voir
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                    Aucun événement trouvé
                                </td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Charts & Activity -->
    <div class="row g-4 mb-4">
        <div class="col-xl-8">
            <div class="card card-modern">
                <div class="card-header">
                    <i class="fas fa-chart-line me-2"></i>Inscriptions des 7 derniers jours
                </div>
                <div class="card-body">
                    <canvas id="userGrowthChart" height="80"></canvas>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="card card-modern">
                <div class="card-header"><i class="fas fa-history me-2"></i>Activité Récente</div>
                <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                    {% if recent_activities is not empty %}
                        {% for activity in recent_activities %}
                            <div class="activity-item">
                                <div class="activity-icon {{ activity.class }}">
                                    <i class="fas fa-{{ activity.icon }}"></i>
                                </div>
                                <div>
                                    <div class="fw-bold">{{ activity.title }}</div>
                                    <small class="text-muted">{{ activity.description }}</small>
                                    <div><small class="text-muted"><i class="far fa-clock me-1"></i>{{ activity.time }}</small></div>
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-inbox fa-2x mb-2"></i>
                            <p class="mb-0">Aucune activité récente</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Role Distribution & Recent Users -->
    <div class="row g-4 mb-4">
        <div class="col-xl-4">
            <div class="card card-modern">
                <div class="card-header">
                    <i class="fas fa-chart-pie me-2"></i>Répartition par Rôle
                </div>
                <div class="card-body">
                    <canvas id="roleDistributionChart" height="200"></canvas>
                    
                    <div class="progress-section">
                        {% set total = stats.total_users %}
                        
                        <div class="progress-item">
                            <div class="progress-label">
                                <span><i class="fas fa-circle text-danger me-2"></i>Administrateurs</span>
                                <strong>{{ stats.admin_count }} ({{ (stats.admin_count / total * 100)|round }}%)</strong>
                            </div>
                            <div class="progress">
                                <div class="progress-bar bg-danger" style="width: {{ (stats.admin_count / total * 100) }}%"></div>
                            </div>
                        </div>

                        <div class="progress-item">
                            <div class="progress-label">
                                <span><i class="fas fa-circle text-success me-2"></i>Vendeurs</span>
                                <strong>{{ stats.vendor_count }} ({{ (stats.vendor_count / total * 100)|round }}%)</strong>
                            </div>
                            <div class="progress">
                                <div class="progress-bar bg-success" style="width: {{ (stats.vendor_count / total * 100) }}%"></div>
                            </div>
                        </div>

                        <div class="progress-item">
                            <div class="progress-label">
                                <span><i class="fas fa-circle text-primary me-2"></i>Clients</span>
                                <strong>{{ stats.client_count }} ({{ (stats.client_count / total * 100)|round }}%)</strong>
                            </div>
                            <div class="progress">
                                <div class="progress-bar bg-primary" style="width: {{ (stats.client_count / total * 100) }}%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="card card-modern">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div><i class="fas fa-users me-2"></i>Utilisateurs Récents</div>
                    <a href="{{ path('app_users_index') }}" class="btn btn-sm btn-primary">
                        Voir Tous <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th>Utilisateur</th>
                                    <th>Email</th>
                                    <th>Rôle</th>
                                    <th>Statut</th>
                                    <th>Date</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% if recent_users is not empty %}
                                    {% for user in recent_users %}
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="user-avatar">
                                                        {{ user.fullname|slice(0, 1)|upper }}{{ user.fullname|split(' ')[1]|default('')|slice(0, 1)|upper }}
                                                    </div>
                                                    <strong>{{ user.fullname }}</strong>
                                                </div>
                                            </td>
                                            <td>{{ user.email }}</td>
                                            <td>
                                                {% if user.role.value == 'ADMIN' %}
                                                    <span class="role-badge admin"><i class="fas fa-user-shield me-1"></i>Admin</span>
                                                {% elseif user.role.value == 'VENDEUR' %}
                                                    <span class="role-badge vendor"><i class="fas fa-store me-1"></i>Vendeur</span>
                                                {% elseif user.role.value == 'CLIENT' %}
                                                    <span class="role-badge client"><i class="fas fa-user me-1"></i>Client</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if user.isActive %}
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check-circle me-1"></i>Actif
                                                    </span>
                                                {% else %}
                                                    <span class="badge bg-danger">
                                                        <i class="fas fa-times-circle me-1"></i>Inactif
                                                    </span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    <i class="far fa-calendar me-1"></i>
                                                    {{ user.createdAt ? user.createdAt|date("d/m/Y") : 'N/A' }}
                                                </small>
                                            </td>
                                            <td class="text-center">
                                                <a href="{{ path('app_users_show', {'id': user.id}) }}" class="btn btn-sm btn-info me-1" title="Voir">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="{{ path('app_users_edit', {'id': user.id}) }}" class="btn btn-sm btn-warning" title="Modifier">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                            Aucun utilisateur trouvé
                                        </td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // User Growth Chart - Données réelles depuis le contrôleur
    const userGrowthCtx = document.getElementById('userGrowthChart');
    const chartLabels = {{ chart_data.labels|json_encode|raw }};
    const chartData = {{ chart_data.data|json_encode|raw }};
    
    new Chart(userGrowthCtx, {
        type: 'line',
        data: {
            labels: chartLabels,
            datasets: [{
                label: 'Nouveaux Utilisateurs',
                data: chartData,
                borderColor: '#667eea',
                backgroundColor: 'rgba(102, 126, 234, 0.1)',
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#667eea',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: 'rgba(0, 0, 0, 0.8)',
                    padding: 12,
                    titleFont: { size: 14 },
                    bodyFont: { size: 13 }
                }
            },
            scales: {
                y: { 
                    beginAtZero: true,
                    ticks: { precision: 0 }
                }
            }
        }
    });
    
    // Role Distribution Chart - Données réelles
    const roleCtx = document.getElementById('roleDistributionChart');
    new Chart(roleCtx, {
        type: 'doughnut',
        data: {
            labels: ['Administrateurs', 'Vendeurs', 'Clients'],
            datasets: [{
                data: [
                    {{ stats.admin_count }},
                    {{ stats.vendor_count }},
                    {{ stats.client_count }}
                ],
                backgroundColor: [
                    '#dc3545',
                    '#198754',
                    '#0d6efd'
                ],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        padding: 15,
                        font: { size: 12 }
                    }
                },
                tooltip: {
                    backgroundColor: 'rgba(0, 0, 0, 0.8)',
                    padding: 12
                }
            }
        }
    });
});
</script>
{% endblock %}