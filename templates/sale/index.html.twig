{% extends 'base.html.twig' %}

{% block title %}Galerie d'Art - Client{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    #layoutSidenav_content {
        min-height: 100vh;
        background: #0a0a0a;
        padding: 0;
    }

    .gallery-container {
        padding: 40px 20px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .gallery-header {
        text-align: center;
        margin-bottom: 50px;
    }

    .gallery-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .gallery-subtitle {
        font-size: 1.2rem;
        color: rgba(255, 255, 255, 0.6);
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .sales-filters {
        display: flex;
        gap: 15px;
        justify-content: center;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 10px 20px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 25px;
        background: rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.8);
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.8rem;
    }

    .filter-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.4);
        transform: translateY(-2px);
    }

    .filter-btn.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-color: transparent;
    }

    .sales-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 30px;
        margin-bottom: 40px;
    }

    .sale-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 30px;
        transition: all 0.4s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .sale-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 60px rgba(102, 126, 234, 0.3);
        border-color: rgba(102, 126, 234, 0.5);
    }

    .sale-card-image {
        width: 100%;
        height: 300px;
        object-fit: cover;
        border-radius: 15px;
        margin-bottom: 20px;
        border: 2px solid rgba(255, 255, 255, 0.1);
        cursor: pointer;
    }

    .sale-card-image-placeholder {
        width: 100%;
        height: 300px;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.2) 100%);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.3);
        font-size: 3rem;
        margin-bottom: 20px;
    }

    .sale-card-badge {
        display: inline-block;
        padding: 8px 20px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 15px;
        width: fit-content;
    }

    .sale-card-badge.vente {
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid #667eea;
    }

    .sale-card-badge.ticket {
        background: rgba(240, 147, 251, 0.2);
        color: #f093fb;
        border: 1px solid #f093fb;
    }

    .sale-card-badge.echange {
        background: rgba(79, 172, 254, 0.2);
        color: #4facfe;
        border: 1px solid #4facfe;
    }

    .sale-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 10px;
        line-height: 1.3;
    }

    .sale-card-description {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.6);
        margin-bottom: 20px;
        line-height: 1.6;
        flex-grow: 1;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .sale-card-price {
        font-size: 2rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 25px;
        font-family: 'Playfair Display', serif;
    }

    .sale-card-buttons {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .btn-sale-action {
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: 2px solid transparent;
    }

    .btn-buy {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .btn-buy:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .btn-details {
        background: transparent;
        color: #ffffff;
        border: 2px solid rgba(255, 255, 255, 0.3);
    }

    .btn-details:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.6);
        color: white;
    }

    .no-sales {
        text-align: center;
        padding: 80px 20px;
        color: rgba(255, 255, 255, 0.5);
    }

    .no-sales i {
        font-size: 5rem;
        opacity: 0.3;
        margin-bottom: 20px;
    }

    @media (max-width: 768px) {
        .gallery-title {
            font-size: 2.5rem;
        }

        .sales-grid {
            grid-template-columns: 1fr;
        }

        .sale-card {
            padding: 20px;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="gallery-container">
    <div class="gallery-header">
        <h1 class="gallery-title">🎨 Galerie d'Art</h1>
        <p class="gallery-subtitle">Découvrez nos œuvres disponibles</p>
    </div>

    <!-- Filtres -->
    <div class="sales-filters">
        <button class="filter-btn active" data-type="">Tous</button>
        <button class="filter-btn" data-type="vente">Ventes</button>
        <button class="filter-btn" data-type="ticket">Tickets</button>
        <button class="filter-btn" data-type="echange">Échanges</button>
    </div>

    <!-- Grille des ventes -->
    {% if sales|length > 0 %}
    <div class="sales-grid" id="salesGrid">
        {% for sale in sales %}
        <div class="sale-card" data-type="{{ sale.type.value }}">
            {% set images = sale.sortedImages %}
            {% set primaryImage = null %}
            {% for image in images %}
                {% if image.isPrimary %}
                    {% set primaryImage = image %}
                {% endif %}
            {% endfor %}
            
            {% if primaryImage %}
                <img src="{{ asset(primaryImage.path) }}" alt="{{ sale.title }}" class="sale-card-image"
                     onclick="showImageModal('{{ asset(primaryImage.path) }}', '{{ sale.title }}')">
            {% elseif sale.image %}
                <img src="{{ asset(sale.image) }}" alt="{{ sale.title }}" class="sale-card-image"
                     onclick="showImageModal('{{ asset(sale.image) }}', '{{ sale.title }}')">
            {% else %}
                <div class="sale-card-image-placeholder">
                    <i class="fas fa-palette"></i>
                </div>
            {% endif %}
            
            <span class="sale-card-badge {{ sale.type.value }}">
                {% if sale.type.value == 'vente' %}
                    <i class="fas fa-shopping-bag me-1"></i>Vente
                {% elseif sale.type.value == 'ticket' %}
                    <i class="fas fa-ticket-alt me-1"></i>Ticket
                {% elseif sale.type.value == 'echange' %}
                    <i class="fas fa-exchange-alt me-1"></i>Échange
                {% endif %}
            </span>
            
            <h3 class="sale-card-title">{{ sale.title ?? 'Sans titre' }}</h3>
            
            {% if sale.description %}
                <p class="sale-card-description">{{ sale.description }}</p>
            {% endif %}
            
            {% if sale.amount %}
                <div class="sale-card-price">{{ sale.amount|number_format(2, ',', ' ') }} €</div>
            {% endif %}
            
            <div class="sale-card-buttons">
                {% if sale.amount and sale.amount > 0 and (sale.status.value == 'disponible' or sale.status.value == 'en attente') %}
                    <a href="{{ path('app_payment_page', {'id': sale.id}) }}" class="btn-sale-action btn-buy">
                        <i class="fas fa-shopping-cart"></i>
                        Acheter maintenant
                    </a>
                {% endif %}
                <a href="{{ path('app_sale_details', {'id': sale.id}) }}" class="btn-sale-action btn-details">
                    <i class="fas fa-eye"></i>
                    Voir détails
                </a>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="no-sales">
        <i class="fas fa-palette"></i>
        <h2 style="color: rgba(255,255,255,0.6); margin-bottom: 10px; font-family: 'Playfair Display', serif;">Aucune œuvre disponible</h2>
        <p>Il n'y a actuellement aucune œuvre en attente de vente.</p>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Filtres pour la galerie
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const type = this.dataset.type;
            
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            
            // Filtrer les cartes
            const cards = document.querySelectorAll('.sale-card');
            cards.forEach(card => {
                if (type === '' || card.dataset.type === type) {
                    card.style.display = 'block';
                    card.style.animation = 'fadeIn 0.5s ease';
                } else {
                    card.style.display = 'none';
                }
            });
            
            // Mettre à jour l'URL
            const url = new URL(window.location);
            if (type) {
                url.searchParams.set('type', type);
            } else {
                url.searchParams.delete('type');
            }
            window.history.pushState({}, '', url);
        });
    });

    // Appliquer le filtre initial depuis l'URL
    const urlParams = new URLSearchParams(window.location.search);
    const typeFilter = urlParams.get('type');
    if (typeFilter) {
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.classList.remove('active');
            if (btn.dataset.type === typeFilter) {
                btn.classList.add('active');
            }
        });
        
        const cards = document.querySelectorAll('.sale-card');
        cards.forEach(card => {
            if (card.dataset.type !== typeFilter) {
                card.style.display = 'none';
            }
        });
    }
});

// Fonction pour afficher l'image en modal
function showImageModal(imageSrc, title) {
    const modal = document.createElement('div');
    modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 9999; display: flex; align-items: center; justify-content: center; cursor: pointer;';
    modal.innerHTML = `
        <div style="max-width: 90%; max-height: 90%; text-align: center; position: relative;">
            <img src="${imageSrc}" alt="${title}" style="max-width: 100%; max-height: 90vh; border-radius: 8px; box-shadow: 0 10px 40px rgba(255,255,255,0.1);">
            <p style="color: white; margin-top: 20px; font-size: 1.2rem;">${title}</p>
            <button onclick="this.closest('div[style*=\"position: fixed\"]').remove()" 
                    style="position: absolute; top: 20px; right: 20px; background: rgba(255,255,255,0.2); border: none; color: white; width: 40px; height: 40px; border-radius: 50%; font-size: 1.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.3s;"
                    onmouseover="this.style.background='rgba(255,255,255,0.3)'"
                    onmouseout="this.style.background='rgba(255,255,255,0.2)'">
                ×
            </button>
        </div>
    `;
    modal.onclick = (e) => {
        if (e.target === modal) {
            modal.remove();
        }
    };
    document.body.appendChild(modal);
    
    // Fermer avec la touche Escape
    const closeOnEscape = (e) => {
        if (e.key === 'Escape') {
            modal.remove();
            document.removeEventListener('keydown', closeOnEscape);
        }
    };
    document.addEventListener('keydown', closeOnEscape);
}

// Animation fadeIn
const style = document.createElement('style');
style.textContent = `
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
`;
document.head.appendChild(style);
</script>
{% endblock %}

