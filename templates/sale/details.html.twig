{% extends 'base.html.twig' %}

{% block title %}{{ sale.title }} - Galerie{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    #layoutSidenav_content {
        min-height: 100vh;
        background: #0a0a0a;
        padding: 0;
    }

    .sale-details-container {
        padding: 40px 20px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        margin-bottom: 30px;
        transition: color 0.3s ease;
    }

    .back-link:hover {
        color: #667eea;
    }

    .sale-header {
        margin-bottom: 40px;
    }

    .sale-title {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 15px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .sale-meta {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }

    .meta-badge {
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .badge-status {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .badge-type {
        background: rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .badge-price {
        background: rgba(25, 135, 84, 0.2);
        color: #20c997;
        border: 1px solid rgba(25, 135, 84, 0.3);
    }

    .sale-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        margin-bottom: 40px;
    }

    @media (max-width: 968px) {
        .sale-content {
            grid-template-columns: 1fr;
        }
    }

    .gallery-section {
        position: relative;
    }

    .main-image {
        width: 100%;
        height: 500px;
        object-fit: cover;
        border-radius: 15px;
        margin-bottom: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        cursor: pointer;
    }

    .gallery-thumbnails {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 10px;
    }

    .thumbnail {
        width: 100%;
        height: 100px;
        object-fit: cover;
        border-radius: 8px;
        cursor: pointer;
        transition: transform 0.3s ease, opacity 0.3s ease;
        border: 2px solid transparent;
    }

    .thumbnail:hover {
        transform: scale(1.05);
        opacity: 0.8;
    }

    .thumbnail.active {
        border-color: #667eea;
    }

    .info-section {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 15px;
        padding: 30px;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .info-section h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        margin-bottom: 20px;
        color: #ffffff;
    }

    .description {
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.8;
        margin-bottom: 30px;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 15px;
        color: rgba(255, 255, 255, 0.7);
    }

    .info-item i {
        color: #667eea;
        width: 20px;
    }

    .price-display {
        font-size: 2.5rem;
        font-weight: 700;
        color: #20c997;
        margin: 20px 0;
    }

    .action-buttons {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-top: 30px;
    }

    .btn-primary-custom {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        padding: 15px 30px;
        border-radius: 10px;
        color: white;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-primary-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .btn-success-custom {
        background: linear-gradient(135deg, #198754 0%, #20c997 100%);
        border: none;
        padding: 15px 30px;
        border-radius: 10px;
        color: white;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .btn-success-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(25, 135, 84, 0.4);
        color: white;
    }
</style>
{% endblock %}

{% block body %}
<div class="sale-details-container">
    <a href="{{ path('app_home_sale') }}" class="back-link">
        <i class="fas fa-arrow-left"></i>
        Retour à la galerie
    </a>

    <div class="sale-header">
        <h1 class="sale-title">{{ sale.title }}</h1>
        <div class="sale-meta">
            <span class="meta-badge badge-status">{{ sale.status.value|upper }}</span>
            <span class="meta-badge badge-type">{{ sale.type.value|upper }}</span>
            {% if sale.amount %}
                <span class="meta-badge badge-price">{{ sale.amount|number_format(2, ',', ' ') }} €</span>
            {% endif %}
        </div>
    </div>

    <div class="sale-content">
        <!-- Galerie d'images -->
        <div class="gallery-section">
            {% set primaryImage = null %}
            {% set secondaryImages = [] %}
            {% for image in images %}
                {% if image.isPrimary %}
                    {% set primaryImage = image %}
                {% else %}
                    {% set secondaryImages = secondaryImages|merge([image]) %}
                {% endif %}
            {% endfor %}
            
            {% if primaryImage or sale.image %}
                <div style="margin-bottom: 20px;">
                    {% if primaryImage %}
                        <img src="{{ asset(primaryImage.path) }}" alt="{{ sale.title }}" 
                             class="main-image"
                             onclick="showImageModal('{{ asset(primaryImage.path) }}', '{{ sale.title }}')">
                    {% elseif sale.image %}
                        <img src="{{ asset(sale.image) }}" alt="{{ sale.title }}" 
                             class="main-image"
                             onclick="showImageModal('{{ asset(sale.image) }}', '{{ sale.title }}')">
                    {% endif %}
                </div>
                
                {% if secondaryImages|length > 0 %}
                    <div class="gallery-thumbnails">
                        {% for image in secondaryImages %}
                            <img src="{{ asset(image.path) }}" alt="{{ sale.title }}" 
                                 class="thumbnail"
                                 onclick="showImageModal('{{ asset(image.path) }}', '{{ sale.title }}')">
                        {% endfor %}
                    </div>
                {% endif %}
            {% else %}
                <div class="main-image" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-image" style="font-size: 4rem; opacity: 0.3;"></i>
                </div>
            {% endif %}
        </div>

        <!-- Informations et actions -->
        <div class="info-section">
            <h3>Détails de l'œuvre</h3>
            
            {% if sale.description %}
                <div class="description">{{ sale.description|nl2br }}</div>
            {% endif %}

            {% if sale.amount %}
                <div class="price-display">{{ sale.amount|number_format(2, ',', ' ') }} €</div>
            {% endif %}

            <div class="info-item">
                <i class="fas fa-map-marker-alt"></i>
                <span>{{ sale.location ?: 'Non spécifié' }}</span>
            </div>

            {% if sale.contactInfo %}
                <div class="info-item">
                    <i class="fas fa-envelope"></i>
                    <span>{{ sale.contactInfo }}</span>
                </div>
            {% endif %}

            <div class="info-item">
                <i class="fas fa-calendar"></i>
                <span>Publié le {{ sale.createdAt|date('d/m/Y') }}</span>
            </div>

            <div class="action-buttons">
                {% if sale.status.value == 'disponible' or sale.status.value == 'en attente' %}
                    {% if sale.amount and sale.amount > 0 %}
                        <a href="{{ path('app_payment_page', {'id': sale.id}) }}" class="btn-success-custom">
                            <i class="fas fa-shopping-cart"></i>
                            Acheter maintenant ({{ sale.amount|number_format(2, ',', ' ') }} €)
                        </a>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function showImageModal(imageSrc, title) {
    const modal = document.createElement('div');
    modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 9999; display: flex; align-items: center; justify-content: center; cursor: pointer;';
    modal.innerHTML = `
        <div style="max-width: 90%; max-height: 90%; text-align: center; position: relative;">
            <img src="${imageSrc}" alt="${title}" style="max-width: 100%; max-height: 90vh; border-radius: 8px; box-shadow: 0 10px 40px rgba(255,255,255,0.1);">
            <p style="color: white; margin-top: 20px; font-size: 1.2rem;">${title}</p>
            <button onclick="this.closest('div[style*=\"position: fixed\"]').remove()" 
                    style="position: absolute; top: 20px; right: 20px; background: rgba(255,255,255,0.2); border: none; color: white; width: 40px; height: 40px; border-radius: 50%; font-size: 1.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.3s;"
                    onmouseover="this.style.background='rgba(255,255,255,0.3)'"
                    onmouseout="this.style.background='rgba(255,255,255,0.2)'">
                ×
            </button>
        </div>
    `;
    modal.onclick = (e) => {
        if (e.target === modal) {
            modal.remove();
        }
    };
    document.body.appendChild(modal);
    
    const closeOnEscape = (e) => {
        if (e.key === 'Escape') {
            modal.remove();
            document.removeEventListener('keydown', closeOnEscape);
        }
    };
    document.addEventListener('keydown', closeOnEscape);
}
</script>
{% endblock %}

