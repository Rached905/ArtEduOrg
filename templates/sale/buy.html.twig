{% extends 'basec.html.twig' %}

{% block title %}Acheter {{ sale.title }} - ArtMarket{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .buy-container {
        max-width: 900px;
        margin: 2rem auto;
        padding: 2rem;
    }

    .buy-header {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e9ecef;
    }

    .buy-header h1 {
        color: var(--dark-color);
        font-weight: 700;
        margin-bottom: 0.5rem;
        font-size: 2.2rem;
    }

    .breadcrumb {
        background: none;
        padding: 0;
        margin: 0;
    }

    .breadcrumb-item a {
        color: var(--accent-color);
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .breadcrumb-item a:hover {
        color: #d63850;
    }

    .breadcrumb-item.active {
        color: #6c757d;
    }

    .buy-card {
        background: white;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        animation: slideIn 0.5s ease-out;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .artwork-preview {
        display: flex;
        gap: 2rem;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
        border-left: 4px solid var(--accent-color);
    }

    .artwork-preview-image {
        width: 150px;
        height: 150px;
        border-radius: 12px;
        object-fit: cover;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    }

    .artwork-preview-info {
        flex: 1;
    }

    .artwork-preview-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dark-color);
        margin-bottom: 0.5rem;
    }

    .artwork-preview-price {
        font-size: 1.8rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--accent-color) 0%, #d63850 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.5rem;
    }

    .artwork-preview-artist {
        color: #6c757d;
        font-size: 0.95rem;
    }

    .artwork-preview-artist i {
        color: var(--accent-color);
        margin-right: 0.5rem;
    }

    .form-section {
        margin-bottom: 2rem;
    }

    .form-section-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--dark-color);
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: var(--dark-color);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-label .required {
        color: var(--accent-color);
        margin-left: 0.25rem;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: white;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--accent-color);
        box-shadow: 0 0 0 4px rgba(233, 69, 96, 0.1);
    }

    .form-control::placeholder {
        color: #adb5bd;
    }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
        font-family: inherit;
    }

    .form-help {
        font-size: 0.85rem;
        color: #6c757d;
        margin-top: 0.5rem;
    }

    .form-help i {
        color: var(--accent-color);
        margin-right: 0.25rem;
    }

    .action-buttons {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 2px solid #e9ecef;
        flex-wrap: wrap;
    }

    .btn-submit {
        flex: 1;
        min-width: 200px;
        padding: 16px 32px;
        background: linear-gradient(135deg, var(--accent-color) 0%, #d63850 100%);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 700;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 8px 25px rgba(233, 69, 96, 0.3);
        cursor: pointer;
    }

    .btn-submit:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(233, 69, 96, 0.4);
    }

    .btn-cancel {
        padding: 16px 32px;
        background: white;
        color: #6c757d;
        border: 2px solid #e9ecef;
        border-radius: 15px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .btn-cancel:hover {
        background: #f8f9fa;
        border-color: #dee2e6;
        color: var(--dark-color);
        transform: translateY(-2px);
    }

    .info-box {
        padding: 1.5rem;
        background: linear-gradient(135deg, rgba(233, 69, 96, 0.1) 0%, rgba(233, 69, 96, 0.05) 100%);
        border-radius: 12px;
        border-left: 4px solid var(--accent-color);
        margin-bottom: 2rem;
    }

    .info-box-title {
        font-weight: 700;
        color: var(--dark-color);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .info-box-text {
        color: #555;
        line-height: 1.6;
        margin: 0;
    }

    .info-box-text i {
        color: var(--accent-color);
        margin-right: 0.5rem;
    }

    @media (max-width: 768px) {
        .buy-container {
            padding: 1rem;
        }

        .buy-card {
            padding: 20px;
        }

        .buy-header h1 {
            font-size: 1.8rem;
        }

        .artwork-preview {
            flex-direction: column;
        }

        .artwork-preview-image {
            width: 100%;
            height: 200px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-submit,
        .btn-cancel {
            width: 100%;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="buy-container">
    <div class="buy-header">
        <h1><i class="fas fa-shopping-cart me-2"></i>Acheter une Œuvre</h1>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ path('app_client') }}"><i class="fas fa-home"></i> Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_client') }}#nos-oeuvres">Nos Oeuvres</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_sale_details', {'id': sale.id}) }}">{{ sale.title }}</a></li>
            <li class="breadcrumb-item active">Achat</li>
        </ol>
    </div>

    <div class="buy-card">
        {# Artwork Preview #}
        <div class="artwork-preview">
            {% set primaryImage = sale.getPrimaryImage() %}
            {% if primaryImage %}
                <img src="{{ asset(primaryImage.path) }}" alt="{{ sale.title }}" class="artwork-preview-image">
            {% elseif sale.image %}
                <img src="{{ asset(sale.image) }}" alt="{{ sale.title }}" class="artwork-preview-image">
            {% else %}
                <div class="artwork-preview-image" style="background: #e9ecef; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-image fa-3x text-muted"></i>
                </div>
            {% endif %}
            <div class="artwork-preview-info">
                <div class="artwork-preview-title">{{ sale.title }}</div>
                <div class="artwork-preview-price">
                    {{ sale.amount ? sale.amount|number_format(0, ',', ' ') ~ ' €' : 'Prix sur demande' }}
                </div>
                {% if sale.vendeur %}
                    <div class="artwork-preview-artist">
                        <i class="fas fa-user"></i>
                        Artiste : {{ sale.vendeur.fullname }}
                    </div>
                {% endif %}
            </div>
        </div>

        {# Info Box #}
        <div class="info-box">
            <div class="info-box-title">
                <i class="fas fa-info-circle"></i>
                Comment ça fonctionne ?
            </div>
            <p class="info-box-text">
                <i class="fas fa-check-circle"></i> Remplissez le formulaire ci-dessous avec vos informations de contact.<br>
                <i class="fas fa-check-circle"></i> Le vendeur recevra votre demande d'achat et vous contactera dans les plus brefs délais.<br>
                <i class="fas fa-check-circle"></i> Vous pourrez ensuite finaliser l'achat directement avec le vendeur.
            </p>
        </div>

        {# Purchase Form #}
        <form method="POST" action="{{ path('app_sale_buy', {'id': sale.id}) }}">
            <div class="form-section">
                <h3 class="form-section-title">
                    <i class="fas fa-user"></i>
                    Vos Informations
                </h3>

                <div class="form-group">
                    <label for="name" class="form-label">
                        Nom complet <span class="required">*</span>
                    </label>
                    <input type="text" 
                           id="name" 
                           name="name" 
                           class="form-control" 
                           placeholder="Votre nom complet"
                           value="{{ app.user ? app.user.fullname : '' }}"
                           required>
                    <div class="form-help">
                        <i class="fas fa-info-circle"></i>
                        Le nom qui sera utilisé pour la transaction
                    </div>
                </div>

                <div class="form-group">
                    <label for="email" class="form-label">
                        Adresse email <span class="required">*</span>
                    </label>
                    <input type="email" 
                           id="email" 
                           name="email" 
                           class="form-control" 
                           placeholder="votre.email@exemple.com"
                           value="{{ app.user ? app.user.email : '' }}"
                           required>
                    <div class="form-help">
                        <i class="fas fa-info-circle"></i>
                        Le vendeur vous contactera à cette adresse
                    </div>
                </div>

                <div class="form-group">
                    <label for="phone" class="form-label">
                        Téléphone
                    </label>
                    <input type="tel" 
                           id="phone" 
                           name="phone" 
                           class="form-control" 
                           placeholder="+33 6 12 34 56 78">
                    <div class="form-help">
                        <i class="fas fa-info-circle"></i>
                        Facultatif, mais recommandé pour un contact plus rapide
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3 class="form-section-title">
                    <i class="fas fa-comment"></i>
                    Message (Optionnel)
                </h3>

                <div class="form-group">
                    <label for="message" class="form-label">
                        Message pour le vendeur
                    </label>
                    <textarea id="message" 
                              name="message" 
                              class="form-control" 
                              placeholder="Bonjour, je suis intéressé(e) par cette œuvre. Pourriez-vous me donner plus d'informations sur..."></textarea>
                    <div class="form-help">
                        <i class="fas fa-info-circle"></i>
                        Vous pouvez poser des questions ou donner des informations supplémentaires
                    </div>
                </div>
            </div>

            <div class="action-buttons">
                <button type="submit" class="btn-submit">
                    <i class="fas fa-paper-plane"></i>
                    Envoyer ma demande d'achat
                </button>
                <a href="{{ path('app_sale_details', {'id': sale.id}) }}" class="btn-cancel">
                    <i class="fas fa-times"></i>
                    Annuler
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}

