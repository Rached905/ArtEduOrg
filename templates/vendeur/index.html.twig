{% extends 'basev.html.twig' %}

{% block title %}Dashboard Vendeur - ArtMarket{% endblock %}

{% block body %}
<div class="vendeur-dashboard">
    
    {# Welcome Section #}
    <div class="welcome-section">
        <div class="welcome-content">
            <div class="welcome-text">
                <h1 class="dashboard-title">
                    Bonjour, <span class="gradient-text">{{ app.user.fullname ?? 'Vendeur' }}</span> 👋
                </h1>
                <p class="dashboard-subtitle">Voici un aperçu de votre activité artistique aujourd'hui</p>
            </div>
            <div class="welcome-date">
                <div class="date-card">
                    <i class="fas fa-calendar-day"></i>
                    <span id="currentDate"></span>
                </div>
            </div>
        </div>
    </div>

    {# Quick Stats Cards #}
    <div class="stats-grid">
        <div class="stat-card stat-card-1">
            <div class="stat-icon">
                <i class="fas fa-palette"></i>
            </div>
            <div class="stat-content">
                <h3 class="stat-value">{{ totalSales }}</h3>
                <p class="stat-label">Œuvres publiées</p>
            </div>
            <div class="stat-trend up">
                <i class="fas fa-check"></i>
            </div>
        </div>

        <div class="stat-card stat-card-2">
            <div class="stat-icon">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <div class="stat-content">
                <h3 class="stat-value">{{ activeSales }}</h3>
                <p class="stat-label">Ventes actives</p>
            </div>
            <div class="stat-trend up">
                <i class="fas fa-check"></i>
            </div>
        </div>

        <div class="stat-card stat-card-3">
            <div class="stat-icon">
                <i class="fas fa-euro-sign"></i>
            </div>
            <div class="stat-content">
                <h3 class="stat-value">{{ monthlyRevenue|number_format(0, ',', ' ') }}€</h3>
                <p class="stat-label">Revenus du mois</p>
            </div>
            <div class="stat-trend up">
                <i class="fas fa-arrow-up"></i> {{ monthlyRevenue > 0 ? '15%' : '0%' }}
            </div>
        </div>

        <div class="stat-card stat-card-4">
            <div class="stat-icon">
                <i class="fas fa-eye"></i>
            </div>
            <div class="stat-content">
                <h3 class="stat-value">{{ totalViews|number_format(0, ',', ' ') }}</h3>
                <p class="stat-label">Vues totales</p>
            </div>
            <div class="stat-trend up">
                <i class="fas fa-arrow-up"></i> {{ totalViews > 0 ? '25%' : '0%' }}
            </div>
        </div>
    </div>

    {# Quick Actions #}
    <div class="quick-actions">
        <h2 class="section-title">
            <i class="fas fa-bolt"></i> Actions rapides
        </h2>
        <div class="actions-grid">
            <a href="{{ path('app_sale_new') }}" class="action-card">
                <div class="action-icon action-icon-1">
                    <i class="fas fa-plus-circle"></i>
                </div>
                <h4>Ajouter une œuvre</h4>
                <p>Publier une nouvelle création</p>
            </a>

            <a href="#" class="action-card">
                <div class="action-icon action-icon-2">
                    <i class="fas fa-calendar-plus"></i>
                </div>
                <h4>Créer un événement</h4>
                <p>Organiser une exposition</p>
            </a>

            <a href="#" class="action-card">
                <div class="action-icon action-icon-3">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h4>Voir les statistiques</h4>
                <p>Analyser vos performances</p>
            </a>

            <a href="#" class="action-card">
                <div class="action-icon action-icon-4">
                    <i class="fas fa-comments"></i>
                </div>
                <h4>Messages</h4>
                <p>Communiquer avec les clients</p>
            </a>
        </div>
    </div>

    {# Recent Activity & Charts #}
    <div class="content-grid">
        {# Recent Orders #}
        <div class="content-card">
            <div class="card-header">
                <h3><i class="fas fa-shopping-bag"></i> Commandes récentes</h3>
                <a href="{{ path('app_sale_index') }}" class="view-all">Voir tout <i class="fas fa-arrow-right"></i></a>
            </div>
            <div class="orders-list">
                {% if recentOrders|length > 0 %}
                    {% for order in recentOrders %}
                        {% set orderDate = order.updatedAt ?? order.createdAt %}
                        {% if orderDate %}
                            {% set now = 'now'|date('U') %}
                            {% set orderTimestamp = orderDate|date('U') %}
                            {% set diff = now - orderTimestamp %}
                            {% set daysDiff = (diff / 86400)|round(0, 'floor') %}
                            {% set hoursDiff = (diff / 3600)|round(0, 'floor') %}
                            
                            {% if daysDiff == 0 %}
                                {% if hoursDiff == 0 %}
                                    {% set dateText = "Il y a moins d'une heure" %}
                                {% elseif hoursDiff == 1 %}
                                    {% set dateText = "Il y a 1 heure" %}
                                {% else %}
                                    {% set dateText = "Il y a " ~ hoursDiff ~ " heures" %}
                                {% endif %}
                            {% elseif daysDiff == 1 %}
                                {% set dateText = "Hier" %}
                            {% else %}
                                {% set dateText = "Il y a " ~ daysDiff ~ " jours" %}
                            {% endif %}
                        {% else %}
                            {% set dateText = "Date inconnue" %}
                        {% endif %}
                        
                        {% set statusValue = order.status.value %}
                        {% set statusClass = 'status-pending' %}
                        {% set statusIcon = 'fa-clock' %}
                        {% set statusText = 'En attente' %}
                        
                        {% if statusValue == 'vendue' %}
                            {% set statusClass = 'status-confirmed' %}
                            {% set statusIcon = 'fa-check' %}
                            {% set statusText = 'Vendue' %}
                        {% elseif statusValue == 'paye' or statusValue == 'payer' %}
                            {% set statusClass = 'status-delivered' %}
                            {% set statusIcon = 'fa-check-circle' %}
                            {% set statusText = 'Payée' %}
                        {% elseif statusValue == 'payement en cours' %}
                            {% set statusClass = 'status-shipped' %}
                            {% set statusIcon = 'fa-shipping-fast' %}
                            {% set statusText = 'Paiement en cours' %}
                        {% endif %}
                        
                        {% set artworkEmoji = '🎨' %}
                        {% if order.type %}
                            {% if order.type.value == 'peinture' %}
                                {% set artworkEmoji = '🎨' %}
                            {% elseif order.type.value == 'sculpture' %}
                                {% set artworkEmoji = '🗿' %}
                            {% elseif order.type.value == 'photographie' %}
                                {% set artworkEmoji = '📷' %}
                            {% elseif order.type.value == 'dessin' %}
                                {% set artworkEmoji = '✏️' %}
                            {% else %}
                                {% set artworkEmoji = '🖼️' %}
                            {% endif %}
                        {% endif %}
                        
                        <div class="order-item">
                            <div class="order-artwork">
                                <div class="artwork-thumb">{{ artworkEmoji }}</div>
                                <div class="order-info">
                                    <h5>{{ order.title }}</h5>
                                    <span class="order-date">{{ dateText }}</span>
                                </div>
                            </div>
                            <div class="order-status {{ statusClass }}">
                                <i class="fas {{ statusIcon }}"></i> {{ statusText }}
                            </div>
                            <div class="order-price">{{ order.amount ? order.amount|number_format(0, ',', ' ') ~ '€' : 'N/A' }}</div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="text-center py-4 text-muted">
                        <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                        <p>Aucune commande récente</p>
                    </div>
                {% endif %}
            </div>
        </div>

        {# Performance Chart #}
        <div class="content-card">
            <div class="card-header">
                <h3><i class="fas fa-chart-bar"></i> Performance des ventes</h3>
                <select class="period-select">
                    <option>7 derniers jours</option>
                    <option>30 derniers jours</option>
                    <option>Cette année</option>
                </select>
            </div>
            <div class="chart-container">
                <canvas id="salesChart"></canvas>
            </div>
        </div>
    </div>

    {# Popular Artworks #}
    <div class="popular-section">
        <div class="card-header">
            <h3><i class="fas fa-fire"></i> Vos œuvres populaires</h3>
            <div style="display: flex; gap: 15px; align-items: center;">
                <a href="{{ path('app_sale_new') }}" class="btn-add-artwork" style="background: var(--accent-color); color: white; padding: 10px 20px; border-radius: 10px; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 8px;">
                    <i class="fas fa-plus"></i> Ajouter une œuvre
                </a>
                <a href="{{ path('app_sale_index') }}" class="view-all">Voir tout <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
        <div class="artworks-grid">
            {% if sales|length > 0 %}
                {% for sale in sales %}
                    <div class="artwork-card">
                        <div class="artwork-image">
                            {% set primaryImage = sale.getPrimaryImage() %}
                            {% if primaryImage %}
                                <img src="{{ asset(primaryImage.path) }}" alt="{{ sale.title }}" style="width: 100%; height: 100%; object-fit: cover;">
                            {% elseif sale.image %}
                                <img src="{{ asset(sale.image) }}" alt="{{ sale.title }}" style="width: 100%; height: 100%; object-fit: cover;">
                            {% else %}
                                <div class="artwork-placeholder">🎨</div>
                            {% endif %}
                            {% if sale.status.value == 'vendue' %}
                                <div class="artwork-badge" style="background: #4caf50;">Vendue</div>
                            {% elseif sale.status.value == 'en attente' %}
                                <div class="artwork-badge" style="background: #ff9800;">En attente</div>
                            {% else %}
                                <div class="artwork-badge">Disponible</div>
                            {% endif %}
                        </div>
                        <div class="artwork-info">
                            <h4>{{ sale.title }}</h4>
                            <div class="artwork-stats">
                                <span><i class="fas fa-calendar"></i> {{ sale.createdAt|date('d/m/Y') }}</span>
                                <span><i class="fas fa-tag"></i> {{ sale.type.value }}</span>
                            </div>
                            <div class="artwork-price">{% if sale.amount %}{{ sale.amount }}€{% else %}Prix sur demande{% endif %}</div>
                            <div class="artwork-actions" style="display: flex; gap: 10px; margin-top: 15px;">
                                <a href="{{ path('app_sale_details', {id: sale.id}) }}" class="btn-action btn-view" style="flex: 1; padding: 8px; background: #f0f0f0; border-radius: 8px; text-align: center; text-decoration: none; color: var(--dark-color); font-size: 0.9rem;">
                                    <i class="fas fa-eye"></i> Consulter
                                </a>
                                <a href="{{ path('app_sale_edit', {id: sale.id}) }}" class="btn-action btn-edit" style="flex: 1; padding: 8px; background: #2196f3; border-radius: 8px; text-align: center; text-decoration: none; color: white; font-size: 0.9rem;">
                                    <i class="fas fa-edit"></i> Modifier
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #999;">
                    <i class="fas fa-palette" style="font-size: 3rem; margin-bottom: 20px; display: block;"></i>
                    <p style="font-size: 1.2rem; margin-bottom: 20px;">Aucune œuvre publiée pour le moment</p>
                    <a href="{{ path('app_sale_new') }}" class="btn-add-artwork" style="background: var(--accent-color); color: white; padding: 12px 30px; border-radius: 10px; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 8px;">
                        <i class="fas fa-plus"></i> Ajouter votre première œuvre
                    </a>
                </div>
            {% endif %}
        </div>
    </div>

</div>

<style>
:root {
    --primary-gradient: linear-gradient(135deg, #e94560 0%, #d63850 100%);
    --secondary-gradient: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    --accent-color: #e94560;
    --dark-color: #1a1a2e;
    --light-bg: #f8f9fa;
}

.vendeur-dashboard {
    padding: 0;
}

/* Welcome Section */
.welcome-section {
    background: var(--secondary-gradient);
    padding: 40px;
    border-radius: 20px;
    margin-bottom: 30px;
    color: white;
    box-shadow: 0 10px 40px rgba(0,0,0,0.15);
}

.welcome-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
}

.dashboard-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 10px;
}

.gradient-text {
    background: linear-gradient(135deg, #ffffff 0%, #ffccdd 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.dashboard-subtitle {
    font-size: 1.1rem;
    opacity: 0.9;
}

.date-card {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    padding: 15px 25px;
    border-radius: 50px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1rem;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.2);
}

/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
    margin-bottom: 40px;
}

.stat-card {
    background: white;
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
    border: 2px solid transparent;
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--primary-gradient);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.stat-card:hover::before {
    transform: scaleX(1);
}

.stat-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 50px rgba(233, 69, 96, 0.2);
    border-color: var(--accent-color);
}

.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    margin-bottom: 20px;
    color: white;
}

.stat-card-1 .stat-icon {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.stat-card-2 .stat-icon {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.stat-card-3 .stat-icon {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.stat-card-4 .stat-icon {
    background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.stat-value {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--dark-color);
    margin-bottom: 5px;
}

.stat-label {
    color: #666;
    font-size: 0.95rem;
    font-weight: 500;
}

.stat-trend {
    position: absolute;
    top: 20px;
    right: 20px;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
}

.stat-trend.up {
    background: rgba(67, 233, 123, 0.15);
    color: #43e97b;
}

.stat-trend.down {
    background: rgba(245, 87, 108, 0.15);
    color: #f5576c;
}

/* Quick Actions */
.quick-actions {
    margin-bottom: 40px;
}

.section-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--dark-color);
    margin-bottom: 25px;
    display: flex;
    align-items: center;
    gap: 12px;
}

.section-title i {
    color: var(--accent-color);
}

.actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
}

.action-card {
    background: white;
    border-radius: 18px;
    padding: 30px 25px;
    text-align: center;
    transition: all 0.4s ease;
    text-decoration: none;
    color: inherit;
    border: 2px solid #f0f0f0;
}

.action-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.12);
    border-color: var(--accent-color);
}

.action-icon {
    width: 70px;
    height: 70px;
    border-radius: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    margin-bottom: 20px;
    color: white;
    transition: all 0.4s ease;
}

.action-card:hover .action-icon {
    transform: scale(1.1) rotate(5deg);
}

.action-icon-1 {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.action-icon-2 {
    background: var(--primary-gradient);
}

.action-icon-3 {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.action-icon-4 {
    background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.action-card h4 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--dark-color);
    margin-bottom: 8px;
}

.action-card p {
    color: #666;
    font-size: 0.9rem;
    margin: 0;
}

/* Content Grid */
.content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
    gap: 30px;
    margin-bottom: 40px;
}

.content-card {
    background: white;
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 2px solid #f0f0f0;
}

.card-header h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--dark-color);
    display: flex;
    align-items: center;
    gap: 10px;
}

.card-header i {
    color: var(--accent-color);
}

.view-all {
    color: var(--accent-color);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 5px;
}

.view-all:hover {
    gap: 10px;
}

.period-select {
    padding: 8px 15px;
    border: 2px solid #f0f0f0;
    border-radius: 10px;
    font-weight: 600;
    color: var(--dark-color);
    cursor: pointer;
    transition: all 0.3s ease;
}

.period-select:focus {
    outline: none;
    border-color: var(--accent-color);
}

/* Orders List */
.orders-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.order-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    background: #f8f9fa;
    border-radius: 15px;
    transition: all 0.3s ease;
}

.order-item:hover {
    background: #f0f0f0;
    transform: translateX(5px);
}

.order-artwork {
    display: flex;
    align-items: center;
    gap: 15px;
    flex: 1;
}

.artwork-thumb {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
}

.order-info h5 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--dark-color);
    margin-bottom: 5px;
}

.order-date {
    font-size: 0.85rem;
    color: #999;
}

.order-status {
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
}

.status-pending {
    background: rgba(255, 193, 7, 0.15);
    color: #ffc107;
}

.status-confirmed {
    background: rgba(33, 150, 243, 0.15);
    color: #2196f3;
}

.status-shipped {
    background: rgba(156, 39, 176, 0.15);
    color: #9c27b0;
}

.status-delivered {
    background: rgba(76, 175, 80, 0.15);
    color: #4caf50;
}

.order-price {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--accent-color);
    min-width: 100px;
    text-align: right;
}

/* Chart */
.chart-container {
    height: 300px;
    position: relative;
}

/* Popular Artworks */
.popular-section {
    background: white;
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
}

.artworks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 25px;
}

.artwork-card {
    background: white;
    border-radius: 18px;
    overflow: hidden;
    border: 2px solid #f0f0f0;
    transition: all 0.4s ease;
}

.artwork-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.15);
    border-color: var(--accent-color);
}

.artwork-image {
    position: relative;
    height: 200px;
    background: linear-gradient(135deg, #f8f9fa 0%, #e8ecf1 100%);
    display: flex;
    align-items: center;
    justify-content: center;
}

.artwork-placeholder {
    font-size: 4rem;
}

.artwork-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    padding: 6px 15px;
    background: var(--primary-gradient);
    color: white;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
}

.artwork-info {
    padding: 20px;
}

.artwork-info h4 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--dark-color);
    margin-bottom: 12px;
}

.artwork-stats {
    display: flex;
    gap: 20px;
    margin-bottom: 12px;
    font-size: 0.9rem;
    color: #666;
}

.artwork-stats span {
    display: flex;
    align-items: center;
    gap: 5px;
}

.artwork-price {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--accent-color);
}

/* Responsive */
@media (max-width: 768px) {
    .dashboard-title {
        font-size: 1.8rem;
    }
    
    .content-grid {
        grid-template-columns: 1fr;
    }
    
    .stats-grid {
        grid-template-columns: 1fr;
    }
    
    .actions-grid {
        grid-template-columns: 1fr;
    }
    
    .order-item {
        flex-wrap: wrap;
        gap: 15px;
    }
    
    .artworks-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Current Date
document.getElementById('currentDate').textContent = new Date().toLocaleDateString('fr-FR', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric'
});

// Sales Chart
const ctx = document.getElementById('salesChart');
if (ctx) {
    // Préparer les données dynamiques
    const salesData = {{ salesByDay|json_encode|raw }};
    
    // Générer les 7 derniers jours avec leurs noms
    const days = ['Dim', 'Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam'];
    const labels = [];
    const data = [];
    
    // Créer un tableau pour les 7 derniers jours
    for (let i = 6; i >= 0; i--) {
        const date = new Date();
        date.setDate(date.getDate() - i);
        const dateKey = date.toISOString().split('T')[0];
        const dayName = days[date.getDay()];
        
        labels.push(dayName);
        data.push(salesData[dateKey] || 0);
    }
    
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Ventes (€)',
                data: data,
                borderColor: '#e94560',
                backgroundColor: 'rgba(233, 69, 96, 0.1)',
                borderWidth: 3,
                fill: true,
                tension: 0.4,
                pointBackgroundColor: '#e94560',
                pointBorderColor: '#fff',
                pointBorderWidth: 3,
                pointRadius: 6,
                pointHoverRadius: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return 'Ventes: ' + context.parsed.y.toFixed(2) + ' €';
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(0, 0, 0, 0.05)'
                    },
                    ticks: {
                        callback: function(value) {
                            return value.toFixed(0) + ' €';
                        }
                    }
                },
                x: {
                    grid: {
                        display: false
                    }
                }
            }
        }
    });
}
</script>
{% endblock %}