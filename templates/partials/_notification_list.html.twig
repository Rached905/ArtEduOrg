<div class="notification-list">
    {% if notifications|length == 0 %}
        <p class="text-muted text-center py-5">Aucune notification.</p>
    {% else %}
        <ul class="list-group list-group-flush">
            {% for notif in notifications %}
                <li class="list-group-item d-flex justify-content-between align-items-start {{ notif.isRead ? '' : 'bg-light' }}">
                    <div class="ms-2 me-auto">
                        {% if notif.type == 'purchased' %}
                            <span class="fw-bold">Vous avez acheté : {{ notif.sale.title }}</span>
                            <p class="mb-0 small text-muted">Le {{ notif.createdAt|date('d/m/Y à H:i') }}</p>
                        {% else %}
                            <span class="fw-bold">Votre œuvre a été vendue : {{ notif.sale.title }}</span>
                            <p class="mb-0 small text-muted">Le {{ notif.createdAt|date('d/m/Y à H:i') }}</p>
                        {% endif %}
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <a href="{{ path('app_sale_details', {id: notif.sale.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                        {% if not notif.isRead %}
                            <form method="post" action="{{ path('app_notification_mark_read', {id: notif.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('notification_read') }}">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Marquer lu</button>
                            </form>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
