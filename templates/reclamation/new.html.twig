{% extends 'basec.html.twig' %}

{% block title %}Nouvelle Réclamation{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Ajustements pour la page de réclamation */
    .reclamation-wrapper {
        padding: 2rem 0;
    }

    .reclamation-form-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        background: white;
    }

    .form-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2.5rem 2rem;
        text-align: center;
    }

    .form-header i {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.9;
    }

    .form-header h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 600;
        font-family: 'Poppins', sans-serif;
    }

    .form-header p {
        margin: 0.8rem 0 0 0;
        opacity: 0.95;
        font-size: 1rem;
    }

    .form-body {
        padding: 2.5rem;
    }

    .form-label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.6rem;
        font-size: 0.95rem;
    }

    .form-control, 
    .form-select {
        border-radius: 10px;
        border: 2px solid #e2e8f0;
        padding: 0.75rem 1rem;
        transition: all 0.3s ease;
        font-size: 0.95rem;
        background: white;
    }

    .form-control:focus, 
    .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.15);
        outline: none;
    }

    .form-control:disabled,
    .form-select:disabled {
        background-color: #f7fafc;
        cursor: not-allowed;
    }

    textarea.form-control {
        resize: vertical;
        min-height: 150px;
    }

    .btn-submit {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 0.875rem 2.5rem;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        font-size: 1rem;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .btn-submit:active {
        transform: translateY(0);
    }

    .btn-cancel {
        border: 2px solid #cbd5e0;
        color: #4a5568;
        background: white;
        padding: 0.875rem 2.5rem;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-cancel:hover {
        background-color: #f7fafc;
        border-color: #a0aec0;
        color: #2d3748;
        transform: translateY(-2px);
    }

    .user-info-badge {
        background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
        padding: 1.25rem;
        border-radius: 12px;
        margin-bottom: 2rem;
        border-left: 4px solid #667eea;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .user-info-badge i.fa-user-circle {
        color: #667eea;
        font-size: 2.5rem;
    }

    .user-info-badge strong {
        color: #2d3748;
        font-size: 1rem;
    }

    .user-info-badge .text-muted {
        color: #718096 !important;
        font-size: 0.9rem;
    }

    .required-field::after {
        content: " *";
        color: #e53e3e;
        font-weight: 700;
    }

    .info-alert {
        background: linear-gradient(135deg, #ebf4ff 0%, #e1f0ff 100%);
        border: none;
        border-left: 4px solid #4299e1;
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 2rem;
        box-shadow: 0 2px 8px rgba(66, 153, 225, 0.1);
    }

    .info-alert .alert-heading {
        color: #2c5282;
        font-weight: 600;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .info-alert ul {
        margin-bottom: 0;
        padding-left: 1.5rem;
        color: #2d3748;
    }

    .info-alert li {
        margin-bottom: 0.5rem;
        line-height: 1.6;
    }

    .info-alert li:last-child {
        margin-bottom: 0;
    }

    .form-text {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #718096;
        font-size: 0.875rem;
        margin-top: 0.5rem;
    }

    .form-text i {
        color: #4299e1;
    }

    /* Alert messages */
    .alert {
        border-radius: 12px;
        border: none;
        padding: 1rem 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .alert-success {
        background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
        color: #155724;
    }

    .alert-success i {
        color: #28a745;
    }

    /* Divider */
    hr {
        border: none;
        height: 2px;
        background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
        margin: 2rem 0;
    }

    /* Form errors */
    .form-error-message {
        color: #e53e3e;
        font-size: 0.875rem;
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .form-error-message::before {
        content: "⚠";
    }

    /* Animation d'entrée */
    @keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .reclamation-form-card {
        animation: slideInUp 0.6s ease-out;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .form-body {
            padding: 1.5rem;
        }

        .form-header {
            padding: 2rem 1.5rem;
        }

        .form-header h1 {
            font-size: 1.5rem;
        }

        .btn-submit,
        .btn-cancel {
            width: 100%;
            margin-bottom: 0.75rem;
        }

        .d-flex.gap-3 {
            flex-direction: column;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="reclamation-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9 col-xl-8">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>{{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                <div class="reclamation-form-card">
                    <div class="form-header">
                        <i class="fas fa-file-alt"></i>
                        <h1>Nouvelle Réclamation</h1>
                        <p>Décrivez votre problème et nous vous répondrons dans les plus brefs délais</p>
                    </div>

                    <div class="form-body">
                        <!-- Informations de l'utilisateur connecté -->
                        <div class="user-info-badge">
                            <div class="d-flex align-items-center gap-3">
                                <i class="fas fa-user-circle"></i>
                                <div class="flex-grow-1">
                                    <strong>Utilisateur connecté :</strong><br>
                                    <span class="text-muted">
                                        <i class="fas fa-id-badge me-1"></i>ID: {{ app.user.id }}
                                    </span>
                                    {% if app.user.email %}
                                        <span class="text-muted ms-3">
                                            <i class="fas fa-envelope me-1"></i>{{ app.user.email }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                        <div class="mb-4">
                            {{ form_label(form.objet, 'Objet de la réclamation', {'label_attr': {'class': 'form-label required-field'}}) }}
                            {{ form_widget(form.objet, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Problème de livraison'}}) }}
                            {{ form_errors(form.objet) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.description, 'Description détaillée', {'label_attr': {'class': 'form-label required-field'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '6', 'placeholder': 'Décrivez votre problème en détail...'}}) }}
                            {{ form_errors(form.description) }}
                            <small class="form-text">
                                <i class="fas fa-info-circle"></i>
                                Plus votre description est détaillée, plus nous pourrons vous aider rapidement.
                            </small>
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.typeReclamation, 'Type de réclamation', {'label_attr': {'class': 'form-label required-field'}}) }}
                            {{ form_widget(form.typeReclamation, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.typeReclamation) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.statusReclamation, 'Statut', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.statusReclamation, {'attr': {'class': 'form-select', 'readonly': 'readonly', 'disabled': 'disabled'}}) }}
                            <small class="form-text">
                                <i class="fas fa-lock"></i>
                                Le statut est défini automatiquement sur "En attente"
                            </small>
                        </div>

                        {{ form_rest(form, {'render_rest': false}) }}

                        <hr>

                        <div class="d-flex gap-3 justify-content-end">
                            <button type="submit" class="btn btn-submit">
                                <i class="fas fa-paper-plane me-2"></i>Soumettre la réclamation
                            </button>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>

                <!-- Informations supplémentaires -->
                <div class="info-alert" role="alert">
                    <h5 class="alert-heading">
                        <i class="fas fa-info-circle"></i>
                        À savoir
                    </h5>
                    <ul>
                        <li>Votre réclamation sera traitée dans les 24-48 heures</li>
                        <li>Vous recevrez une notification par email une fois qu'une réponse sera disponible</li>
                        <li>Vous pouvez consulter l'état de votre réclamation dans votre espace personnel</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Validation du formulaire
    const form = document.querySelector('form[name*="reclamation"]');
    if (form) {
        form.addEventListener('submit', function(e) {
            const objet = document.querySelector('input[name*="objet"]');
            const description = document.querySelector('textarea[name*="description"]');
            
            if (!objet || !objet.value.trim() || !description || !description.value.trim()) {
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'Attention',
                    text: 'Veuillez remplir tous les champs obligatoires',
                    confirmButtonColor: '#667eea',
                    confirmButtonText: 'Compris'
                });
                return false;
            }
        });
    }

    // Animation au focus des champs
    document.querySelectorAll('.form-control, .form-select').forEach(field => {
        field.addEventListener('focus', function() {
            this.parentElement.style.transform = 'translateY(-2px)';
            this.parentElement.style.transition = 'transform 0.3s ease';
        });
        
        field.addEventListener('blur', function() {
            this.parentElement.style.transform = 'translateY(0)';
        });
    });
</script>
{% endblock %}