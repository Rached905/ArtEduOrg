{% extends 'base.html.twig' %}

{% block title %}Liste des réclamations{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --success-gradient: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        --warning-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        --danger-gradient: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        --info-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        --dark-gradient: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
        --orange-gradient: linear-gradient(135deg, #ff9a56 0%, #ff6a00 100%);
    }

    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
    }

    .stats-card {
        background: white;
        border: none;
        border-radius: 20px;
        padding: 2rem;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        position: relative;
        overflow: hidden;
    }

    .stats-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--primary-gradient);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s ease;
    }

    .stats-card:hover::before {
        transform: scaleX(1);
    }

    .stats-card:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 20px 60px rgba(102, 126, 234, 0.3);
    }

    .stats-icon {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        position: relative;
    }

    .stats-icon::after {
        content: '';
        position: absolute;
        inset: -10px;
        border-radius: 20px;
        background: inherit;
        opacity: 0.2;
        z-index: -1;
    }

    .stats-value {
        font-size: 3rem;
        font-weight: 800;
        margin: 0;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .stats-label {
        font-size: 0.9rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 600;
        margin: 0;
    }

    .icon-total {
        background: var(--primary-gradient);
        color: white;
    }

    .icon-en-attente {
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: white;
    }

    .icon-en-cours {
        background: var(--orange-gradient);
        color: white;
    }

    .icon-resolue {
        background: var(--success-gradient);
        color: white;
    }

    .icon-rejetee {
        background: var(--warning-gradient);
        color: white;
    }

    .page-header {
        background: white;
        border-radius: 25px;
        padding: 2.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        position: relative;
        overflow: hidden;
    }

    .page-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--primary-gradient);
        opacity: 0.05;
        z-index: 0;
    }

    .page-header-content {
        position: relative;
        z-index: 1;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 800;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .page-subtitle {
        color: #6c757d;
        font-size: 1.1rem;
        margin: 0.5rem 0 0 0;
    }

    .table-card {
        background: white;
        border: none;
        border-radius: 25px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    .table {
        margin: 0;
    }

    .table thead {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .table thead th {
        border: none;
        padding: 1.5rem 1rem;
        font-weight: 700;
        color: #2c3e50;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
    }

    .table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f0f0f0;
    }

    .table tbody tr:hover {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
        transform: scale(1.01);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
    }

    .table tbody td {
        padding: 1.25rem 1rem;
        vertical-align: middle;
    }

    .filter-card {
        background: white;
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    }

    .search-box {
        position: relative;
    }

    .search-box i {
        position: absolute;
        left: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        color: #667eea;
        font-size: 1.1rem;
    }

    .search-box input {
        padding-left: 3.5rem;
        border-radius: 15px;
        border: 2px solid #e9ecef;
        padding-top: 0.875rem;
        padding-bottom: 0.875rem;
        transition: all 0.3s ease;
    }

    .search-box input:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.15);
        transform: translateY(-2px);
    }

    .form-select {
        border-radius: 15px;
        border: 2px solid #e9ecef;
        padding: 0.875rem 1rem;
        transition: all 0.3s ease;
    }

    .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.15);
    }

    .badge {
        padding: 0.5rem 1rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .response-preview {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-left: 4px solid #667eea;
        padding: 0.75rem;
        border-radius: 10px;
        font-size: 0.85rem;
        max-width: 200px;
    }

    .no-response {
        color: #6c757d;
        font-style: italic;
        font-size: 0.85rem;
    }

    .btn {
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.75rem;
    }

    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
    }

    .btn-info {
        background: var(--info-gradient);
        color: white;
    }

    .btn-respond {
        background: var(--primary-gradient);
        color: white;
    }

    .btn-warning {
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: white;
    }

    .btn-danger {
        background: var(--warning-gradient);
        color: white;
    }

    .btn-outline-secondary {
        border: 2px solid #6c757d;
        color: #6c757d;
        background: transparent;
    }

    .btn-outline-secondary:hover {
        background: #6c757d;
        color: white;
    }

    .btn-action-group {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    @keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-in {
        animation: slideInUp 0.6s ease forwards;
    }

    .empty-state {
        padding: 5rem 2rem;
        text-align: center;
    }

    .empty-state i {
        font-size: 5rem;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        opacity: 0.3;
    }

    .empty-state h3 {
        margin-top: 2rem;
        color: #6c757d;
        font-weight: 600;
    }

    .info-footer {
        background: white;
        border-radius: 20px;
        padding: 1.5rem;
        margin-top: 2rem;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    }

    .alert {
        border: none;
        border-radius: 15px;
        padding: 1.25rem;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    .alert-success {
        background: linear-gradient(135deg, rgba(17, 153, 142, 0.1) 0%, rgba(56, 239, 125, 0.1) 100%);
        color: #0f5132;
        border-left: 4px solid #38ef7d;
    }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <!-- Page Header -->
    <div class="page-header mt-4 animate-in">
        <div class="page-header-content">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="page-title">
                        <i class="fas fa-clipboard-list me-3"></i>Réclamations
                    </h1>
                    <p class="page-subtitle">
                        Consultez et gérez toutes les réclamations des utilisateurs
                    </p>
                </div>
                {% if not is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('reclamation_new') }}" class="btn btn-lg" style="background: var(--primary-gradient); color: white;">
                        <i class="fas fa-plus me-2"></i>Nouvelle Réclamation
                    </a>
                {% endif %}
            </div>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show animate-in" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <!-- Statistics Cards -->
<div class="row g-4 mb-4 justify-content-center">

    <div class="col-xl-4 col-lg-4 col-md-6 col-sm-12">
        <div class="stats-card animate-in h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="stats-value">{{ stats.total }}</p>
                    <p class="stats-label">Total</p>
                </div>
                <div class="stats-icon icon-total">
                    <i class="fas fa-clipboard-list"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-4 col-md-6 col-sm-12">
        <div class="stats-card animate-in h-100" style="animation-delay: 0.1s;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="stats-value">{{ stats.en_attente }}</p>
                    <p class="stats-label">En Attente</p>
                </div>
                <div class="stats-icon icon-en-attente">
                    <i class="fas fa-hourglass-half"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-4 col-md-6 col-sm-12">
        <div class="stats-card animate-in h-100" style="animation-delay: 0.2s;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="stats-value">{{ stats.resolue }}</p>
                    <p class="stats-label">Résolues</p>
                </div>
                <div class="stats-icon icon-resolue">
                    <i class="fas fa-check-circle"></i>
                </div>
            </div>
        </div>
    </div>

</div>


    <!-- Filtres et Recherche -->
    <div class="filter-card animate-in" style="animation-delay: 0.3s;">
        <div class="row g-3 align-items-center">
            <div class="col-md-4">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" id="searchInput" class="form-control" placeholder="Rechercher une réclamation...">
                </div>
            </div>
            <div class="col-md-3">
                <select id="filterStatus" class="form-select">
                    <option value="">Tous les statuts</option>
                    <option value="en_attente">En Attente</option>
                    <option value="en_cours">En Cours</option>
                    <option value="resolue">Résolue</option>
                    <option value="rejetee">Rejetée</option>
                </select>
            </div>
            <div class="col-md-3">
                <select id="filterType" class="form-select">
                    <option value="">Tous les types</option>
                    {% for type in types %}
                        <option value="{{ type }}">{{ type }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <button onclick="resetFilters()" class="btn btn-outline-secondary w-100">
                    <i class="fas fa-redo me-2"></i>Reset
                </button>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="table-card animate-in" style="animation-delay: 0.35s;">
        <div class="table-responsive">
            <table class="table mb-0" id="reclamationsTable">
                <thead>
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Objet</th>
                        <th style="width: 120px;">Type</th>
                        <th style="width: 140px;">Status</th>
                        <th style="width: 100px;">User ID</th>
                        <th style="width: 180px;">Email</th>
                        <th style="width: 140px;">Date</th>
                        <th style="width: 200px;">Réponse</th>
                        <th style="width: 250px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for reclamation in reclamations %}
                    <tr data-status="{{ reclamation.statusReclamation.value }}" data-type="{{ reclamation.typeReclamation.value }}">
                        <td>
                            <span class="badge" style="background: var(--dark-gradient);">#{{ reclamation.id }}</span>
                        </td>
                        <td>
                            <strong>{{ reclamation.objet }}</strong>
                        </td>
                        <td>
                            <span class="badge" style="background: var(--info-gradient);">
                                <i class="fas fa-tag me-1"></i>{{ reclamation.typeReclamation.value }}
                            </span>
                        </td>
                        <td>
                            {% set statusClass = '' %}
                            {% set statusIcon = '' %}
                            {% if reclamation.statusReclamation.value == 'en_attente' %}
                                {% set statusClass = 'bg-warning' %}
                                {% set statusIcon = 'hourglass-half' %}
                            {% elseif reclamation.statusReclamation.value == 'en_cours' %}
                                {% set statusClass = 'bg-info' %}
                                {% set statusIcon = 'spinner' %}
                            {% elseif reclamation.statusReclamation.value == 'resolue' %}
                                {% set statusClass = 'bg-success' %}
                                {% set statusIcon = 'check-circle' %}
                            {% else %}
                                {% set statusClass = 'bg-danger' %}
                                {% set statusIcon = 'times-circle' %}
                            {% endif %}
                            
                            <span class="badge {{ statusClass }}">
                                <i class="fas fa-{{ statusIcon }} me-1"></i>
                                {{ reclamation.statusReclamation.value|replace({'_': ' '})|title }}
                            </span>
                        </td>
                        <td>
                            <span class="badge" style="background: var(--dark-gradient);">
                                <i class="fas fa-user me-1"></i>{{ reclamation.userId }}
                            </span>
                        </td>
                        <td>
                            {% if reclamation.userEmail %}
                                <a href="mailto:{{ reclamation.userEmail }}" class="text-decoration-none" title="{{ reclamation.userEmail }}" style="color: #667eea;">
                                    <i class="fas fa-envelope me-1"></i>
                                    <small>{{ reclamation.userEmail|length > 20 ? reclamation.userEmail|slice(0, 20) ~ '...' : reclamation.userEmail }}</small>
                                </a>
                            {% else %}
                                <span class="text-muted"><small>N/A</small></span>
                            {% endif %}
                        </td>
                        <td>
                            <small style="color: #6c757d;">
                                <i class="fas fa-calendar me-1"></i>{{ reclamation.dateTime|date('d/m/Y') }}<br>
                                <i class="fas fa-clock me-1"></i>{{ reclamation.dateTime|date('H:i') }}
                            </small>
                        </td>
                        <td>
                            {% if reclamation.reponseAdmin %}
                                <div class="response-preview" title="{{ reclamation.reponseAdmin }}">
                                    <i class="fas fa-reply me-1"></i>
                                    {{ reclamation.reponseAdmin|length > 30 ? reclamation.reponseAdmin|slice(0, 30) ~ '...' : reclamation.reponseAdmin }}
                                </div>
                            {% else %}
                                <span class="no-response">
                                    <i class="fas fa-clock me-1"></i>En attente
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-action-group">
                                <a href="{{ path('reclamation_show', {id: reclamation.id}) }}" 
                                   class="btn btn-sm btn-info" 
                                   title="Voir">
                                    <i class="fas fa-eye"></i>
                                </a>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <button type="button" 
                                            class="btn btn-sm btn-respond" 
                                            onclick="respondToReclamation({{ reclamation.id }}, '{{ reclamation.objet|e('js') }}', '{{ reclamation.reponseAdmin|default('')|e('js') }}')"
                                            title="Répondre">
                                        <i class="fas fa-reply"></i>
                                    </button>
                                {% endif %}
                                <a href="{{ path('reclamation_edit', {id: reclamation.id}) }}" 
                                   class="btn btn-sm btn-warning" 
                                   title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" 
                                      action="{{ path('reclamation_delete', {id: reclamation.id}) }}" 
                                      style="display:inline;"
                                      onsubmit="return confirmDelete()">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reclamation.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="9">
                            <div class="empty-state">
                                <i class="fas fa-inbox"></i>
                                <h3>Aucune réclamation trouvée</h3>
                                <p class="text-muted">Les réclamations apparaîtront ici une fois créées</p>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Footer Info -->
    {% if reclamations|length > 0 %}
        <div class="info-footer animate-in" style="animation-delay: 0.4s;">
            <div class="d-flex justify-content-between align-items-center">
                <p class="mb-0" style="color: #6c757d;">
                    <i class="fas fa-info-circle me-2"></i>
                    Affichage de <strong>{{ reclamations|length }}</strong> réclamation(s)
                </p>
                <p class="mb-0" style="color: #6c757d;">
                    <i class="fas fa-clock me-2"></i>
                    Dernière mise à jour : <strong>{{ "now"|date('d/m/Y H:i') }}</strong>
                </p>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.getElementById('searchInput').addEventListener('keyup', function() {
    filterTable();
});

document.getElementById('filterStatus').addEventListener('change', function() {
    filterTable();
});

document.getElementById('filterType').addEventListener('change', function() {
    filterTable();
});

function filterTable() {
    const searchValue = document.getElementById('searchInput').value.toLowerCase();
    const statusValue = document.getElementById('filterStatus').value.toLowerCase();
    const typeValue = document.getElementById('filterType').value.toLowerCase();
    
    const table = document.getElementById('reclamationsTable');
    const rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');
    
    for (let row of rows) {
        const text = row.textContent.toLowerCase();
        const status = row.getAttribute('data-status');
        const type = row.getAttribute('data-type');
        
        const matchSearch = searchValue === '' || text.includes(searchValue);
        const matchStatus = statusValue === '' || status === statusValue;
        const matchType = typeValue === '' || type === typeValue;
        
        if (matchSearch && matchStatus && matchType) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    }
}

function resetFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('filterStatus').value = '';
    document.getElementById('filterType').value = '';
    filterTable();
}

function confirmDelete() {
    return confirm('Êtes-vous sûr de vouloir supprimer cette réclamation ? Cette action est irréversible.');
}

function respondToReclamation(id, objet, currentResponse) {
    Swal.fire({
        title: 'Répondre à la réclamation',
        html: `
            <div class="text-start mb-3 p-3" style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%); border-radius: 12px;">
                <strong style="color: #667eea;">Objet :</strong> ${objet}
            </div>
        `,
        input: 'textarea',
        inputLabel: 'Votre réponse',
        inputPlaceholder: 'Écrivez votre réponse ici...',
        inputValue: currentResponse,
        inputAttributes: {
            'aria-label': 'Votre réponse',
            'style': 'min-height: 150px; border-radius: 12px; border: 2px solid #e9ecef;'
        },
        showCancelButton: true,
        confirmButtonColor: '#667eea',
        cancelButtonColor: '#6c757d',
        confirmButtonText: '<i class="fas fa-paper-plane me-2"></i>Envoyer',
        cancelButtonText: '<i class="fas fa-times me-2"></i>Annuler',
        customClass: {
            popup: 'rounded-4',
            confirmButton: 'rounded-3',
            cancelButton: 'rounded-3'
        },
        inputValidator: (value) => {
            if (!value) {
                return 'Vous devez écrire une réponse !';
            }
        }
    }).then((result) => {
        if (result.isConfirmed) {
            Swal.fire({
                title: 'Envoi en cours...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            fetch(`/reclamation/${id}/respond`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    response: result.value
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Réponse envoyée !',
                        text: 'La réponse a été enregistrée avec succès.',
                        confirmButtonColor: '#667eea',
                        customClass: {
                            popup: 'rounded-4',
                            confirmButton: 'rounded-3'
                        }
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Erreur',
                        text: data.message || 'Une erreur est survenue',
                        confirmButtonColor: '#dc3545',
                        customClass: {
                            popup: 'rounded-4',
                            confirmButton: 'rounded-3'
                            }
                });
            }
        })
        .catch(error => {
            console.error('Error:', error);
            Swal.fire({
                icon: 'error',
                title: 'Erreur',
                text: 'Impossible d\'envoyer la réponse',
                confirmButtonColor: '#dc3545',
