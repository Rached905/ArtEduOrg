{% extends 'base.html.twig' %}

{% block title %}Check-in Réussi{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="alert alert-success text-center">
        <i class="fas fa-check-circle fa-4x mb-3"></i>
        <h2>Check-in Validé !</h2>

        <p class="lead">Bienvenue, {{ ticket.buyerName }}</p>
        <hr>

        <p>
            <strong>Email :</strong> {{ ticket.buyerEmail }}<br>

            <strong>Événement :</strong>
            {{ ticket.event ? ticket.event.title : 'N/A' }}<br>

            <strong>Date :</strong>
            {{ ticket.event and ticket.event.startDate ? ticket.event.startDate|date('d/m/Y à H:i') : 'Date N/A' }}<br>

            <strong>Place :</strong>
            {{ ticket.seatNumber ?: 'Placement libre' }}
        </p>

        <small class="text-muted">
            Ticket #{{ ticket.id }} • Scanné le {{ ticket.checkedInAt ? ticket.checkedInAt|date('d/m/Y à H:i') : '' }}
        </small>
    </div>
</div>
{% endblock %}


