{% extends 'base.html.twig' %}

{% block title %}Détails du Parrainage{% endblock %}

{% block body %}
<div class="page-header">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="page-title">
                <i class="fas fa-gift"></i>
                Détails du Parrainage
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_sponsorship_index') }}">Parrainages</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Détails</li>
                </ol>
            </nav>
        </div>
        <a href="{{ path('app_sponsorship_index') }}" class="btn btn-reset">
            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-borderless">
            <tbody>
                <tr>
                    <th width="200">Description</th>
                    <td>{{ sponsorship.description|nl2br }}</td>
                </tr>
                <tr>
                    <th>Sponsor</th>
                    <td>
                        <strong>{{ sponsorship.sponsor.name }}</strong>
                        {% if sponsorship.sponsor.email %}
                            <br><small class="text-muted">{{ sponsorship.sponsor.email }}</small>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Type</th>
                    <td><span class="badge bg-secondary">{{ sponsorship.type.value }}</span></td>
                </tr>
                <tr>
                    <th>Type de parrainage</th>
                    <td><span class="badge bg-primary">{{ sponsorship.sponsorshipType.value }}</span></td>
                </tr>
                <tr>
                    <th>Montant</th>
                    <td><strong class="text-success fs-5">{{ sponsorship.amount|number_format(2, ',', ' ') }} €</strong></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a href="{{ path('app_sponsorship_index') }}" class="btn btn-secondary">Retour à la liste</a>
    <a href="{{ path('app_sponsorship_edit', {'id': sponsorship.id}) }}" class="btn btn-warning">
        <i class="fas fa-edit"></i> Modifier
    </a>
    {{ include('sponsorship/_delete_form.html.twig') }}
</div>
{% endblock %}


