{# templates/home/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Bienvenue - ArtMarket{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #e94560 0%, #d63850 100%);
            --secondary-gradient: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            --accent-color: #e94560;
            --dark-color: #1a1a2e;
        }

        /* Hero Section - Modern ArtMarket Style */
        .hero-section {
            position: relative;
            background: var(--secondary-gradient);
            border-radius: 30px;
            padding: 5rem 3rem;
            box-shadow: 0 20px 60px rgba(26, 26, 46, 0.3);
            margin: 2rem auto;
            overflow: hidden;
            animation: fadeInUp 0.8s ease;
            min-height: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .hero-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 50%, rgba(233, 69, 96, 0.2) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(233, 69, 96, 0.15) 0%, transparent 50%);
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 2;
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero-badge {
            display: inline-block;
            padding: 10px 25px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 25px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            animation: fadeInUp 0.8s ease 0.2s both;
        }
        
        .hero-section h1 {
            font-size: 4rem;
            font-weight: 800;
            background: linear-gradient(to right, #ffffff, #ffccdd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1.5rem;
            animation: fadeInUp 0.8s ease 0.3s both;
            text-shadow: 0 0 40px rgba(255, 255, 255, 0.1);
        }

        .hero-section h1 i {
            color: var(--accent-color);
            filter: drop-shadow(0 0 20px rgba(233, 69, 96, 0.5));
        }
        
        .hero-section p {
            font-size: 1.4rem;
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: 3rem;
            animation: fadeInUp 0.8s ease 0.4s both;
            line-height: 1.7;
        }
        
        .action-buttons {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            flex-wrap: wrap;
            animation: fadeInUp 0.8s ease 0.5s both;
        }
        
        .btn-hero {
            padding: 18px 45px;
            font-size: 1.1rem;
            font-weight: 600;
            border-radius: 50px;
            transition: all 0.4s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            position: relative;
            overflow: hidden;
            z-index: 1;
        }

        .btn-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.2);
            transition: left 0.4s ease;
            z-index: -1;
        }

        .btn-hero:hover::before {
            left: 100%;
        }
        
        .btn-primary-hero {
            background: white;
            color: var(--accent-color);
            border: 2px solid white;
        }
        
        .btn-primary-hero:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(255, 255, 255, 0.3);
            color: var(--accent-color);
        }
        
        .btn-secondary-hero {
            background: transparent;
            color: white;
            border: 2px solid white;
        }
        
        .btn-secondary-hero:hover {
            background: white;
            color: var(--accent-color);
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(255, 255, 255, 0.3);
        }

        /* Decorative Shapes */
        .hero-decoration {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            pointer-events: none;
            z-index: 1;
        }

        .floating-shape {
            position: absolute;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(233, 69, 96, 0.2));
            backdrop-filter: blur(5px);
            animation: float 25s infinite ease-in-out;
        }

        .shape-1 {
            width: 200px;
            height: 200px;
            top: 10%;
            left: 5%;
            animation-delay: 0s;
        }

        .shape-2 {
            width: 150px;
            height: 150px;
            top: 60%;
            right: 10%;
            animation-delay: 7s;
        }

        .shape-3 {
            width: 100px;
            height: 100px;
            bottom: 15%;
            left: 50%;
            animation-delay: 14s;
        }

        @keyframes float {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            25% { transform: translate(30px, -40px) rotate(90deg); }
            50% { transform: translate(-20px, 30px) rotate(180deg); }
            75% { transform: translate(40px, 20px) rotate(270deg); }
        }
        
        /* Features Section */
        .features-section {
            margin-top: 4rem;
            animation: fadeInUp 0.8s ease 0.6s both;
        }

        .section-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .section-badge {
            display: inline-block;
            padding: 8px 20px;
            background: rgba(233, 69, 96, 0.1);
            color: var(--accent-color);
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 1px;
            margin-bottom: 15px;
        }

        .section-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--dark-color);
            margin-bottom: 15px;
        }
        
        .feature-card {
            background: white;
            border-radius: 25px;
            padding: 40px 30px;
            margin-bottom: 2rem;
            transition: all 0.4s ease;
            border: 2px solid transparent;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            position: relative;
            overflow: hidden;
        }
        
        .feature-card::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: var(--primary-gradient);
            transform: scaleX(0);
            transition: transform 0.4s ease;
        }

        .feature-card:hover::before {
            transform: scaleX(1);
        }

        .feature-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 20px 60px rgba(233, 69, 96, 0.2);
            border-color: var(--accent-color);
        }
        
        .feature-icon {
            width: 90px;
            height: 90px;
            background: var(--primary-gradient);
            border-radius: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: white;
            margin-bottom: 1.5rem;
            box-shadow: 0 15px 40px rgba(233, 69, 96, 0.3);
            transition: all 0.4s ease;
        }

        .feature-card:hover .feature-icon {
            transform: scale(1.1) rotate(5deg);
        }
        
        .feature-card h3 {
            font-weight: 700;
            color: var(--dark-color);
            margin-bottom: 1rem;
            font-size: 1.5rem;
        }
        
        .feature-card p {
            color: #666;
            line-height: 1.7;
            font-size: 1.05rem;
        }
        
        /* Stats Section */
        .stats-section {
            background: white;
            border-radius: 25px;
            padding: 4rem 3rem;
            margin-top: 4rem;
            margin-bottom: 3rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            position: relative;
            overflow: hidden;
        }

        .stats-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: var(--primary-gradient);
        }
        
        .stat-item {
            text-align: center;
            padding: 1.5rem;
            transition: all 0.3s ease;
        }

        .stat-item:hover {
            transform: scale(1.05);
        }
        
        .stat-number {
            font-size: 3.5rem;
            font-weight: 800;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 10px;
        }
        
        .stat-label {
            font-size: 1.1rem;
            color: #666;
            font-weight: 600;
        }

        /* CTA Section */
        .cta-section {
            background: var(--secondary-gradient);
            border-radius: 25px;
            padding: 4rem 3rem;
            margin-bottom: 3rem;
            text-align: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .cta-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 30% 50%, rgba(233, 69, 96, 0.3) 0%, transparent 50%),
                radial-gradient(circle at 70% 80%, rgba(233, 69, 96, 0.2) 0%, transparent 50%);
        }

        .cta-content {
            position: relative;
            z-index: 2;
        }

        .cta-icon {
            width: 80px;
            height: 80px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin-bottom: 25px;
            border: 2px solid rgba(255, 255, 255, 0.3);
        }

        .cta-section h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .cta-section p {
            font-size: 1.2rem;
            margin-bottom: 30px;
            opacity: 0.9;
        }
        
        /* Showcase Sections */
        .showcase-section {
            margin-top: 4rem;
            margin-bottom: 4rem;
            animation: fadeInUp 0.8s ease 0.7s both;
        }

        .btn-view-all {
            background: var(--primary-gradient);
            color: white;
            padding: 12px 30px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            border: none;
        }

        .btn-view-all:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(233, 69, 96, 0.3);
            color: white;
        }

        /* Œuvres Grid */
        .showcase-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .showcase-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            transition: all 0.4s ease;
            border: 2px solid transparent;
        }

        .showcase-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 60px rgba(233, 69, 96, 0.2);
            border-color: var(--accent-color);
        }

        .showcase-image {
            position: relative;
            height: 250px;
            background: linear-gradient(135deg, #f8f9fa 0%, #e8ecf1 100%);
            overflow: hidden;
        }

        .showcase-image .card-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

        .showcase-card:hover .card-img {
            transform: scale(1.1);
        }

        .card-img-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            color: #ccc;
        }

        .status-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            padding: 6px 15px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            color: white;
        }

        .status-badge.available {
            background: #28a745;
        }

        .status-badge.sold {
            background: #6c757d;
        }

        .showcase-content {
            padding: 1.5rem;
        }

        .showcase-content h4 {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--dark-color);
            margin-bottom: 0.75rem;
        }

        .showcase-description {
            color: #666;
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 1rem;
            min-height: 48px;
        }

        .showcase-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 1rem;
            font-size: 0.85rem;
            color: #999;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .showcase-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 1rem;
            border-top: 1px solid #f0f0f0;
        }

        .showcase-price {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--accent-color);
        }

        .btn-view-details {
            background: var(--primary-gradient);
            color: white;
            padding: 8px 20px;
            border-radius: 25px;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.3s ease;
        }

        .btn-view-details:hover {
            transform: translateX(5px);
            box-shadow: 0 5px 15px rgba(233, 69, 96, 0.3);
            color: white;
        }

        /* Artistes Grid */
        .artists-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .artist-card {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            text-align: center;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            transition: all 0.4s ease;
            border: 2px solid transparent;
        }

        .artist-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 60px rgba(233, 69, 96, 0.2);
            border-color: var(--accent-color);
        }

        .artist-avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: var(--primary-gradient);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            font-weight: 700;
            margin: 0 auto 1.5rem;
            box-shadow: 0 10px 30px rgba(233, 69, 96, 0.3);
        }

        .artist-info h4 {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--dark-color);
            margin-bottom: 0.5rem;
        }

        .artist-email {
            color: #666;
            font-size: 0.9rem;
            margin-bottom: 1rem;
        }

        .artist-stats {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
        }

        .stat-badge {
            background: rgba(233, 69, 96, 0.1);
            color: var(--accent-color);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        /* Événements Grid */
        .events-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .event-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            transition: all 0.4s ease;
            border: 2px solid transparent;
        }

        .event-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 60px rgba(233, 69, 96, 0.2);
            border-color: var(--accent-color);
        }

        .event-header {
            background: var(--primary-gradient);
            color: white;
            padding: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: start;
        }

        .event-header h4 {
            font-size: 1.3rem;
            font-weight: 700;
            margin: 0;
            flex: 1;
        }

        .event-type-badge {
            background: rgba(255, 255, 255, 0.2);
            padding: 5px 12px;
            border-radius: 15px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-left: 1rem;
        }

        .event-body {
            padding: 1.5rem;
        }

        .event-description {
            color: #666;
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 1.5rem;
            min-height: 48px;
        }

        .event-details {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .event-detail-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #666;
            font-size: 0.9rem;
        }

        .event-detail-item i {
            color: var(--accent-color);
            width: 20px;
        }

        .event-footer {
            padding: 1rem 1.5rem;
            background: #f8f9fa;
            border-top: 1px solid #e9ecef;
        }

        .btn-event-details {
            background: var(--primary-gradient);
            color: white;
            padding: 10px 25px;
            border-radius: 25px;
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            width: 100%;
            justify-content: center;
        }

        .btn-event-details:hover {
            transform: translateX(5px);
            box-shadow: 0 5px 15px rgba(233, 69, 96, 0.3);
            color: white;
        }

        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 4rem 2rem;
            color: #999;
        }

        .empty-state i {
            font-size: 4rem;
            margin-bottom: 1rem;
            display: block;
            opacity: 0.5;
        }

        .empty-state p {
            font-size: 1.1rem;
            margin: 0;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero-section {
                padding: 3rem 2rem;
            }

            .hero-section h1 {
                font-size: 2.5rem;
            }
            
            .hero-section p {
                font-size: 1.1rem;
            }
            
            .btn-hero {
                width: 100%;
                justify-content: center;
            }
            
            .action-buttons {
                flex-direction: column;
            }

            .section-title {
                font-size: 2rem;
            }

            .stat-number {
                font-size: 2.5rem;
            }

            .cta-section h2 {
                font-size: 2rem;
            }

            .showcase-grid,
            .artists-grid,
            .events-grid {
                grid-template-columns: 1fr;
            }

            .btn-view-all {
                width: 100%;
                justify-content: center;
                margin-top: 1rem;
            }

            .section-header {
                flex-direction: column;
                align-items: flex-start !important;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="container">
    {# Hero Section #}
    <div class="hero-section text-center">
        <div class="hero-decoration">
            <div class="floating-shape shape-1"></div>
            <div class="floating-shape shape-2"></div>
            <div class="floating-shape shape-3"></div>
        </div>

        <div class="hero-content">
            <div class="hero-badge">
                <i class="bi bi-star-fill"></i> Plateforme Premium
            </div>
            <h1>
                <i class="bi bi-lightning-charge-fill"></i>
                Bienvenue sur ArtMarket
            </h1>
            <p class="lead">
                La solution moderne pour gérer vos projets artistiques simplement et efficacement.<br>
                Rejoignez des milliers d'artistes et collectionneurs satisfaits.
            </p>
            
            <div class="action-buttons">
                <a href="{{ path('app_login') }}" class="btn btn-primary-hero">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Se connecter
                </a>
                <a href="{{ path('app_welcome_new') }}" class="btn btn-secondary-hero">
                    <i class="bi bi-person-plus"></i>
                    Créer un compte
                </a>
            </div>
        </div>
    </div>
    
    {# Features Section #}
    <div class="features-section">
        <div class="section-header">
            <div class="section-badge">FONCTIONNALITÉS</div>
            <h2 class="section-title">Pourquoi nous choisir ?</h2>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h3>Sécurisé</h3>
                    <p>
                        Vos données et vos œuvres sont protégées avec les dernières 
                        technologies de cryptage et de sécurité pour une tranquillité totale.
                    </p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-speedometer2"></i>
                    </div>
                    <h3>Rapide</h3>
                    <p>
                        Interface ultra-rapide et intuitive pour une productivité 
                        maximale. Gérez vos créations et événements en quelques clics.
                    </p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-people"></i>
                    </div>
                    <h3>Collaboratif</h3>
                    <p>
                        Connectez-vous avec des artistes et des collectionneurs du monde 
                        entier. Partagez et vendez vos œuvres facilement.
                    </p>
                </div>
            </div>
        </div>
    </div>
    
    {# Section Nos Œuvres #}
    <div class="showcase-section">
        <div class="section-header">
            <div class="section-badge">GALERIE</div>
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <h2 class="section-title">Nos Œuvres</h2>
                <a href="{{ path('app_login') }}" class="btn-view-all">
                    Voir tout <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
        
        <div class="showcase-grid">
            {% if sales|length > 0 %}
                {% for sale in sales %}
                    <div class="showcase-card">
                        <div class="showcase-image">
                            {% set primaryImage = sale.getPrimaryImage() %}
                            {% if primaryImage %}
                                <img src="{{ asset(primaryImage.path) }}" alt="{{ sale.title }}" class="card-img">
                            {% elseif sale.image %}
                                <img src="{{ asset(sale.image) }}" alt="{{ sale.title }}" class="card-img">
                            {% else %}
                                <div class="card-img-placeholder">
                                    <i class="bi bi-image"></i>
                                </div>
                            {% endif %}
                            {% if sale.status.value == 'disponible' or sale.status.value == 'en attente' %}
                                <span class="status-badge available">Disponible</span>
                            {% elseif sale.status.value == 'vendue' %}
                                <span class="status-badge sold">Vendue</span>
                            {% endif %}
                        </div>
                        <div class="showcase-content">
                            <h4>{{ sale.title }}</h4>
                            <p class="showcase-description">{{ sale.description|length > 80 ? sale.description|slice(0, 80) ~ '...' : sale.description }}</p>
                            <div class="showcase-meta">
                                <span class="meta-item">
                                    <i class="bi bi-tag"></i> {{ sale.type.value|capitalize }}
                                </span>
                                {% if sale.vendeur %}
                                    <span class="meta-item">
                                        <i class="bi bi-person"></i> {{ sale.vendeur.fullname }}
                                    </span>
                                {% endif %}
                            </div>
                            <div class="showcase-footer">
                                <span class="showcase-price">
                                    {% if sale.amount %}
                                        {{ sale.amount|number_format(0, ',', ' ') }} €
                                    {% else %}
                                        Prix sur demande
                                    {% endif %}
                                </span>
                                <a href="{{ path('app_login') }}" class="btn-view-details">
                                    Voir détails <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div class="empty-state">
                    <i class="bi bi-palette"></i>
                    <p>Aucune œuvre disponible pour le moment</p>
                </div>
            {% endif %}
        </div>
    </div>

    {# Section Nos Artistes #}
    <div class="showcase-section">
        <div class="section-header">
            <div class="section-badge">ARTISTES</div>
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <h2 class="section-title">Nos Artistes</h2>
                <a href="{{ path('app_login') }}" class="btn-view-all">
                    Voir tout <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
        
        <div class="artists-grid">
            {% if artists|length > 0 %}
                {% for artist in artists %}
                    <div class="artist-card">
                        <div class="artist-avatar">
                            {% if artist.isVirtual is defined and artist.isVirtual %}
                                {% if artist.fullname %}
                                    {{ artist.fullname|first|upper }}
                                {% else %}
                                    <i class="bi bi-person"></i>
                                {% endif %}
                            {% else %}
                                {% if artist.fullname %}
                                    {{ artist.fullname|first|upper }}
                                {% else %}
                                    <i class="bi bi-person"></i>
                                {% endif %}
                            {% endif %}
                        </div>
                        <div class="artist-info">
                            <h4>{{ artist.fullname ?? 'Artiste' }}</h4>
                            <p class="artist-email">{{ artist.email ?? 'N/A' }}</p>
                            <div class="artist-stats">
                                <span class="stat-badge">
                                    <i class="bi bi-palette"></i> Artiste
                                </span>
                                {% if artist.isVirtual is defined and artist.isVirtual %}
                                    <span class="stat-badge" style="background: rgba(108, 117, 125, 0.1); color: #6c757d; margin-left: 0.5rem;">
                                        <i class="bi bi-star"></i> Légendaire
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div class="empty-state">
                    <i class="bi bi-people"></i>
                    <p>Aucun artiste disponible pour le moment</p>
                </div>
            {% endif %}
        </div>
    </div>

    {# Section Nos Événements #}
    <div class="showcase-section">
        <div class="section-header">
            <div class="section-badge">ÉVÉNEMENTS</div>
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <h2 class="section-title">Nos Événements</h2>
                <a href="{{ path('app_login') }}" class="btn-view-all">
                    Voir tout <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
        
        <div class="events-grid">
            {% if events|length > 0 %}
                {% for event in events %}
                    <div class="event-card">
                        <div class="event-header">
                            <h4>
                                {% if event.isVirtual is defined and event.isVirtual %}
                                    {{ event.title }}
                                    <span class="event-type-badge" style="background: rgba(255, 255, 255, 0.3); font-size: 0.7rem; margin-left: 0.5rem;">
                                        <i class="bi bi-star"></i> Virtuel
                                    </span>
                                {% else %}
                                    {{ event.title }}
                                {% endif %}
                            </h4>
                            {% if event.type %}
                                <span class="event-type-badge">
                                    {% if event.isVirtual is defined and event.isVirtual %}
                                        {{ event.type }}
                                    {% else %}
                                        {{ event.type }}
                                    {% endif %}
                                </span>
                            {% endif %}
                        </div>
                        <div class="event-body">
                            {% if event.description %}
                                <p class="event-description">{{ event.description|length > 100 ? event.description|slice(0, 100) ~ '...' : event.description }}</p>
                            {% elseif event.getDescription is defined %}
                                <p class="event-description">{{ event.getDescription()|length > 100 ? event.getDescription()|slice(0, 100) ~ '...' : event.getDescription() }}</p>
                            {% endif %}
                            <div class="event-details">
                                {% if event.isVirtual is defined and event.isVirtual %}
                                    {# Événement virtuel #}
                                    {% if event.startDate %}
                                        <div class="event-detail-item">
                                            <i class="bi bi-calendar-event"></i>
                                            <span>{{ event.startDate|date('d/m/Y H:i') }}</span>
                                        </div>
                                    {% endif %}
                                    {% if event.location %}
                                        <div class="event-detail-item">
                                            <i class="bi bi-geo-alt"></i>
                                            <span>{{ event.location }}</span>
                                        </div>
                                    {% endif %}
                                    {% if event.price is defined %}
                                        {% set virtualPrice = event.price|replace({',': '.'})|number_format(2, '.', '') %}
                                        {% if virtualPrice > 0 %}
                                            <div class="event-detail-item">
                                                <i class="bi bi-currency-euro"></i>
                                                <span>{{ event.price }} €</span>
                                            </div>
                                        {% else %}
                                            <div class="event-detail-item">
                                                <i class="bi bi-gift"></i>
                                                <span>Gratuit</span>
                                            </div>
                                        {% endif %}
                                    {% else %}
                                        <div class="event-detail-item">
                                            <i class="bi bi-gift"></i>
                                            <span>Gratuit</span>
                                        </div>
                                    {% endif %}
                                {% else %}
                                    {# Événement réel de la base de données #}
                                    {% if event.getStartDate() %}
                                        <div class="event-detail-item">
                                            <i class="bi bi-calendar-event"></i>
                                            <span>{{ event.getStartDate()|date('d/m/Y H:i') }}</span>
                                        </div>
                                    {% endif %}
                                    {% if event.getLocation() %}
                                        <div class="event-detail-item">
                                            <i class="bi bi-geo-alt"></i>
                                            <span>{{ event.getLocation() }}</span>
                                        </div>
                                    {% endif %}
                                    {% if event.getPrice() %}
                                        {% set eventPrice = event.getPrice()|replace({',': '.'})|number_format(2, '.', '') %}
                                        {% if eventPrice > 0 %}
                                            <div class="event-detail-item">
                                                <i class="bi bi-currency-euro"></i>
                                                <span>{{ event.getPrice() }} €</span>
                                            </div>
                                        {% else %}
                                            <div class="event-detail-item">
                                                <i class="bi bi-gift"></i>
                                                <span>Gratuit</span>
                                            </div>
                                        {% endif %}
                                    {% else %}
                                        <div class="event-detail-item">
                                            <i class="bi bi-gift"></i>
                                            <span>Gratuit</span>
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </div>
                        </div>
                        <div class="event-footer">
                            <a href="{{ path('app_login') }}" class="btn-event-details">
                                Voir détails <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div class="empty-state">
                    <i class="bi bi-calendar-event"></i>
                    <p>Aucun événement disponible pour le moment</p>
                </div>
            {% endif %}
        </div>
    </div>
    
    {# Stats Section #}
    <div class="stats-section">
        <div class="row">
            <div class="col-md-3 col-6">
                <div class="stat-item">
                    <div class="stat-number">1000+</div>
                    <div class="stat-label">Artistes</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-item">
                    <div class="stat-number">5000+</div>
                    <div class="stat-label">Œuvres</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-item">
                    <div class="stat-number">50+</div>
                    <div class="stat-label">Événements</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-item">
                    <div class="stat-number">24/7</div>
                    <div class="stat-label">Support</div>
                </div>
            </div>
        </div>
    </div>

    {# CTA Section #}
    <div class="cta-section">
        <div class="cta-content">
            <div class="cta-icon">
                <i class="bi bi-rocket-takeoff-fill"></i>
            </div>
            <h2>Prêt à commencer votre aventure artistique ?</h2>
            <p>Rejoignez notre communauté dès maintenant et découvrez un monde d'opportunités</p>
            <a href="{{ path('app_welcome_new') }}" class="btn btn-primary-hero">
                <i class="bi bi-arrow-right-circle"></i>
                Commencer gratuitement
            </a>
        </div>
    </div>
</div>
{% endblock %}