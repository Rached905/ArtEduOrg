{% extends 'base1.html.twig' %}

{% block title %}Connexion - ArtMarket{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #e94560 0%, #d63850 100%);
            --secondary-gradient: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            --accent-color: #e94560;
            --dark-color: #1a1a2e;
        }

        body {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #1a1a2e 100%);
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 30%, rgba(233, 69, 96, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(233, 69, 96, 0.1) 0%, transparent 50%);
            pointer-events: none;
        }

        #layoutAuthentication_content {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 2rem 0;
        }

        .login-container {
            position: relative;
            z-index: 2;
            animation: fadeInUp 0.8s ease;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .login-card {
            background: white;
            border-radius: 30px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            border: none;
            overflow: hidden;
            backdrop-filter: blur(10px);
            width: 100%;
        }

        .card-header {
            background: var(--secondary-gradient);
            border: none;
            padding: 3rem 2rem 2rem;
            position: relative;
            overflow: hidden;
        }

        .card-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 30% 50%, rgba(233, 69, 96, 0.2) 0%, transparent 50%);
        }

        .brand-logo {
            width: 80px;
            height: 80px;
            background: var(--primary-gradient);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            box-shadow: 0 15px 40px rgba(233, 69, 96, 0.4);
            position: relative;
            z-index: 2;
        }

        .brand-logo i {
            font-size: 2.5rem;
            color: white;
        }

        .card-header h3 {
            color: white;
            font-weight: 800;
            font-size: 2rem;
            margin: 0;
            position: relative;
            z-index: 2;
            line-height: 1.2;
        }

        .card-header p {
            color: rgba(255, 255, 255, 0.8);
            margin-top: 0.5rem;
            position: relative;
            z-index: 2;
        }

        .card-body {
            padding: 3rem 4rem;
        }

        .alert {
            border-radius: 15px;
            border: none;
            padding: 1rem 1.25rem;
            margin-bottom: 1.5rem;
        }

        .alert-danger {
            background: rgba(220, 53, 69, 0.1);
            color: #dc3545;
        }

        .form-floating {
            margin-bottom: 1.5rem;
        }

        .form-floating > .form-control {
            border-radius: 15px;
            border: 2px solid #e9ecef;
            padding: 1.25rem 1rem;
            transition: all 0.3s ease;
            background: #f8f9fa;
        }

        .form-floating > .form-control:focus {
            border-color: var(--accent-color);
            box-shadow: 0 0 0 0.2rem rgba(233, 69, 96, 0.1);
            background: white;
        }

        .form-floating > label {
            padding: 1.25rem 1rem;
            color: #6c757d;
        }

        .form-check {
            margin-bottom: 1.5rem;
        }

        .form-check-input {
            width: 1.25rem;
            height: 1.25rem;
            border-radius: 0.375rem;
            border: 2px solid #dee2e6;
        }

        .form-check-input:checked {
            background-color: var(--accent-color);
            border-color: var(--accent-color);
        }

        .form-check-label {
            margin-left: 0.5rem;
            color: #495057;
            font-weight: 500;
        }

        .btn-login {
            background: var(--primary-gradient);
            border: none;
            border-radius: 15px;
            padding: 0.875rem 2.5rem;
            font-weight: 600;
            font-size: 1.05rem;
            transition: all 0.3s ease;
            color: white;
            box-shadow: 0 10px 30px rgba(233, 69, 96, 0.3);
        }

        .btn-login:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(233, 69, 96, 0.4);
            color: white;
        }

        .forgot-password {
            color: var(--accent-color);
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .forgot-password:hover {
            color: #d63850;
            text-decoration: underline;
        }

        .card-footer {
            background: #f8f9fa;
            border-top: 2px solid #e9ecef;
            padding: 1.5rem 2rem;
        }

        .card-footer a {
            color: var(--accent-color);
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .card-footer a:hover {
            color: #d63850;
            text-decoration: underline;
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 1.5rem 0;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 2px solid #e9ecef;
        }

        .divider span {
            padding: 0 1rem;
            color: #6c757d;
            font-weight: 600;
            font-size: 0.875rem;
        }

        .social-login {
            display: flex;
            gap: 1rem;
            margin-top: 1.5rem;
        }

        .btn-social {
            flex: 1;
            padding: 0.75rem;
            border-radius: 15px;
            border: 2px solid #e9ecef;
            background: white;
            transition: all 0.3s ease;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-social:hover {
            border-color: var(--accent-color);
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        /* Footer */
        #layoutAuthentication_footer footer {
            background: rgba(26, 26, 46, 0.5);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        #layoutAuthentication_footer .text-muted {
            color: rgba(255, 255, 255, 0.6) !important;
        }

        #layoutAuthentication_footer a {
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            transition: all 0.3s ease;
        }

        #layoutAuthentication_footer a:hover {
            color: var(--accent-color);
        }

        /* Floating shapes decoration */
        .floating-shape {
            position: absolute;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(255,255,255,0.05), rgba(233, 69, 96, 0.1));
            backdrop-filter: blur(5px);
            animation: float 20s infinite ease-in-out;
            pointer-events: none;
        }

        .shape-1 {
            width: 150px;
            height: 150px;
            top: 10%;
            left: 10%;
            animation-delay: 0s;
        }

        .shape-2 {
            width: 100px;
            height: 100px;
            bottom: 20%;
            right: 15%;
            animation-delay: 7s;
        }

        @keyframes float {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            25% { transform: translate(20px, -30px) rotate(90deg); }
            50% { transform: translate(-15px, 20px) rotate(180deg); }
            75% { transform: translate(30px, 15px) rotate(270deg); }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .card-header h3 {
                font-size: 1.5rem;
            }

            .card-body {
                padding: 2rem 1.5rem;
            }

            .btn-login {
                width: 100%;
            }

            .social-login {
                flex-direction: column;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="floating-shape shape-1"></div>
<div class="floating-shape shape-2"></div>

<div class="container login-container">
    <div class="row justify-content-center">
        <div class="col-lg-15 col-md-10 col-sm-11">
            <div class="card login-card">
                <div class="card-header text-center">
                    <div class="brand-logo">
                        <i class="fas fa-palette"></i>
                    </div>
                    <h3>Bienvenue sur<br>ArtMarket</h3>
                    <p>Connectez-vous pour continuer</p>
                </div>

                <div class="card-body">
                    <form method="post" novalidate>
                        {% if error %}
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-circle me-2"></i>
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        {% if app.user %}
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                Vous êtes connecté en tant que {{ app.user.userIdentifier }},
                                <a href="{{ path('app_logout') }}" class="alert-link">Se déconnecter</a>
                            </div>
                        {% endif %}

                        <div class="form-floating">
                            <input value="{{ last_username }}" 
                                   name="email" 
                                   id="inputEmail" 
                                   type="email"
                                   class="form-control" 
                                   placeholder="nom@exemple.com"
                                   required>
                            <label for="inputEmail">
                                <i class="fas fa-envelope me-2"></i>Adresse email
                            </label>
                        </div>

                        <div class="form-floating">
                            <input type="password" 
                                   name="password" 
                                   id="inputPassword" 
                                   class="form-control"
                                   placeholder="Mot de passe"
                                   required>
                            <label for="inputPassword">
                                <i class="fas fa-lock me-2"></i>Mot de passe
                            </label>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <div class="form-check">
                            <input class="form-check-input" 
                                   id="remember_me" 
                                   type="checkbox" 
                                   name="_remember_me" />
                            <label class="form-check-label" for="remember_me">
                                Se souvenir de moi
                            </label>
                        </div>

                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <a class="forgot-password" href="{{ path('forgot_password') }}">
                                <i class="fas fa-question-circle me-1"></i>
                                Mot de passe oublié ?
                            </a>
                            <button class="btn btn-login" type="submit">
                                <i class="fas fa-sign-in-alt me-2"></i>
                                Se connecter
                            </button>
                        </div>
                    </form>

                    <div class="divider">
                        <span>OU</span>
                    </div>

                    <div class="social-login">
    <button class="btn btn-social" type="button" onclick="window.location.href='{{ path('connect_google_start') }}'">
        <i class="fab fa-google"></i>
        Google
    </button>
    <button class="btn btn-social" type="button" disabled>
        <i class="fab fa-facebook-f"></i>
        Facebook
    </button>
</div>

                <div class="card-footer text-center">
                    <div class="small">
                        Pas encore de compte ? 
                        <a href="{{ path('app_welcome_new') }}">
                            <i class="fas fa-user-plus me-1"></i>
                            Créer un compte
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}