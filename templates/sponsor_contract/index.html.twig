{% extends 'base.html.twig' %}

{% block title %}Liste des Contrats{% endblock %}

{% block body %}
<div class="page-header">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="page-title">
                <i class="fas fa-file-contract"></i>
                Liste des Contrats
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Contrats</li>
                </ol>
            </nav>
        </div>
        <a href="{{ path('app_sponsor_contract_new') }}" class="btn btn-add">
            <i class="fas fa-plus me-2"></i>Créer un Contrat
        </a>
    </div>
</div>

{% if sponsor_contracts|length > 0 %}
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Numéro de contrat</th>
                            <th>Date de signature</th>
                            <th>Date d'expiration</th>
                            <th>Niveau</th>
                            <th>Sponsor</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for sponsor_contract in sponsor_contracts %}
                        <tr>
                            <td><strong>{{ sponsor_contract.contractNumber }}</strong></td>
                            <td>{{ sponsor_contract.signedAt ? sponsor_contract.signedAt|date('d/m/Y') : '' }}</td>
                            <td>{{ sponsor_contract.expiresAt ? sponsor_contract.expiresAt|date('d/m/Y') : '' }}</td>
                            <td>
                                {% set levelColors = {
                                    'BRONZE': 'bg-secondary',
                                    'SILVER': 'bg-light text-dark',
                                    'GOLD': 'bg-warning',
                                    'PLATINUM': 'bg-info'
                                } %}
                                <span class="badge {{ levelColors[sponsor_contract.level.value] ?? 'bg-secondary' }}">{{ sponsor_contract.level.value }}</span>
                            </td>
                            <td>{{ sponsor_contract.sponsor.name }}</td>
                            <td>
                                <a href="{{ path('app_sponsor_contract_show', {'id': sponsor_contract.id}) }}" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('app_sponsor_contract_pdf', {'id': sponsor_contract.id}) }}" class="btn btn-sm btn-danger" target="_blank">
                                    <i class="fas fa-file-pdf"></i> PDF
                                </a>
                                <a href="{{ path('app_sponsor_contract_edit', {'id': sponsor_contract.id}) }}" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="{{ path('app_sponsor_contract_delete', {'id': sponsor_contract.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce contrat ?');" style="display: inline-block;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ sponsor_contract.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% else %}
    <div class="card">
        <div class="card-body">
            <div class="alert alert-info">
                <p class="mb-0">Aucun contrat trouvé. <a href="{{ path('app_sponsor_contract_new') }}">Créer le premier contrat</a></p>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}


