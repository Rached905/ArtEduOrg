{% extends 'base.html.twig' %}

{% block title %}Détails du Contrat{% endblock %}

{% block body %}
<div class="page-header">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="page-title">
                <i class="fas fa-file-contract"></i>
                Détails du Contrat
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_sponsor_contract_index') }}">Contrats</a></li>
                    <li class="breadcrumb-item active">{{ sponsor_contract.contractNumber }}</li>
                </ol>
            </nav>
        </div>
        <a href="{{ path('app_sponsor_contract_index') }}" class="btn btn-reset">
            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-borderless">
            <tbody>
                <tr>
                    <th width="200">Numéro de contrat</th>
                    <td><strong>{{ sponsor_contract.contractNumber }}</strong></td>
                </tr>
                <tr>
                    <th>Date de signature</th>
                    <td>{{ sponsor_contract.signedAt ? sponsor_contract.signedAt|date('d/m/Y') : '' }}</td>
                </tr>
                <tr>
                    <th>Date d'expiration</th>
                    <td>{{ sponsor_contract.expiresAt ? sponsor_contract.expiresAt|date('d/m/Y') : '' }}</td>
                </tr>
                <tr>
                    <th>Niveau</th>
                    <td>
                        {% set levelColors = {
                            'BRONZE': 'bg-secondary',
                            'SILVER': 'bg-light text-dark',
                            'GOLD': 'bg-warning',
                            'PLATINUM': 'bg-info'
                        } %}
                        <span class="badge {{ levelColors[sponsor_contract.level.value] ?? 'bg-secondary' }}">{{ sponsor_contract.level.value }}</span>
                    </td>
                </tr>
                <tr>
                    <th>Conditions</th>
                    <td>{{ sponsor_contract.terms|nl2br }}</td>
                </tr>
                <tr>
                    <th>Sponsor</th>
                    <td>
                        <strong>{{ sponsor_contract.sponsor.name }}</strong>
                        {% if sponsor_contract.sponsor.email %}
                            <br><small class="text-muted">{{ sponsor_contract.sponsor.email }}</small>
                        {% endif %}
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a href="{{ path('app_sponsor_contract_index') }}" class="btn btn-secondary">Retour à la liste</a>
    <a href="{{ path('app_sponsor_contract_pdf', {'id': sponsor_contract.id}) }}" class="btn btn-danger" target="_blank">
        <i class="fas fa-file-pdf"></i> Télécharger le PDF
    </a>
    <a href="{{ path('app_sponsor_contract_edit', {'id': sponsor_contract.id}) }}" class="btn btn-warning">
        <i class="fas fa-edit"></i> Modifier
    </a>
    {{ include('sponsor_contract/_delete_form.html.twig') }}
</div>
{% endblock %}


