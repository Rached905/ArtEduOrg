{% extends 'base.html.twig' %}

{% block title %}Créer un Contrat{% endblock %}

{% block body %}
<div class="page-header">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="page-title">
                <i class="fas fa-file-contract"></i>
                Créer un Contrat
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_sponsor_contract_index') }}">Contrats</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Nouveau</li>
                </ol>
            </nav>
        </div>
        <a href="{{ path('app_sponsor_contract_index') }}" class="btn btn-reset">
            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        {{ include('sponsor_contract/_form.html.twig', {'button_label': 'Créer le contrat'}) }}
    </div>
</div>
{% endblock %}


