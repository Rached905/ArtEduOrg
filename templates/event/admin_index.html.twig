{% extends 'base.html.twig' %}

{% block title %}Gestion des Événements{% endblock %}

{% block body %}
<!-- Flash Messages -->
{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="mdi mdi-check-circle"></i> {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="mdi mdi-alert-circle"></i> {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
{% endfor %}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="page-title">
                <i class="fas fa-calendar"></i>
                Gestion des Événements
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Événements</li>
                </ol>
            </nav>
        </div>
        <a href="{{ path('app_event_new') }}" class="btn btn-add">
            <i class="fas fa-plus me-2"></i>+ Nouvel événement
        </a>
    </div>
</div>

<!-- Cartes Statistiques -->
<div class="row mb-4">
    <div class="col-xl-3 col-sm-6 mb-4">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <div class="card-body text-white">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h6 class="text-white-50 mb-1" style="font-size: 0.875rem; font-weight: 500;">Programmés</h6>
                        <h2 class="mb-0 text-white" style="font-size: 2.5rem; font-weight: 700;">{{ stats.programme|default(0) }}</h2>
                    </div>
                    <div>
                        <i class="fas fa-calendar-clock fa-3x text-white" style="opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-3 col-sm-6 mb-4">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
            <div class="card-body text-white">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h6 class="text-white-50 mb-1" style="font-size: 0.875rem; font-weight: 500;">En cours</h6>
                        <h2 class="mb-0 text-white" style="font-size: 2.5rem; font-weight: 700;">{{ stats.en_cours|default(0) }}</h2>
                    </div>
                    <div>
                        <i class="fas fa-play-circle fa-3x text-white" style="opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-3 col-sm-6 mb-4">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #00c9ff 0%, #92fe9d 100%);">
            <div class="card-body text-white">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h6 class="text-white-50 mb-1" style="font-size: 0.875rem; font-weight: 500;">Terminés</h6>
                        <h2 class="mb-0 text-white" style="font-size: 2.5rem; font-weight: 700;">{{ stats.termine|default(0) }}</h2>
                    </div>
                    <div>
                        <i class="fas fa-check-circle fa-3x text-white" style="opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-3 col-sm-6 mb-4">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
            <div class="card-body text-white">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h6 class="text-white-50 mb-1" style="font-size: 0.875rem; font-weight: 500;">Annulés</h6>
                        <h2 class="mb-0 text-white" style="font-size: 2.5rem; font-weight: 700;">{{ stats.annule|default(0) }}</h2>
                    </div>
                    <div>
                        <i class="fas fa-times-circle fa-3x text-white" style="opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tableau des événements -->
<div class="row">
    <div class="col-12">
        <div class="stat-card">
            <h4 class="mb-4" style="font-weight: 600; color: #2d3436;">Liste des événements</h4>
            <div class="table-responsive">
                <table class="table table-hover" style="margin-bottom: 0;">
                    <thead>
                        <tr>
                            <th>Titre</th>
                            <th>Date début</th>
                            <th>Date fin</th>
                            <th>Lieu</th>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Capacité</th>
                            <th>Prix</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for event in events %}
                            <tr>
                                <td><strong>{{ event.title }}</strong></td>
                                <td>{{ event.startDate ? event.startDate|date('d/m/Y H:i') : 'N/A' }}</td>
                                <td>{{ event.endDate ? event.endDate|date('d/m/Y H:i') : 'N/A' }}</td>
                                <td>{{ event.location }}</td>
                                <td><span class="badge bg-black text-white" style="background-color: black !important;">{{ event.type }}</span></td>
                                <td>
                                    <span class="badge bg-black text-white" style="background-color: black !important;">
                                        {{ event.status ? event.status.value : 'N/A' }}
                                    </span>
                                </td>
                                <td>{{ event.capacity }}</td>
                                <td>{{ event.price ? event.price ~ ' €' : 'Gratuit' }}</td>
                                <td>
                                    <a href="{{ path('app_event_show', {'id': event.id}) }}" class="btn btn-sm btn-info btn-icon">
                                        <i class="mdi mdi-eye"></i>
                                    </a>
                                    <a href="{{ path('app_event_edit', {'id': event.id}) }}" class="btn btn-sm btn-primary btn-icon">
                                        <i class="mdi mdi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_event_delete', {'id': event.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet événement ?');" style="display: inline-block;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                                        <button type="submit" class="btn btn-sm btn-danger btn-icon">
                                            <i class="mdi mdi-delete"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    <p class="mt-2">Aucun événement trouvé</p>
                                    <a href="{{ path('app_event_new') }}" class="btn btn-add btn-sm mt-2">
                                        <i class="fas fa-plus me-2"></i>Créer un événement
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}


