{% extends 'basev.html.twig' %}

{% block title %}{{ event.title }} - ArtMarket{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="container">
        <div class="page-header mt-4 mb-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h1 class="page-title">
                        <i class="fas fa-calendar"></i>
                        {{ event.title }}
                    </h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="{{ path('app_vendeur') }}">Dashboard</a></li>
                            <li class="breadcrumb-item"><a href="{{ path('app_event_index') }}">Événements</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Détails</li>
                        </ol>
                    </nav>
                </div>
                <a href="{{ path('app_event_index') }}" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                </a>
            </div>
        </div>
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h1 class="card-title">{{ event.title }}</h1>
                </div>
                <div class="card-body">
                    <p class="lead">{{ event.description }}</p>

                    <div class="row">
                        <div class="col-md-6">
                            <h5>Dates</h5>
                            <p>{{ event.startDate|date('d/m/Y H:i') }} - {{ event.endDate ? event.endDate|date('d/m/Y H:i') : 'N/A' }}</p>
                        </div>
                        <div class="col-md-6">
                            <h5>Lieu</h5>
                            <p>{{ event.location }}</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <h5>Type</h5>
                            <p><span class="badge badge-info">{{ event.type }}</span></p>
                        </div>
                        <div class="col-md-6">
                            <h5>Prix</h5>
                            <p>{{ event.price ? event.price ~ ' €' : 'Gratuit' }}</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <h5>Capacité</h5>
                            <p>{{ event.capacity }}</p>
                        </div>
                        <div class="col-md-6">
                            <h5>Places restantes</h5>
                            <p>{{ event.capacity - event.ticketsSold }}</p>
                        </div>
                    </div>

                    {# Affichage des sponsors de l'événement #}
                    {% set event_sponsors = get_event_sponsors(event) %}
                    {% if event_sponsors|length > 0 %}
                        <div class="row mt-4">
                            <div class="col-md-12">
                                <h5>Sponsors de cet événement</h5>
                                <div class="d-flex flex-wrap gap-3">
                                    {% for sponsor in event_sponsors %}
                                        {% if sponsor.logo %}
                                            <a href="{{ sponsor.website ? sponsor.website : '#' }}" target="_blank" class="sponsor-logo-link" title="{{ sponsor.name }}">
                                                <img src="{{ asset('uploads/sponsors/' ~ sponsor.logo) }}" alt="{{ sponsor.name }}" class="sponsor-logo" style="max-height: 60px; max-width: 150px; object-fit: contain;">
                                            </a>
                                        {% else %}
                                            <span class="sponsor-name text-muted">{{ sponsor.name }}</span>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Acheter des billets</h5>
                </div>
                <div class="card-body">
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success">{{ message }}</div>
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endfor %}

                    {% set availableSeats = event.capacity - event.ticketsSold %}
                    {% if availableSeats > 0 %}
                        <form action="{{ path('app_ticket_purchase', {id: event.id})}}" method="post" id="ticketForm" onsubmit="return validateTicketForm({{ availableSeats }});" novalidate>
                            <div class="form-group mb-3">
                                <label for="buyer_name" class="form-label fw-bold">Nom <span class="text-danger">*</span></label>
                                <input type="text" id="buyer_name" name="buyer_name" class="form-control" 
                                       value="{{ app.user ? app.user.fullname : '' }}" required>
                            </div>
                            
                            <div class="form-group mb-3">
                                <label for="buyer_email" class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                                <input type="email" id="buyer_email" name="buyer_email" class="form-control" 
                                       value="{{ app.user ? app.user.email : '' }}" required>
                            </div>
                            
                            <div class="form-group mb-3">
                                <label for="quantity" class="form-label fw-bold">
                                    Nombre de billets <span class="text-danger">*</span>
                                    <small class="text-muted">(Places disponibles : {{ availableSeats }})</small>
                                </label>
                                <input type="number" id="quantity" name="quantity" 
                                       class="form-control" 
                                       min="1" 
                                       max="{{ availableSeats }}" 
                                       required>
                                <div class="form-text">Nombre maximum de billets que vous pouvez acheter : {{ availableSeats }}</div>
                            </div>
                            
                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-ticket-alt me-2"></i> Acheter les billets
                                </button>
                            </div>
                            
                            <div class="mt-3 text-muted small">
                                <span class="text-danger">*</span> Champs obligatoires
                            </div>
                        </form>
                    {% else %}
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> Désolé, cet événement est complet.
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# Section des avis #}
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-star"></i> Avis sur cet événement
                        {% if averageRating > 0 %}
                            <span class="badge bg-warning text-dark ms-2">{{ averageRating }}/5</span>
                        {% endif %}
                    </h5>
                    <button type="button" class="btn btn-success btn-sm" onclick="toggleReviewForm()">
                        <i class="fas fa-star me-2"></i>Créer un Avis
                    </button>
                </div>
                <div class="card-body">
                    {# Formulaire inline pour créer un avis #}
                    <div id="reviewFormContainer" style="display: none;" class="mb-4 p-3 bg-light rounded">
                        <h6 class="mb-3"><i class="fas fa-star me-2"></i>Votre avis</h6>
                        <form id="vendorReviewForm" onsubmit="submitVendorReview(event)">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Note <span class="text-danger">*</span></label>
                                <div class="star-rating-container">
                                    <div class="star-rating" id="vendorStarRating">
                                        {% for i in 1..5 %}
                                            <i class="far fa-star star-icon" data-rating="{{ i }}" style="font-size: 1.5rem; color: #ffc107; cursor: pointer; margin-right: 5px; user-select: none;"></i>
                                        {% endfor %}
                                    </div>
                                    <input type="hidden" id="vendor-rating-input" name="rating" required>
                                    <div class="invalid-feedback d-block" id="rating-error"></div>
                                    <small class="text-muted d-block mt-2">Cliquez sur les étoiles pour noter (1 à 5 étoiles)</small>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="vendor-comment" class="form-label fw-bold">Commentaire</label>
                                <textarea id="vendor-comment" name="comment" class="form-control" rows="3" placeholder="Votre commentaire..."></textarea>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-save me-2"></i>Enregistrer l'avis
                                </button>
                                <button type="button" class="btn btn-secondary" onclick="toggleReviewForm()">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </button>
                            </div>
                        </form>
                    </div>

                    <div id="reviewsList">
                        {% if reviews|length > 0 %}
                            {% for review in reviews %}
                                <div class="border-bottom pb-3 mb-3">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <strong>{{ review.user ? review.user.fullname : 'Anonyme' }}</strong>
                                            <div class="mt-1">
                                                {% for i in 1..5 %}
                                                    {% if i <= review.rating %}
                                                        <i class="fas fa-star text-warning"></i>
                                                    {% else %}
                                                        <i class="far fa-star text-muted"></i>
                                                    {% endif %}
                                                {% endfor %}
                                                <span class="ms-2 text-muted">({{ review.rating }}/5)</span>
                                            </div>
                                        </div>
                                        <small class="text-muted">{{ review.createdAt|date('d/m/Y H:i') }}</small>
                                    </div>
                                    {% if review.comment %}
                                        <p class="mb-0">{{ review.comment }}</p>
                                    {% else %}
                                        <p class="text-muted mb-0"><em>Aucun commentaire</em></p>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        {% else %}
                            <p class="text-muted text-center py-3">
                                <i class="fas fa-inbox fa-2x mb-2"></i><br>
                                Aucun avis pour cet événement. Soyez le premier à en laisser un !
                            </p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

<style>
:root {
    --primary-gradient: linear-gradient(135deg, #e94560 0%, #d63850 100%);
    --accent-color: #e94560;
    --dark-color: #1a1a2e;
}

.page-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--dark-color);
    margin-bottom: 10px;
}

.card {
    border-radius: 15px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    border: none;
    margin-bottom: 20px;
}

.card-header {
    background: var(--primary-gradient);
    color: white;
    border-radius: 15px 15px 0 0 !important;
    padding: 20px;
    border: none;
}

.card-header h1, .card-header h5 {
    color: white;
    margin: 0;
}

.badge-info {
    background: var(--accent-color);
    color: white;
    padding: 8px 15px;
    border-radius: 20px;
    font-weight: 600;
}

.btn-primary {
    background: var(--primary-gradient);
    border: none;
    border-radius: 50px;
    padding: 12px 30px;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(233, 69, 96, 0.4);
}

.form-control {
    border-radius: 10px;
    border: 2px solid #e0e0e0;
    padding: 12px 15px;
    transition: all 0.3s ease;
}

.form-control:focus {
    border-color: var(--accent-color);
    box-shadow: 0 0 0 0.2rem rgba(233, 69, 96, 0.25);
}

.sponsor-logo {
    max-height: 60px;
    max-width: 150px;
    object-fit: contain;
    filter: grayscale(20%);
    opacity: 0.8;
    transition: all 0.3s ease;
}

.sponsor-logo-link:hover .sponsor-logo {
    filter: grayscale(0%);
    opacity: 1;
    transform: scale(1.05);
}

/* Styles pour les étoiles du formulaire d'avis */
.star-rating-container {
    padding: 15px;
    background: #f8f9fa;
    border-radius: 8px;
    border: 1px solid #dee2e6;
}

.star-rating {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 10px;
}

.star-icon {
    transition: all 0.2s ease;
    cursor: pointer !important;
    pointer-events: auto !important;
    user-select: none;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
}

.star-icon:hover {
    transform: scale(1.3);
}

.star-icon.fas {
    color: #ffc107 !important;
}

.star-icon.far {
    color: #ffc107 !important;
}

#rating-error {
    color: #dc3545;
    font-size: 0.875rem;
    margin-top: 5px;
}
</style>

<script>
function validateTicketForm(availableSeats) {
    const quantity = parseInt(document.getElementById('quantity').value);
    if (quantity > availableSeats) {
        alert('Désolé, il ne reste que ' + availableSeats + ' place(s) disponible(s).');
        return false;
    }
    if (quantity > 10) {
        alert('Vous ne pouvez pas acheter plus de 10 billets à la fois.');
        return false;
    }
    return true;
}

// Variables globales pour les étoiles
let vendorStarsInitialized = false;

// Fonction pour initialiser les étoiles
function initVendorStarRating() {
    const starContainer = document.getElementById('vendorStarRating');
    if (!starContainer) return;
    
    // Éviter la double initialisation
    if (vendorStarsInitialized) return;
    
    const stars = starContainer.querySelectorAll('.star-icon');
    const ratingInput = document.getElementById('vendor-rating-input');
    if (!ratingInput || stars.length === 0) return;
    
    stars.forEach((star, index) => {
        const rating = index + 1;
        
        // Supprimer les anciens event listeners si existants
        const newStar = star.cloneNode(true);
        star.parentNode.replaceChild(newStar, star);
        
        // Ajouter les nouveaux event listeners
        newStar.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            ratingInput.value = rating;
            updateVendorStars(stars, rating);
            const errorElement = document.getElementById('rating-error');
            if (errorElement) {
                errorElement.style.display = 'none';
            }
        });
        
        newStar.addEventListener('mouseenter', function() {
            highlightVendorStars(stars, rating);
        });
    });
    
    starContainer.addEventListener('mouseleave', function() {
        const currentValue = ratingInput.value ? parseInt(ratingInput.value) : 0;
        if (currentValue > 0) {
            updateVendorStars(stars, currentValue);
        } else {
            clearVendorStars();
        }
    });
    
    vendorStarsInitialized = true;
}

function updateVendorStars(stars, rating) {
    stars.forEach((star, index) => {
        const starRating = index + 1;
        if (starRating <= rating) {
            star.classList.remove('far');
            star.classList.add('fas', 'filled', 'active');
            star.style.color = '#ffc107';
        } else {
            star.classList.remove('fas', 'filled', 'active');
            star.classList.add('far');
            star.style.color = '#ffc107';
        }
    });
}

function highlightVendorStars(stars, rating) {
    stars.forEach((star, index) => {
        const starRating = index + 1;
        if (starRating <= rating) {
            star.style.color = '#ffc107';
            star.style.transform = 'scale(1.2)';
        } else {
            star.style.color = '#ddd';
            star.style.transform = 'scale(1)';
        }
    });
}

function clearVendorStars() {
    const stars = document.querySelectorAll('#vendorStarRating .star-icon');
    stars.forEach(star => {
        star.classList.remove('fas', 'filled', 'active');
        star.classList.add('far');
        star.style.color = '#ffc107';
        star.style.transform = 'scale(1)';
    });
}

// Fonction pour afficher/masquer le formulaire d'avis
function toggleReviewForm() {
    const formContainer = document.getElementById('reviewFormContainer');
    if (!formContainer) return;
    
    if (formContainer.style.display === 'none' || formContainer.style.display === '') {
        formContainer.style.display = 'block';
        // Réinitialiser les étoiles quand le formulaire est affiché
        vendorStarsInitialized = false;
        setTimeout(initVendorStarRating, 100);
    } else {
        formContainer.style.display = 'none';
        // Réinitialiser le formulaire
        const form = document.getElementById('vendorReviewForm');
        if (form) form.reset();
        const ratingInput = document.getElementById('vendor-rating-input');
        if (ratingInput) ratingInput.value = '';
        clearVendorStars();
    }
}

// Initialisation au chargement de la page
(function() {
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(initVendorStarRating, 500);
        });
    } else {
        setTimeout(initVendorStarRating, 500);
    }
})();

// Fonction pour soumettre l'avis du vendeur
async function submitVendorReview(event) {
    event.preventDefault();
    event.stopPropagation();
    
    const ratingInput = document.getElementById('vendor-rating-input');
    const commentInput = document.getElementById('vendor-comment');
    const ratingError = document.getElementById('rating-error');
    const submitButton = event.target.querySelector('button[type="submit"]') || event.target;
    
    if (!ratingInput || !ratingInput.value || parseInt(ratingInput.value) < 1 || parseInt(ratingInput.value) > 5) {
        if (ratingError) {
            ratingError.textContent = 'Veuillez sélectionner une note entre 1 et 5 étoiles.';
            ratingError.style.display = 'block';
            ratingError.style.color = '#dc3545';
        } else {
            alert('Veuillez sélectionner une note entre 1 et 5 étoiles.');
        }
        return false;
    }
    
    if (ratingError) {
        ratingError.style.display = 'none';
    }
    
    // Désactiver le bouton pendant l'envoi
    if (submitButton) {
        submitButton.disabled = true;
        submitButton.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Enregistrement...';
    }
    
    const formData = new FormData();
    formData.append('rating', ratingInput.value);
    formData.append('comment', commentInput ? commentInput.value : '');
    
    // Construire l'URL de la route avec l'ID de l'événement depuis le template
    const url = '{{ path('app_event_review_vendor_new', {'eventId': event.id}) }}';
    
    try {
        const response = await fetch(url, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        
        if (!response.ok) {
            throw new Error('Erreur HTTP: ' + response.status);
        }
        
        const data = await response.json();
        
        if (data.success) {
            // Afficher un message de succès
            alert(data.message || 'Votre avis a été enregistré avec succès.');
            
            // Masquer le formulaire
            toggleReviewForm();
            
            // Recharger la page pour afficher le nouvel avis
            setTimeout(() => {
                window.location.reload();
            }, 500);
        } else {
            alert('Erreur : ' + (data.message || 'Une erreur est survenue.'));
            if (submitButton) {
                submitButton.disabled = false;
                submitButton.innerHTML = '<i class="fas fa-save me-2"></i>Enregistrer l\'avis';
            }
        }
    } catch (error) {
        console.error('Erreur:', error);
        alert('Une erreur est survenue lors de l\'enregistrement de l\'avis. Veuillez réessayer.');
        if (submitButton) {
            submitButton.disabled = false;
            submitButton.innerHTML = '<i class="fas fa-save me-2"></i>Enregistrer l\'avis';
        }
    }
    
    return false;
}
</script>
{% endblock %}

