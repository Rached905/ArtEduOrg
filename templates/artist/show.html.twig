{% extends 'basec.html.twig' %}

{% block title %}Œuvres de {{ artist.fullname }} - ArtMarket{% endblock %}

{% block body %}
<div class="artist-works-page" style="padding: 2rem; max-width: 1400px; margin: 0 auto;">
    <div class="page-header" style="margin-bottom: 2rem; background: white; padding: 2rem; border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
        <div style="display: flex; align-items: center; gap: 2rem; margin-bottom: 1rem;">
            <div class="artist-avatar-large" style="width: 150px; height: 150px; border-radius: 50%; background: linear-gradient(135deg, #e94560 0%, #d63850 100%); display: flex; align-items: center; justify-content: center; font-size: 4rem; color: white; font-weight: 700; flex-shrink: 0;">
                {{ artist.fullname|first|upper }}
            </div>
            <div style="flex: 1;">
                <h1 style="font-size: 2.5rem; font-weight: 700; color: #1a1a2e; margin-bottom: 0.5rem;">
                    {{ artist.fullname }}
                </h1>
                <p style="color: #666; font-size: 1.1rem; margin-bottom: 0.5rem;">
                    <i class="fas fa-envelope"></i> {{ artist.email }}
                </p>
                <p style="color: #999; font-size: 0.9rem;">
                    <i class="fas fa-calendar"></i> Membre depuis {{ artist.createdAt|date('F Y') }}
                </p>
            </div>
        </div>
        <a href="{{ path('app_artist_index') }}" style="display: inline-flex; align-items: center; gap: 0.5rem; color: #e94560; text-decoration: none; font-weight: 600;">
            <i class="fas fa-arrow-left"></i> Retour à la galerie des artistes
        </a>
    </div>

    <div style="margin-bottom: 2rem;">
        <h2 style="font-size: 2rem; font-weight: 700; color: #1a1a2e; margin-bottom: 1rem;">
            <i class="fas fa-palette" style="color: #e94560;"></i> Œuvres partagées ({{ sales|length }})
        </h2>
    </div>

    {% if sales|length > 0 %}
        <div class="artworks-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
            {% for sale in sales %}
                <div class="artwork-card" style="background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.1); transition: all 0.3s ease; cursor: pointer; border: 2px solid transparent;"
                     onclick="window.location.href='{{ path('app_sale_details', {id: sale.id}) }}'"
                     onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 20px 60px rgba(0,0,0,0.15)'; this.style.borderColor='#e94560';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 40px rgba(0,0,0,0.1)'; this.style.borderColor='transparent';">
                    <div class="artwork-image" style="position: relative; height: 250px; background: linear-gradient(135deg, #f8f9fa 0%, #e8ecf1 100%); overflow: hidden;">
                        {% if sale.image %}
                            <img src="{{ asset('uploads/sales/' ~ sale.image) }}" alt="{{ sale.title }}" 
                                 style="width: 100%; height: 100%; object-fit: cover;">
                        {% elseif sale.getPrimaryImage() %}
                            <img src="{{ asset('uploads/sales/' ~ sale.getPrimaryImage().path) }}" alt="{{ sale.title }}" 
                                 style="width: 100%; height: 100%; object-fit: cover;">
                        {% else %}
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; font-size: 4rem;">
                                🎨
                            </div>
                        {% endif %}
                        {% if sale.status.value == 'vendue' %}
                            <div style="position: absolute; top: 15px; right: 15px; padding: 6px 15px; background: #4caf50; color: white; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">
                                Vendue
                            </div>
                        {% elseif sale.status.value == 'disponible' %}
                            <div style="position: absolute; top: 15px; right: 15px; padding: 6px 15px; background: #2196f3; color: white; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">
                                Disponible
                            </div>
                        {% endif %}
                    </div>
                    <div class="artwork-info" style="padding: 1.5rem;">
                        <h4 style="font-size: 1.2rem; font-weight: 700; color: #1a1a2e; margin-bottom: 0.75rem;">
                            {{ sale.title }}
                        </h4>
                        <div style="display: flex; gap: 15px; margin-bottom: 1rem; font-size: 0.9rem; color: #666;">
                            <span><i class="fas fa-tag"></i> {{ sale.type.value }}</span>
                            <span><i class="fas fa-calendar"></i> {{ sale.createdAt|date('d/m/Y') }}</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div style="font-size: 1.4rem; font-weight: 800; color: #e94560;">
                                {% if sale.amount %}{{ sale.amount|number_format(0, ',', ' ') }}€{% else %}Prix sur demande{% endif %}
                            </div>
                            <a href="{{ path('app_sale_details', {id: sale.id}) }}" 
                               style="padding: 8px 20px; background: #e94560; color: white; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9rem;">
                                Voir détails
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div style="text-align: center; padding: 4rem; background: white; border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
            <i class="fas fa-palette" style="font-size: 4rem; color: #ccc; margin-bottom: 1rem; display: block;"></i>
            <h3 style="color: #666; margin-bottom: 1rem;">Aucune œuvre partagée</h3>
            <p style="color: #999;">Cet artiste n'a pas encore partagé d'œuvres sur la plateforme.</p>
        </div>
    {% endif %}
</div>

<style>
    @media (max-width: 768px) {
        .artworks-grid {
            grid-template-columns: 1fr !important;
        }
        .page-header > div {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
{% endblock %}

