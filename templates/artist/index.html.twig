{% extends 'basec.html.twig' %}

{% block title %}Galerie des Artistes - ArtMarket{% endblock %}

{% block body %}
<div class="artists-gallery" style="padding: 2rem; max-width: 1400px; margin: 0 auto;">
    <div class="page-header" style="margin-bottom: 2rem;">
        <h1 style="font-size: 2.5rem; font-weight: 700; color: #1a1a2e; margin-bottom: 0.5rem;">
            <i class="fas fa-palette" style="color: #e94560;"></i> Galerie des Artistes
        </h1>
        <p style="color: #666; font-size: 1.1rem;">Découvrez tous nos artistes et leurs créations</p>
    </div>

    {% if artists|length > 0 %}
        <div class="artists-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
            {% for artist in artists %}
                <div class="artist-card" style="background: white; border-radius: 20px; padding: 2rem; box-shadow: 0 10px 40px rgba(0,0,0,0.1); transition: all 0.3s ease; cursor: pointer; border: 2px solid transparent;" 
                     onclick="window.location.href='{{ path('app_artist_show', {id: artist.id}) }}'"
                     onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 20px 60px rgba(0,0,0,0.15)'; this.style.borderColor='#e94560';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 40px rgba(0,0,0,0.1)'; this.style.borderColor='transparent';">
                    <div class="artist-avatar" style="width: 120px; height: 120px; margin: 0 auto 1.5rem; border-radius: 50%; background: linear-gradient(135deg, #e94560 0%, #d63850 100%); display: flex; align-items: center; justify-content: center; font-size: 3rem; color: white; font-weight: 700;">
                        {{ artist.fullname|first|upper }}
                    </div>
                    <h3 style="text-align: center; font-size: 1.5rem; font-weight: 700; color: #1a1a2e; margin-bottom: 0.5rem;">
                        {{ artist.fullname }}
                    </h3>
                    <p style="text-align: center; color: #666; margin-bottom: 1rem; font-size: 0.9rem;">
                        <i class="fas fa-envelope"></i> {{ artist.email }}
                    </p>
                    <div style="text-align: center;">
                        <a href="{{ path('app_artist_show', {id: artist.id}) }}" 
                           style="display: inline-block; padding: 12px 30px; background: linear-gradient(135deg, #e94560 0%, #d63850 100%); color: white; border-radius: 10px; text-decoration: none; font-weight: 600; transition: all 0.3s ease;"
                           onmouseover="this.style.transform='scale(1.05)';"
                           onmouseout="this.style.transform='scale(1)';">
                            <i class="fas fa-eye"></i> Voir les œuvres
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div style="text-align: center; padding: 4rem; background: white; border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
            <i class="fas fa-palette" style="font-size: 4rem; color: #ccc; margin-bottom: 1rem; display: block;"></i>
            <h3 style="color: #666; margin-bottom: 1rem;">Aucun artiste trouvé</h3>
            <p style="color: #999;">Il n'y a pas encore d'artistes inscrits sur la plateforme.</p>
        </div>
    {% endif %}
</div>

<style>
    @media (max-width: 768px) {
        .artists-grid {
            grid-template-columns: 1fr !important;
        }
    }
</style>
{% endblock %}

