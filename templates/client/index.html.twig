{% extends 'basec.html.twig' %}

{% block title %}ArtMarket - Plateforme d'Art{% endblock %}

{% block body %}
<div class="artmarket-home">
    
    {# Hero Section with modern gradient #}
    <section class="hero-section">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
            <div class="hero-badge animate-fade-in">🎨 Plateforme d'Art Premium</div>
            <h1 class="hero-title animate-fade-in-delay">Bienvenue sur ArtMarket</h1>
            <p class="hero-subtitle animate-fade-in-delay-2">Découvrez et achetez des œuvres d'art uniques lors d'événements exclusifs</p>
            
            {% if app.user %}
                <div class="welcome-message animate-fade-in-delay-3">
                    <div class="user-card-hero">
                        <div class="user-avatar-hero">{{ app.user.fullname|first|upper }}</div>
                        <p class="user-greeting">Bonjour <strong>{{ app.user.fullname }}</strong> !</p>
                    </div>
                    <a href="{{ path('app_login') }}" class="btn btn-hero-modern">
                        <span>Explorer les événements</span>
                        <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            {% else %}
                <div class="hero-actions animate-fade-in-delay-3">
                    <a href="{{ path('app_login') }}" class="btn btn-hero-modern btn-primary-modern">
                        <span>Se connecter</span>
                        <i class="fas fa-sign-in-alt ms-2"></i>
                    </a>
                    <a href="{{ path('app_register') }}" class="btn btn-hero-modern btn-outline-modern">
                        <span>S'inscrire</span>
                        <i class="fas fa-user-plus ms-2"></i>
                    </a>
                </div>
            {% endif %}
        </div>
        
        {# Modern decorative elements #}
        <div class="hero-decoration">
            <div class="floating-shape shape-1"></div>
            <div class="floating-shape shape-2"></div>
            <div class="floating-shape shape-3"></div>
            <div class="floating-shape shape-4"></div>
        </div>
        
        {# Scroll indicator #}
        <div class="scroll-indicator">
            <div class="mouse">
                <div class="wheel"></div>
            </div>
        </div>
    </section>

    {# Statistics Section #}
    <section class="stats-section">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card-modern">
                        <div class="stat-icon-modern">
                            <i class="fas fa-palette"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-number-modern" data-count="500">0</div>
                            <div class="stat-label-modern">Œuvres d'art</div>
                        </div>
                        <div class="stat-bg-icon">🎨</div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card-modern">
                        <div class="stat-icon-modern">
                            <i class="fas fa-users"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-number-modern" data-count="150">0</div>
                            <div class="stat-label-modern">Artistes</div>
                        </div>
                        <div class="stat-bg-icon">👨‍🎨</div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card-modern">
                        <div class="stat-icon-modern">
                            <i class="fas fa-calendar-check"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-number-modern" data-count="50">0</div>
                            <div class="stat-label-modern">Événements</div>
                        </div>
                        <div class="stat-bg-icon">📅</div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card-modern">
                        <div class="stat-icon-modern">
                            <i class="fas fa-smile"></i>
                        </div>
                        <div class="stat-content">
                            <div class="stat-number-modern" data-count="1000">0</div>
                            <div class="stat-label-modern">Clients satisfaits</div>
                        </div>
                        <div class="stat-bg-icon">⭐</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# How it works Section #}
    <section class="how-it-works-modern">
        <div class="container">
            <div class="section-header-modern">
                <span class="section-badge">PROCESSUS</span>
                <h2 class="section-title-modern">Comment ça marche ?</h2>
                <p class="section-subtitle-modern">Trois étapes simples pour acquérir vos œuvres préférées</p>
            </div>
            
            <div class="steps-container-modern">
                <div class="step-card-modern">
                    <div class="step-number-modern">01</div>
                    <div class="step-icon-wrapper">
                        <div class="step-icon-modern">
                            <i class="fas fa-search"></i>
                        </div>
                    </div>
                    <h4 class="step-title-modern">Parcourez les événements</h4>
                    <p class="step-description-modern">Découvrez les expositions et ventes d'art à venir dans votre région</p>
                    <div class="step-arrow">
                        <i class="fas fa-arrow-right"></i>
                    </div>
                </div>
                
                <div class="step-card-modern">
                    <div class="step-number-modern">02</div>
                    <div class="step-icon-wrapper">
                        <div class="step-icon-modern">
                            <i class="fas fa-image"></i>
                        </div>
                    </div>
                    <h4 class="step-title-modern">Explorez les œuvres</h4>
                    <p class="step-description-modern">Visualisez les tableaux des artistes participants en haute qualité</p>
                    <div class="step-arrow">
                        <i class="fas fa-arrow-right"></i>
                    </div>
                </div>
                
                <div class="step-card-modern">
                    <div class="step-number-modern">03</div>
                    <div class="step-icon-wrapper">
                        <div class="step-icon-modern">
                            <i class="fas fa-shopping-bag"></i>
                        </div>
                    </div>
                    <h4 class="step-title-modern">Achetez en toute sécurité</h4>
                    <p class="step-description-modern">Réservez vos coups de cœur facilement et en toute confiance</p>
                </div>
            </div>
        </div>
    </section>

    {# Features Section #}
    <section class="features-section-modern">
        <div class="container">
            <div class="section-header-modern">
                <span class="section-badge">AVANTAGES</span>
                <h2 class="section-title-modern">Pourquoi choisir ArtMarket ?</h2>
            </div>
            
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card-modern">
                        <div class="feature-icon-wrapper">
                            <div class="feature-icon-modern">
                                <i class="fas fa-certificate"></i>
                            </div>
                        </div>
                        <h4>Artistes vérifiés</h4>
                        <p>Tous nos artistes sont soigneusement sélectionnés pour leur talent et authenticité</p>
                        <div class="feature-hover-effect"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card-modern">
                        <div class="feature-icon-wrapper">
                            <div class="feature-icon-modern">
                                <i class="fas fa-shield-alt"></i>
                            </div>
                        </div>
                        <h4>Paiement sécurisé</h4>
                        <p>Transactions 100% sécurisées avec garantie de remboursement</p>
                        <div class="feature-hover-effect"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card-modern">
                        <div class="feature-icon-wrapper">
                            <div class="feature-icon-modern">
                                <i class="fas fa-truck"></i>
                            </div>
                        </div>
                        <h4>Livraison soignée</h4>
                        <p>Emballage professionnel et livraison assurée pour vos œuvres</p>
                        <div class="feature-hover-effect"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# CTA Section #}
    <section class="cta-section-modern">
        <div class="cta-background"></div>
        <div class="container">
            <div class="cta-content-modern">
                <div class="cta-icon-modern">
                    <i class="fas fa-rocket"></i>
                </div>
                <h2 class="cta-title-modern">Prêt à découvrir l'art autrement ?</h2>
                <p class="cta-text-modern">Rejoignez notre communauté d'amateurs d'art dès aujourd'hui et explorez un monde d'œuvres uniques</p>
                <a href="{{ path('app_login') }}" class="btn-cta-modern">
                    <span>Découvrir les événements</span>
                    <i class="fas fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </section>

</div>

<style>
:root {
    --primary-gradient: linear-gradient(135deg, #e94560 0%, #d63850 100%);
    --secondary-gradient: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    --accent-color: #e94560;
    --dark-color: #1a1a2e;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

.artmarket-home {
    overflow-x: hidden;
}

/* Hero Section - Modern Style */
.hero-section {
    position: relative;
    min-height: 85vh;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #e94560 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    overflow: hidden;
}

.hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
        radial-gradient(circle at 20% 50%, rgba(233, 69, 96, 0.2) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(233, 69, 96, 0.15) 0%, transparent 50%);
}

.hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 80px 20px;
}

.hero-badge {
    display: inline-block;
    padding: 10px 25px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 25px;
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.hero-title {
    font-size: 4.5rem;
    font-weight: 800;
    margin-bottom: 25px;
    text-shadow: 2px 2px 30px rgba(0,0,0,0.3);
    background: linear-gradient(to right, #ffffff, #ffccdd);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hero-subtitle {
    font-size: 1.4rem;
    margin-bottom: 50px;
    opacity: 0.95;
    font-weight: 400;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
}

.user-card-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    margin-bottom: 30px;
    padding: 20px 40px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 50px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: inline-flex;
}

.user-avatar-hero {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: var(--primary-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.3rem;
    border: 3px solid white;
}

.user-greeting {
    font-size: 1.3rem;
    margin: 0;
}

.hero-actions {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
}

.btn-hero-modern {
    padding: 18px 45px;
    font-size: 1.1rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.4s ease;
    display: inline-flex;
    align-items: center;
    border: 2px solid white;
    position: relative;
    overflow: hidden;
    z-index: 1;
}

.btn-hero-modern::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.2);
    transition: left 0.4s ease;
    z-index: -1;
}

.btn-hero-modern:hover::before {
    left: 100%;
}

.btn-hero-modern.btn-primary-modern {
    background: white;
    color: var(--accent-color);
}

.btn-hero-modern.btn-primary-modern:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.3);
}

.btn-hero-modern.btn-outline-modern {
    background: transparent;
    color: white;
}

.btn-hero-modern.btn-outline-modern:hover {
    background: white;
    color: var(--accent-color);
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.3);
}

/* Modern floating shapes */
.floating-shape {
    position: absolute;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(233, 69, 96, 0.2));
    backdrop-filter: blur(5px);
    animation: float 25s infinite ease-in-out;
}

.shape-1 {
    width: 250px;
    height: 250px;
    top: 10%;
    left: 5%;
    animation-delay: 0s;
}

.shape-2 {
    width: 180px;
    height: 180px;
    top: 60%;
    right: 10%;
    animation-delay: 7s;
}

.shape-3 {
    width: 120px;
    height: 120px;
    bottom: 15%;
    left: 55%;
    animation-delay: 14s;
}

.shape-4 {
    width: 200px;
    height: 200px;
    top: 40%;
    right: 40%;
    animation-delay: 3s;
}

@keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(30px, -40px) rotate(90deg); }
    50% { transform: translate(-20px, 30px) rotate(180deg); }
    75% { transform: translate(40px, 20px) rotate(270deg); }
}

/* Scroll indicator */
.scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
}

.mouse {
    width: 30px;
    height: 50px;
    border: 2px solid rgba(255, 255, 255, 0.6);
    border-radius: 20px;
    display: flex;
    justify-content: center;
    padding-top: 10px;
}

.wheel {
    width: 4px;
    height: 10px;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 2px;
    animation: scroll 1.5s infinite;
}

@keyframes scroll {
    0% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(15px); }
}

/* Animations */
.animate-fade-in {
    animation: fadeInUp 0.8s ease-out;
}

.animate-fade-in-delay {
    animation: fadeInUp 0.8s ease-out 0.2s both;
}

.animate-fade-in-delay-2 {
    animation: fadeInUp 0.8s ease-out 0.4s both;
}

.animate-fade-in-delay-3 {
    animation: fadeInUp 0.8s ease-out 0.6s both;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(40px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Stats Section - Modern */
.stats-section {
    padding: 100px 0;
    background: #f8f9fa;
    position: relative;
}

.stat-card-modern {
    position: relative;
    background: white;
    border-radius: 20px;
    padding: 40px 30px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    transition: all 0.4s ease;
    overflow: hidden;
    border: 2px solid transparent;
}

.stat-card-modern:hover {
    transform: translateY(-15px);
    box-shadow: 0 20px 60px rgba(233, 69, 96, 0.2);
    border-color: var(--accent-color);
}

.stat-icon-modern {
    width: 70px;
    height: 70px;
    background: var(--primary-gradient);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 25px;
    color: white;
    font-size: 1.8rem;
    box-shadow: 0 8px 25px rgba(233, 69, 96, 0.3);
}

.stat-content {
    position: relative;
    z-index: 2;
}

.stat-number-modern {
    font-size: 3rem;
    font-weight: 800;
    background: var(--primary-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 10px;
}

.stat-number-modern::after {
    content: '+';
}

.stat-label-modern {
    font-size: 1.1rem;
    color: #666;
    font-weight: 600;
}

.stat-bg-icon {
    position: absolute;
    right: -20px;
    bottom: -20px;
    font-size: 120px;
    opacity: 0.05;
    z-index: 1;
}

/* How it works - Modern */
.how-it-works-modern {
    padding: 100px 0;
    background: white;
}

.section-header-modern {
    text-align: center;
    margin-bottom: 80px;
}

.section-badge {
    display: inline-block;
    padding: 8px 20px;
    background: rgba(233, 69, 96, 0.1);
    color: var(--accent-color);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 20px;
}

.section-title-modern {
    font-size: 3rem;
    font-weight: 800;
    color: var(--dark-color);
    margin-bottom: 20px;
}

.section-subtitle-modern {
    font-size: 1.3rem;
    color: #666;
    max-width: 600px;
    margin: 0 auto;
}

.steps-container-modern {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 40px;
    position: relative;
}

.step-card-modern {
    position: relative;
    background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
    border-radius: 25px;
    padding: 50px 35px;
    text-align: center;
    transition: all 0.4s ease;
    border: 2px solid #f0f0f0;
}

.step-card-modern:hover {
    transform: translateY(-15px);
    box-shadow: 0 25px 60px rgba(0,0,0,0.12);
    border-color: var(--accent-color);
}

.step-number-modern {
    position: absolute;
    top: -20px;
    right: 30px;
    font-size: 5rem;
    font-weight: 900;
    background: var(--primary-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    opacity: 0.15;
}

.step-icon-wrapper {
    margin-bottom: 30px;
}

.step-icon-modern {
    width: 90px;
    height: 90px;
    background: var(--primary-gradient);
    border-radius: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 2.2rem;
    box-shadow: 0 15px 40px rgba(233, 69, 96, 0.3);
    transition: all 0.4s ease;
}

.step-card-modern:hover .step-icon-modern {
    transform: scale(1.1) rotate(5deg);
}

.step-title-modern {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--dark-color);
    margin-bottom: 15px;
}

.step-description-modern {
    color: #666;
    line-height: 1.7;
    font-size: 1.05rem;
}

.step-arrow {
    position: absolute;
    right: -20px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 2rem;
    color: var(--accent-color);
    opacity: 0.3;
}

.step-card-modern:last-child .step-arrow {
    display: none;
}

/* Features Section - Modern */
.features-section-modern {
    padding: 100px 0;
    background: linear-gradient(135deg, #f8f9fa 0%, #e8ecf1 100%);
}

.feature-card-modern {
    position: relative;
    background: white;
    border-radius: 25px;
    padding: 50px 40px;
    text-align: center;
    transition: all 0.4s ease;
    border: 2px solid transparent;
    overflow: hidden;
}

.feature-card-modern:hover {
    transform: translateY(-15px);
    border-color: var(--accent-color);
    box-shadow: 0 25px 60px rgba(233, 69, 96, 0.15);
}

.feature-icon-wrapper {
    margin-bottom: 30px;
}

.feature-icon-modern {
    width: 100px;
    height: 100px;
    background: var(--primary-gradient);
    border-radius: 25px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 2.5rem;
    box-shadow: 0 15px 40px rgba(233, 69, 96, 0.3);
    transition: all 0.4s ease;
}

.feature-card-modern:hover .feature-icon-modern {
    transform: scale(1.1) rotate(-5deg);
}

.feature-card-modern h4 {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--dark-color);
    margin-bottom: 20px;
}

.feature-card-modern p {
    color: #666;
    line-height: 1.7;
    font-size: 1.05rem;
}

.feature-hover-effect {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 5px;
    background: var(--primary-gradient);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}

.feature-card-modern:hover .feature-hover-effect {
    transform: scaleX(1);
}

/* CTA Section - Modern */
.cta-section-modern {
    position: relative;
    padding: 120px 0;
    background: var(--secondary-gradient);
    color: white;
    overflow: hidden;
}

.cta-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
        radial-gradient(circle at 30% 50%, rgba(233, 69, 96, 0.3) 0%, transparent 50%),
        radial-gradient(circle at 70% 80%, rgba(233, 69, 96, 0.2) 0%, transparent 50%);
}

.cta-content-modern {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
}

.cta-icon-modern {
    width: 100px;
    height: 100px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    margin-bottom: 30px;
    border: 2px solid rgba(255, 255, 255, 0.3);
}

.cta-title-modern {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 25px;
}

.cta-text-modern {
    font-size: 1.3rem;
    margin-bottom: 50px;
    opacity: 0.95;
    line-height: 1.7;
}

.btn-cta-modern {
    padding: 22px 55px;
    font-size: 1.2rem;
    background: white;
    color: var(--accent-color);
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    transition: all 0.4s ease;
    box-shadow: 0 15px 45px rgba(0,0,0,0.3);
    border: 2px solid white;
