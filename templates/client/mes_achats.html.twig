{% extends 'basec.html.twig' %}

{% block title %}Mes Achats - ArtMarket{% endblock %}

{% block body %}
<div class="container-fluid py-5" style="margin-top: 80px;">
    <div class="container">
        <div class="page-header mb-5">
            <h1 class="page-title">
                <i class="fas fa-shopping-cart"></i>
                Mes Achats
            </h1>
            <p class="text-muted">Consultez tous vos tickets et œuvres achetés</p>
        </div>

        {# Section des Œuvres Achetées #}
        {% if purchasedSales|length > 0 %}
        <div class="section-header mb-4">
            <h2 class="section-title">
                <i class="fas fa-palette me-2"></i>
                Mes Œuvres Achetées
            </h2>
            <p class="text-muted mb-0">Consultez la fiche de chaque œuvre, modifiez les informations ou sa visibilité sur la plateforme.</p>
        </div>
        <div class="row g-4 mb-5">
            {% for sale in purchasedSales %}
            <div class="col-md-6 col-lg-4">
                <div class="card artwork-purchase-card">
                    {% set primaryImage = sale.getPrimaryImage() %}
                    <div class="artwork-purchase-image">
                        {% if primaryImage %}
                            <img src="{{ asset(primaryImage.path) }}" alt="{{ sale.title }}" class="card-img-top">
                        {% elseif sale.image %}
                            <img src="{{ asset(sale.image) }}" alt="{{ sale.title }}" class="card-img-top">
                        {% else %}
                            <div class="artwork-placeholder">
                                <i class="fas fa-image fa-3x"></i>
                            </div>
                        {% endif %}
                        <div class="artwork-badge purchased">
                            <i class="fas fa-check-circle"></i> Achetée
                        </div>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">{{ sale.title }}</h5>
                        {% if sale.description %}
                            <p class="card-text text-muted">{{ sale.description|slice(0, 100) }}{% if sale.description|length > 100 %}...{% endif %}</p>
                        {% endif %}
                        <div class="artwork-purchase-info">
                            <div class="info-item">
                                <i class="fas fa-euro-sign text-primary"></i>
                                <div>
                                    <strong>Prix payé:</strong>
                                    <p class="mb-0">{{ sale.amount|number_format(2, ',', ' ') }} €</p>
                                </div>
                            </div>
                            <div class="info-item">
                                <i class="fas fa-calendar text-primary"></i>
                                <div>
                                    <strong>Date d'achat:</strong>
                                    <p class="mb-0">{{ sale.createdAt ? sale.createdAt|date('d/m/Y') : 'N/A' }}</p>
                                </div>
                            </div>
                            {% if sale.vendeur %}
                            <div class="info-item">
                                <i class="fas fa-user text-primary"></i>
                                <div>
                                    <strong>Artiste:</strong>
                                    <p class="mb-0">{{ sale.vendeur.fullname }}</p>
                                </div>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="card-footer bg-light d-flex gap-2 flex-wrap">
                        <a href="{{ path('app_sale_details', {id: sale.id}) }}" class="btn btn-primary flex-grow-1">
                            <i class="fas fa-eye"></i> Voir les détails
                        </a>
                        <a href="{{ path('app_sale_edit', {id: sale.id}) }}" class="btn btn-outline-secondary">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# Section des Tickets #}
        {% if tickets|length > 0 %}
        <div class="section-header mb-4">
            <h2 class="section-title">
                <i class="fas fa-ticket-alt me-2"></i>
                Mes Tickets d'Événements
            </h2>
        </div>
        <div class="row g-4">
        <div class="row g-4">
            {% for ticket in tickets %}
            <div class="col-md-6 col-lg-4">
                <div class="card ticket-card">
                    <div class="card-header bg-primary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="fas fa-ticket-alt"></i> Ticket #{{ ticket.id }}
                            </h5>
                            <span class="badge bg-light text-dark">{{ ticket.event.title }}</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="ticket-info">
                            <div class="info-item">
                                <i class="fas fa-calendar text-primary"></i>
                                <div>
                                    <strong>Date d'achat:</strong>
                                    <p class="mb-0">{{ ticket.issuedAt|date('d/m/Y H:i') }}</p>
                                </div>
                            </div>
                            <div class="info-item">
                                <i class="fas fa-user text-primary"></i>
                                <div>
                                    <strong>Acheteur:</strong>
                                    <p class="mb-0">{{ ticket.buyerName }}</p>
                                </div>
                            </div>
                            <div class="info-item">
                                <i class="fas fa-euro-sign text-primary"></i>
                                <div>
                                    <strong>Prix:</strong>
                                    <p class="mb-0">{{ ticket.price|number_format(2, ',', ' ') }} €</p>
                                </div>
                            </div>
                            {% if ticket.seatNumber %}
                            <div class="info-item">
                                <i class="fas fa-chair text-primary"></i>
                                <div>
                                    <strong>Siège:</strong>
                                    <p class="mb-0">#{{ ticket.seatNumber }}</p>
                                </div>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="card-footer bg-light">
                        <a href="{{ path('app_ticket_show', {id: ticket.id}) }}" class="btn btn-primary w-100">
                            <i class="fas fa-eye"></i> Voir le QR Code
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# Message si aucun achat #}
        {% if tickets|length == 0 and purchasedSales|length == 0 %}
        <div class="text-center py-5">
            <i class="fas fa-shopping-cart fa-5x text-muted mb-4"></i>
            <h3 class="text-muted">Aucun achat pour le moment</h3>
            <p class="text-muted">Commencez à explorer les œuvres et événements pour faire vos premiers achats !</p>
            <div class="mt-4">
                <a href="{{ path('app_client') }}#nos-oeuvres" class="btn btn-primary btn-lg me-3">
                    <i class="fas fa-palette"></i> Voir les œuvres
                </a>
                <a href="{{ path('app_client_evenements') }}" class="btn btn-outline-primary btn-lg">
                    <i class="fas fa-calendar-alt"></i> Voir les événements
                </a>
            </div>
        </div>
        {% endif %}
    </div>
</div>

<style>
:root {
    --primary-color: #e94560;
    --dark-color: #1a1a2e;
}

.page-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--dark-color);
    margin-bottom: 10px;
}

.ticket-card {
    border-radius: 15px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    transition: all 0.3s ease;
    border: none;
    overflow: hidden;
}

.ticket-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(233, 69, 96, 0.2);
}

.ticket-card .card-header {
    border-radius: 0;
    padding: 20px;
}

.ticket-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.info-item {
    display: flex;
    align-items: flex-start;
    gap: 15px;
}

.info-item i {
    font-size: 1.5rem;
    margin-top: 5px;
}

.info-item strong {
    color: var(--dark-color);
    font-size: 0.9rem;
    display: block;
    margin-bottom: 5px;
}

.info-item p {
    color: #666;
    margin: 0;
}

.section-header {
    margin-top: 3rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e9ecef;
}

.section-header:first-child {
    margin-top: 0;
}

.section-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--dark-color);
    margin: 0;
}

.artwork-purchase-card {
    border-radius: 15px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    transition: all 0.3s ease;
    border: none;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
}

.artwork-purchase-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(233, 69, 96, 0.2);
}

.artwork-purchase-image {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: #f8f9fa;
}

.artwork-purchase-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.artwork-purchase-card:hover .artwork-purchase-image img {
    transform: scale(1.1);
}

.artwork-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ccc;
    background: #f8f9fa;
}

.artwork-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    padding: 8px 15px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
}

.artwork-badge.purchased {
    background: rgba(76, 175, 80, 0.9);
    color: white;
}

.artwork-purchase-info {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin-top: 1rem;
}

.artwork-purchase-card .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.artwork-purchase-card .card-title {
    font-weight: 700;
    color: var(--dark-color);
    margin-bottom: 0.75rem;
}
</style>
{% endblock %}

