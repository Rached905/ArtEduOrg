{% extends 'basec.html.twig' %}

{% block title %}{{ sale.title }} - Détails de l'Œuvre{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .artwork-details-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 2rem;
    }

    .artwork-details-header {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e9ecef;
    }

    .artwork-details-header h1 {
        color: var(--dark-color);
        font-weight: 700;
        margin-bottom: 0.5rem;
        font-size: 2.5rem;
    }

    .breadcrumb {
        background: none;
        padding: 0;
        margin: 0;
    }

    .breadcrumb-item a {
        color: var(--accent-color);
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .breadcrumb-item a:hover {
        color: #d63850;
    }

    .breadcrumb-item.active {
        color: #6c757d;
    }

    .artwork-details-card {
        background: white;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        animation: slideIn 0.5s ease-out;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .artwork-gallery {
        margin-bottom: 3rem;
    }

    .artwork-main-image {
        width: 100%;
        max-height: 600px;
        object-fit: contain;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        cursor: pointer;
        transition: transform 0.3s ease;
        background: #f8f9fa;
        padding: 20px;
    }

    .artwork-main-image:hover {
        transform: scale(1.02);
    }

    .artwork-thumbnails {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        justify-content: center;
        margin-top: 20px;
    }

    .artwork-thumbnail {
        width: 100px;
        height: 100px;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        cursor: pointer;
        transition: all 0.3s ease;
        border: 3px solid transparent;
    }

    .artwork-thumbnail:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(233, 69, 96, 0.3);
        border-color: var(--accent-color);
    }

    .artwork-thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .artwork-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .artwork-info-item {
        padding: 1.5rem;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
        transition: transform 0.3s ease;
        border-left: 4px solid var(--accent-color);
    }

    .artwork-info-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }

    .artwork-info-label {
        font-size: 0.875rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.75rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .artwork-info-value {
        font-size: 1.25rem;
        color: var(--dark-color);
        font-weight: 600;
    }

    .artwork-title-large {
        font-size: 2rem;
        font-weight: 700;
        color: var(--dark-color);
        margin-bottom: 1rem;
    }

    .artwork-description {
        font-size: 1.1rem;
        color: #555;
        line-height: 1.8;
        white-space: pre-wrap;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: #f8f9fa;
        border-radius: 12px;
        border-left: 4px solid var(--accent-color);
    }

    .type-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 25px;
        font-weight: 600;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .type-badge.vente {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white;
    }

    .type-badge.ticket {
        background: linear-gradient(135deg, #198754 0%, #146c43 100%);
        color: white;
    }

    .type-badge.echange {
        background: linear-gradient(135deg, #ffc107 0%, #ffb300 100%);
        color: #000;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 25px;
        font-weight: 600;
        font-size: 0.875rem;
    }

    .status-badge.en-attente {
        background: linear-gradient(135deg, #ffc107 0%, #ffb300 100%);
        color: #000;
    }

    .status-badge.paye {
        background: linear-gradient(135deg, #198754 0%, #146c43 100%);
        color: white;
    }

    .status-badge.annule {
        background: linear-gradient(135deg, #dc3545 0%, #bb2d3b 100%);
        color: white;
    }

    .status-badge.vendue {
        background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
        color: white;
    }

    .status-badge.disponible {
        background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
        color: white;
    }

    .artwork-price-display {
        font-size: 2.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--accent-color) 0%, #d63850 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .artist-info {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem;
        background: linear-gradient(135deg, rgba(233, 69, 96, 0.1) 0%, rgba(233, 69, 96, 0.05) 100%);
        border-radius: 15px;
        margin-bottom: 2rem;
    }

    .artist-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: var(--accent-color);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1.5rem;
        border: 3px solid white;
        box-shadow: 0 4px 15px rgba(233, 69, 96, 0.3);
    }

    .artist-details h4 {
        margin: 0;
        color: var(--dark-color);
        font-weight: 700;
    }

    .artist-details p {
        margin: 0;
        color: #6c757d;
        font-size: 0.9rem;
    }

    .action-buttons-client {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 2px solid #e9ecef;
        flex-wrap: wrap;
    }

    .btn-buy {
        flex: 1;
        min-width: 200px;
        padding: 18px 36px;
        background: linear-gradient(135deg, var(--accent-color) 0%, #d63850 100%);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 700;
        font-size: 1.1rem;
        text-decoration: none;
        text-align: center;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 8px 25px rgba(233, 69, 96, 0.3);
    }

    .btn-buy:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(233, 69, 96, 0.4);
        color: white;
    }

    .btn-buy:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    .btn-back-client {
        padding: 18px 36px;
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .btn-back-client:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        color: white;
    }

    .btn-favorite {
        padding: 18px 24px;
        background: white;
        color: var(--accent-color);
        border: 2px solid var(--accent-color);
        border-radius: 15px;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .btn-favorite:hover {
        background: var(--accent-color);
        color: white;
        transform: translateY(-3px);
    }

    .btn-invoice {
        padding: 18px 36px;
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 700;
        font-size: 1.1rem;
        text-decoration: none;
        text-align: center;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 8px 25px rgba(220, 53, 69, 0.3);
    }

    .btn-invoice:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(220, 53, 69, 0.4);
        color: white;
    }

    .section-title-modern {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dark-color);
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #e9ecef;
        display: flex;
        align-items: center;
    }

    .owner-info-section,
    .payment-info-section {
        margin-top: 2rem;
        margin-bottom: 2rem;
    }

    .owner-card {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 2rem;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
        border-left: 4px solid var(--accent-color);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .owner-avatar-large {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent-color) 0%, #d63850 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 2rem;
        border: 4px solid white;
        box-shadow: 0 6px 20px rgba(233, 69, 96, 0.3);
        flex-shrink: 0;
    }

    .owner-details {
        flex: 1;
    }

    .owner-details h4 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dark-color);
        margin-bottom: 0.5rem;
    }

    .owner-details p {
        margin: 0.5rem 0;
        color: #6c757d;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .payment-info-card {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
        padding: 2rem;
        border-left: 4px solid #28a745;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .payment-info-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 0;
        border-bottom: 1px solid #dee2e6;
    }

    .payment-info-item:last-child {
        border-bottom: none;
    }

    .payment-info-label {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #6c757d;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .payment-info-label i {
        color: var(--accent-color);
        font-size: 1.1rem;
    }

    .payment-info-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--dark-color);
        text-align: right;
    }

    .payment-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .payment-status-badge.paid {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
    }

    @media (max-width: 768px) {
        .artwork-details-container {
            padding: 1rem;
        }

        .artwork-details-card {
            padding: 20px;
        }

        .artwork-details-header h1 {
            font-size: 1.8rem;
        }

        .action-buttons-client {
            flex-direction: column;
        }

        .btn-buy,
        .btn-back-client,
        .btn-favorite {
            width: 100%;
        }
    }
</style>
<script>
function showImageModal(imageSrc, title) {
    const modal = document.createElement('div');
    modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 9999; display: flex; align-items: center; justify-content: center; cursor: pointer;';
    modal.innerHTML = `
        <div style="max-width: 90%; max-height: 90%; text-align: center;">
            <img src="${imageSrc}" alt="${title}" style="max-width: 100%; max-height: 90vh; border-radius: 12px; box-shadow: 0 10px 40px rgba(255,255,255,0.1);">
            <p style="color: white; margin-top: 20px; font-size: 1.2rem;">${title}</p>
        </div>
    `;
    modal.onclick = () => modal.remove();
    document.body.appendChild(modal);
}

function setMainImage(imageSrc) {
    const mainImage = document.querySelector('.artwork-main-image');
    if (mainImage) {
        mainImage.src = imageSrc;
    }
}
</script>
{% endblock %}

{% block body %}
<div class="artwork-details-container">
    <div class="artwork-details-header">
        <h1><i class="fas fa-palette me-2"></i>{{ sale.title ?? 'Œuvre d\'art' }}</h1>
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ path('app_client') }}"><i class="fas fa-home"></i> Accueil</a></li>
            {% if canEditAsAcheteur|default(false) %}
            <li class="breadcrumb-item"><a href="{{ path('app_client_mes_achats') }}">Mes Achats</a></li>
            {% else %}
            <li class="breadcrumb-item"><a href="{{ path('app_client') }}#nos-oeuvres">Nos Oeuvres</a></li>
            {% endif %}
            <li class="breadcrumb-item active">{{ sale.title }}</li>
        </ol>
    </div>

    <div class="artwork-details-card">
        {# Gallery Section #}
        <div class="artwork-gallery">
            {% set primaryImage = null %}
            {% set secondaryImages = [] %}
            {% for image in images %}
                {% if image.isPrimary %}
                    {% set primaryImage = image %}
                {% else %}
                    {% set secondaryImages = secondaryImages|merge([image]) %}
                {% endif %}
            {% endfor %}
            
            {% if primaryImage or sale.image %}
                <div class="text-center">
                    {% if primaryImage %}
                        <img src="{{ asset(primaryImage.path) }}" 
                             alt="{{ sale.title }}" 
                             class="artwork-main-image"
                             onclick="showImageModal('{{ asset(primaryImage.path) }}', '{{ sale.title }}')">
                    {% elseif sale.image %}
                        <img src="{{ asset(sale.image) }}" 
                             alt="{{ sale.title }}" 
                             class="artwork-main-image"
                             onclick="showImageModal('{{ asset(sale.image) }}', '{{ sale.title }}')">
                    {% endif %}
                    
                    {% if secondaryImages|length > 0 %}
                        <div class="artwork-thumbnails">
                            {% for image in secondaryImages %}
                                <div class="artwork-thumbnail" 
                                     onclick="setMainImage('{{ asset(image.path) }}'); showImageModal('{{ asset(image.path) }}', '{{ sale.title }}')">
                                    <img src="{{ asset(image.path) }}" alt="{{ sale.title }}">
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <div class="text-center py-5">
                    <i class="fas fa-image fa-5x text-muted mb-3"></i>
                    <p class="text-muted">Aucune image disponible</p>
                </div>
            {% endif %}
        </div>

        {# Title and Description #}
        <div class="artwork-title-large">{{ sale.title ?? 'Sans titre' }}</div>
        
        {% if sale.description %}
            <div class="artwork-description">{{ sale.description }}</div>
        {% endif %}

        {# Artist Info #}
        {% if sale.vendeur %}
            <div class="artist-info">
                <div class="artist-avatar">{{ sale.vendeur.fullname|first|upper }}</div>
                <div class="artist-details">
                    <h4><i class="fas fa-user me-2"></i>{{ sale.vendeur.fullname }}</h4>
                    <p><i class="fas fa-envelope me-2"></i>{{ sale.vendeur.email }}</p>
                </div>
            </div>
        {% endif %}

        {# Info Grid #}
        <div class="artwork-info-grid">
            <div class="artwork-info-item">
                <div class="artwork-info-label">
                    <i class="fas fa-hashtag"></i>ID
                </div>
                <div class="artwork-info-value">#{{ sale.id }}</div>
            </div>

            <div class="artwork-info-item">
                <div class="artwork-info-label">
                    <i class="fas fa-tag"></i>Type
                </div>
                <div class="artwork-info-value">
                    {% if sale.type.value == 'vente' %}
                        <span class="type-badge vente">
                            <i class="fas fa-shopping-bag"></i> Vente
                        </span>
                    {% elseif sale.type.value == 'ticket' %}
                        <span class="type-badge ticket">
                            <i class="fas fa-ticket-alt"></i> Ticket
                        </span>
                    {% elseif sale.type.value == 'echange' %}
                        <span class="type-badge echange">
                            <i class="fas fa-exchange-alt"></i> Échange
                        </span>
                    {% endif %}
                </div>
            </div>

            <div class="artwork-info-item">
                <div class="artwork-info-label">
                    <i class="fas fa-info-circle"></i>Statut
                </div>
                <div class="artwork-info-value">
                    {% if sale.status.value == 'en attente' %}
                        <span class="status-badge en-attente">
                            <i class="fas fa-clock"></i> En attente
                        </span>
                    {% elseif sale.status.value == 'paye' or sale.status.value == 'payer' %}
                        <span class="status-badge paye">
                            <i class="fas fa-check-circle"></i> Payé
                        </span>
                    {% elseif sale.status.value == 'annule' or sale.status.value == 'refuser' %}
                        <span class="status-badge annule">
                            <i class="fas fa-times-circle"></i> Annulé
                        </span>
                    {% elseif sale.status.value == 'vendue' %}
                        <span class="status-badge vendue">
                            <i class="fas fa-handshake"></i> Vendue
                        </span>
                    {% elseif sale.status.value == 'disponible' %}
                        <span class="status-badge disponible">
                            <i class="fas fa-check"></i> Disponible
                        </span>
                    {% else %}
                        <span class="status-badge en-attente">
                            {{ sale.status.value|capitalize }}
                        </span>
                    {% endif %}
                </div>
            </div>

            <div class="artwork-info-item">
                <div class="artwork-info-label">
                    <i class="fas fa-money-bill-wave"></i>Prix
                </div>
                <div class="artwork-info-value">
                    <span class="artwork-price-display">
                        {{ sale.amount ? sale.amount|number_format(0, ',', ' ') ~ ' €' : 'Prix sur demande' }}
                    </span>
                </div>
            </div>

            {% if sale.contactInfo %}
                <div class="artwork-info-item">
                    <div class="artwork-info-label">
                        <i class="fas fa-envelope"></i>Contact
                    </div>
                    <div class="artwork-info-value">{{ sale.contactInfo }}</div>
                </div>
            {% endif %}

            {% if sale.location %}
                <div class="artwork-info-item">
                    <div class="artwork-info-label">
                        <i class="fas fa-map-marker-alt"></i>Localisation
                    </div>
                    <div class="artwork-info-value">{{ sale.location }}</div>
                </div>
            {% endif %}

            <div class="artwork-info-item">
                <div class="artwork-info-label">
                    <i class="fas fa-calendar"></i>Date de publication
                </div>
                <div class="artwork-info-value">
                    {{ sale.createdAt ? sale.createdAt|date('d/m/Y') : 'N/A' }}
                </div>
            </div>
        </div>

        {# Informations pour l'acheteur #}
        {% if isBuyer %}
            {# Informations du Vendeur/Propriétaire #}
            {% if sale.vendeur %}
            <div class="owner-info-section">
                <h3 class="section-title-modern">
                    <i class="fas fa-user-tie me-2"></i>
                    Informations du Propriétaire
                </h3>
                <div class="owner-card">
                    <div class="owner-avatar-large">
                        {{ sale.vendeur.fullname|first|upper }}
                    </div>
                    <div class="owner-details">
                        <h4>{{ sale.vendeur.fullname }}</h4>
                        <p><i class="fas fa-envelope me-2"></i>{{ sale.vendeur.email }}</p>
                        {% if sale.vendeur.createdAt %}
                            <p class="text-muted">
                                <i class="fas fa-calendar-alt me-2"></i>
                                Membre depuis {{ sale.vendeur.createdAt|date('F Y') }}
                            </p>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}

            {# Informations de Paiement #}
            <div class="payment-info-section">
                <h3 class="section-title-modern">
                    <i class="fas fa-credit-card me-2"></i>
                    Informations de Paiement
                </h3>
                <div class="payment-info-card">
                    <div class="payment-info-item">
                        <div class="payment-info-label">
                            <i class="fas fa-money-bill-wave"></i>
                            Montant payé
                        </div>
                        <div class="payment-info-value">
                            {{ sale.amount|number_format(2, ',', ' ') }} €
                        </div>
                    </div>
                    <div class="payment-info-item">
                        <div class="payment-info-label">
                            <i class="fas fa-check-circle"></i>
                            Statut du paiement
                        </div>
                        <div class="payment-info-value">
                            <span class="payment-status-badge paid">
                                <i class="fas fa-check"></i> Payé
                            </span>
                        </div>
                    </div>
                    <div class="payment-info-item">
                        <div class="payment-info-label">
                            <i class="fas fa-calendar-check"></i>
                            Date d'achat
                        </div>
                        <div class="payment-info-value">
                            {{ sale.updatedAt ? sale.updatedAt|date('d/m/Y à H:i') : sale.createdAt|date('d/m/Y à H:i') }}
                        </div>
                    </div>
                    <div class="payment-info-item">
                        <div class="payment-info-label">
                            <i class="fas fa-shield-alt"></i>
                            Mode de paiement
                        </div>
                        <div class="payment-info-value">
                            <i class="fab fa-stripe me-2"></i>Carte bancaire (Stripe)
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        {# Action Buttons #}
        <div class="action-buttons-client">
            {% if sale.status.value == 'disponible' or sale.status.value == 'en attente' %}
                <a href="{{ path('app_payment_page', {'id': sale.id}) }}" class="btn-buy">
                    <i class="fas fa-shopping-cart"></i>
                    Acheter cette œuvre
                </a>
            {% else %}
                <button class="btn-buy" disabled>
                    <i class="fas fa-ban"></i>
                    Non disponible
                </button>
            {% endif %}
            
            {% if isBuyer and invoicePath %}
                <a href="{{ asset(invoicePath) }}" download class="btn-invoice" target="_blank">
                    <i class="fas fa-file-pdf"></i>
                    Télécharger la Facture
                </a>
            {% endif %}

            {% if canEditAsAcheteur|default(false) %}
                <a href="{{ path('app_sale_edit', {id: sale.id}) }}" class="btn-back-client" style="background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);">
                    <i class="fas fa-edit"></i>
                    Modifier cette œuvre
                </a>
            {% endif %}

            <a href="{{ path('app_client') }}#nos-oeuvres" class="btn-back-client">
                <i class="fas fa-arrow-left"></i>
                Retour aux œuvres
            </a>
            
            {% if app.user %}
                {% if isFavorite %}
                    <form method="post" action="{{ path('app_sale_favori_remove', {id: sale.id}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('favori_remove') }}">
                        <button type="submit" class="btn-favorite" style="border:none;background:transparent;cursor:pointer;">
                            <i class="fas fa-heart" style="color:#e94560;"></i>
                            Retirer des favoris
                        </button>
                    </form>
                {% else %}
                    <form method="post" action="{{ path('app_sale_favori_add', {id: sale.id}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('favori_add') }}">
                        <button type="submit" class="btn-favorite" style="border:none;background:transparent;cursor:pointer;">
                            <i class="fas fa-heart"></i>
                            Ajouter aux favoris
                        </button>
                    </form>
                {% endif %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

