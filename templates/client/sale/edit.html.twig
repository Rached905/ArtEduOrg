{% extends 'basec.html.twig' %}

{% block title %}Modifier mon œuvre - {{ sale.title }}{% endblock %}

{% block body %}
<div class="container-fluid py-5" style="margin-top: 80px;">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_client') }}">Tableau de bord</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_client_mes_achats') }}">Mes Achats</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_sale_details', {id: sale.id}) }}">{{ sale.title }}</a></li>
                <li class="breadcrumb-item active" aria-current="page">Modifier</li>
            </ol>
        </nav>

        <div class="page-header mb-4">
            <h1 class="page-title">
                <i class="fas fa-edit"></i>
                Modifier mon œuvre achetée
            </h1>
            <p class="text-muted">Vous pouvez modifier les informations d'affichage et choisir si l'œuvre est visible sur la plateforme.</p>
        </div>

        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-4">
                {{ form_start(form) }}
                <div class="row">
                    <div class="col-12 mb-3">
                        {{ form_row(form.title, { 'attr': { 'class': 'form-control' } }) }}
                    </div>
                    <div class="col-12 mb-3">
                        {{ form_row(form.description, { 'attr': { 'class': 'form-control', 'rows': 5 } }) }}
                    </div>
                    <div class="col-12 mb-4">
                        {{ form_row(form.isActive) }}
                        <small class="text-muted">Décocher pour masquer cette œuvre sur la plateforme (elle restera visible dans « Mes achats »).</small>
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i> {{ button_label|default('Enregistrer') }}
                    </button>
                    <a href="{{ path('app_sale_details', {id: sale.id}) }}" class="btn btn-outline-primary">
                        <i class="fas fa-eye me-1"></i> Voir la fiche de cette œuvre
                    </a>
                    <a href="{{ path('app_client_mes_achats') }}" class="btn btn-outline-secondary">Retour à Mes Achats</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

<style>
.page-title { font-size: 1.75rem; font-weight: 700; color: var(--dark-color, #1a1a2e); }
.breadcrumb-item a { color: var(--accent-color, #e94560); }
.breadcrumb-item a:hover { text-decoration: underline; }
</style>
{% endblock %}
