{% extends 'basec.html.twig' %}

{% block title %}Mes Œuvres Favoris - ArtEduOrg{% endblock %}

{% block body %}
<div class="container-fluid py-5" style="margin-top: 80px;">
    <div class="container">
        <div class="page-header mb-5">
            <h1 class="page-title">
                <i class="fas fa-heart"></i>
                Mes Œuvres Favoris
            </h1>
            <p class="text-muted">Retrouvez les œuvres que vous avez mises en favori.</p>
        </div>

        {% if favoris|length > 0 %}
        <div class="row g-4">
            {% for sale in favoris %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden">
                    <div class="position-relative" style="height: 220px; background: #f0f0f0;">
                        {% if sale.image %}
                            <img src="{{ asset(sale.image starts with 'uploads/' ? sale.image : 'uploads/sales/' ~ sale.image) }}" alt="{{ sale.title }}" class="w-100 h-100 object-fit-cover">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                <i class="fas fa-image fa-4x"></i>
                            </div>
                        {% endif %}
                        <span class="position-absolute top-0 end-0 m-2 badge bg-primary">{{ sale.type.value|default('') }}</span>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">{{ sale.title }}</h5>
                        {% if sale.description %}
                        <p class="card-text text-muted small flex-grow-1">{{ sale.description|slice(0, 80) }}{% if sale.description|length > 80 %}...{% endif %}</p>
                        {% endif %}
                        <div class="mt-auto pt-2 d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-primary">{% if sale.amount %}{{ sale.amount|number_format(0, ',', ' ') }} €{% else %}Sur demande{% endif %}</span>
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_sale_details', {id: sale.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                                <form method="post" action="{{ path('app_sale_favori_remove', {id: sale.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('favori_remove') }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Retirer des favoris"><i class="fas fa-heart-broken"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <div class="text-center py-5">
            <i class="fas fa-heart fa-5x text-muted mb-4" style="opacity: 0.3;"></i>
            <h3 class="text-muted">Aucune œuvre en favori</h3>
            <p class="text-muted">Ajoutez des œuvres à vos favoris en cliquant sur « Ajouter aux favoris » sur la page de chaque œuvre.</p>
            <a href="{{ path('app_client') }}#nos-oeuvres" class="btn btn-primary btn-lg mt-3">
                <i class="fas fa-palette"></i> Découvrir les œuvres
            </a>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
