{% extends 'basec.html.twig' %}

{% block title %}Paiement - {{ sale.title }} - ArtMarket{% endblock %}

{% block stylesheets %}
{{ parent() }}
<script src="https://js.stripe.com/v3/"></script>
<style>
    .payment-container {
        max-width: 700px;
        margin: 2rem auto;
        padding: 2rem;
    }

    .payment-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e9ecef;
    }

    .payment-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--dark-color);
        margin-bottom: 0.5rem;
    }

    .payment-header p {
        color: #6c757d;
        font-size: 1.1rem;
    }

    .payment-card {
        background: white;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        animation: slideIn 0.5s ease-out;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .sale-info {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
        padding: 25px;
        margin-bottom: 30px;
        border-left: 4px solid var(--accent-color);
    }

    .sale-info h3 {
        color: var(--dark-color);
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .sale-info-item {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #dee2e6;
        color: #495057;
    }

    .sale-info-item:last-child {
        border-bottom: none;
    }

    .sale-info-item strong {
        color: var(--dark-color);
        font-weight: 600;
    }

    .amount-display {
        text-align: center;
        margin: 30px 0;
        padding: 30px;
        background: linear-gradient(135deg, var(--accent-color) 0%, #d63850 100%);
        border-radius: 20px;
        color: white;
        box-shadow: 0 8px 25px rgba(233, 69, 96, 0.3);
    }

    .amount-label {
        font-size: 1rem;
        opacity: 0.95;
        margin-bottom: 10px;
        font-weight: 500;
    }

    .amount-value {
        font-size: 3.5rem;
        font-weight: 800;
    }

    .payment-form {
        margin-top: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        color: var(--dark-color);
        font-weight: 600;
        font-size: 0.95rem;
    }

    .form-label .required {
        color: var(--accent-color);
        margin-left: 0.25rem;
    }

    .form-control {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: white;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--accent-color);
        box-shadow: 0 0 0 4px rgba(233, 69, 96, 0.1);
    }

    #payment-element {
        margin-bottom: 25px;
        padding: 15px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
    }

    #payment-element:focus-within {
        border-color: var(--accent-color);
        box-shadow: 0 0 0 4px rgba(233, 69, 96, 0.1);
    }

    .submit-button {
        width: 100%;
        padding: 18px;
        background: linear-gradient(135deg, var(--accent-color) 0%, #d63850 100%);
        color: white;
        border: none;
        border-radius: 15px;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px rgba(233, 69, 96, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .submit-button:hover:not(:disabled) {
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(233, 69, 96, 0.4);
    }

    .submit-button:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    .error-message {
        background: #fee;
        color: #dc3545;
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
        border-left: 4px solid #dc3545;
        display: none;
        font-weight: 500;
    }

    .error-message.show {
        display: block;
    }

    .success-message {
        background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
        color: #155724;
        padding: 30px;
        border-radius: 15px;
        margin-bottom: 20px;
        border-left: 4px solid #28a745;
        text-align: center;
        display: none;
    }

    .success-message.show {
        display: block;
    }

    .success-message i {
        font-size: 4rem;
        margin-bottom: 20px;
        color: #28a745;
    }

    .success-message h3 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 15px;
        color: #155724;
    }

    .success-message p {
        color: #155724;
        margin-bottom: 10px;
        line-height: 1.6;
    }

    .loading {
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 1s ease-in-out infinite;
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #6c757d;
        text-decoration: none;
        font-weight: 500;
        margin-bottom: 1.5rem;
        transition: all 0.3s ease;
    }

    .back-link:hover {
        color: var(--accent-color);
        transform: translateX(-5px);
    }

    @media (max-width: 768px) {
        .payment-container {
            padding: 1rem;
        }

        .payment-card {
            padding: 25px;
        }

        .payment-header h1 {
            font-size: 2rem;
        }

        .amount-value {
            font-size: 2.5rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="payment-container">
    <a href="{{ path('app_sale_details', {'id': sale.id}) }}" class="back-link">
        <i class="fas fa-arrow-left"></i>
        Retour aux détails
    </a>

    <div class="payment-card">
        <div class="payment-header">
            <h1><i class="fas fa-credit-card me-2"></i>Paiement</h1>
            <p>{{ sale.title }}</p>
        </div>

        <div class="sale-info">
            <h3>
                <i class="fas fa-info-circle"></i>
                Résumé de la transaction
            </h3>
            <div class="sale-info-item">
                <span>Œuvre :</span>
                <strong>{{ sale.title }}</strong>
            </div>
            <div class="sale-info-item">
                <span>Type :</span>
                <strong>Achat direct</strong>
            </div>
            {% if sale.vendeur %}
            <div class="sale-info-item">
                <span>Artiste :</span>
                <strong>{{ sale.vendeur.fullname }}</strong>
            </div>
            {% endif %}
            {% if sale.location %}
            <div class="sale-info-item">
                <span>Localisation :</span>
                <strong>{{ sale.location }}</strong>
            </div>
            {% endif %}
        </div>

        <div class="amount-display">
            <div class="amount-label">Montant à payer</div>
            <div class="amount-value">{{ amount|number_format(2, ',', ' ') }} €</div>
        </div>

        {% if not stripe_public_key or stripe_public_key == '' %}
        <div class="alert alert-warning mb-4" role="alert">
            <strong><i class="fas fa-exclamation-triangle me-2"></i>Paiement non configuré</strong>
            <p class="mb-0 mt-2">Les clés Stripe ne sont pas configurées. L’administrateur doit ajouter dans le fichier <code>.env</code> :<br>
            <code>STRIPE_PUBLIC_KEY=pk_test_...</code> et <code>STRIPE_SECRET_KEY=sk_test_...</code><br>
            Clés de test : <a href="https://dashboard.stripe.com/test/apikeys" target="_blank" rel="noopener">dashboard.stripe.com/test/apikeys</a></p>
        </div>
        {% endif %}

        <div class="error-message" id="error-message"></div>
        <div class="success-message" id="success-message">
            <i class="fas fa-check-circle"></i>
            <h3>Paiement réussi !</h3>
            <p>Votre paiement a été traité avec succès.</p>
            <p style="margin-top: 15px; font-weight: 600;">
                <i class="fas fa-file-pdf"></i> Votre facture a été téléchargée automatiquement.
            </p>
            <p style="margin-top: 10px;">
                <i class="fas fa-envelope"></i> Un email de confirmation avec la facture a été envoyé à votre adresse email.
            </p>
            <p style="margin-top: 20px;">
                <a href="{{ path('app_client_mes_achats') }}" style="color: #155724; font-weight: 600; text-decoration: underline;">
                    Voir mes achats
                </a>
            </p>
        </div>

        <form id="payment-form" class="payment-form" {% if not stripe_public_key or stripe_public_key == '' %}style="display:none;"{% endif %}>
            <div class="form-group">
                <label for="client_name" class="form-label">
                    Nom complet <span class="required">*</span>
                </label>
                <input type="text" 
                       id="client_name" 
                       name="client_name" 
                       class="form-control" 
                       placeholder="Votre nom complet"
                       value="{{ app.user ? app.user.fullname : '' }}"
                       required>
            </div>
            
            <div class="form-group">
                <label for="client_email" class="form-label">
                    Email <span class="required">*</span>
                </label>
                <input type="email" 
                       id="client_email" 
                       name="client_email" 
                       class="form-control" 
                       placeholder="votre@email.com"
                       value="{{ app.user ? app.user.email : '' }}"
                       required>
            </div>
            
            <div id="payment-element">
                <!-- Stripe Elements va créer les champs ici -->
            </div>
            
            <button type="submit" id="submit-button" class="submit-button">
                <span id="button-text">
                    <i class="fas fa-lock"></i> Payer {{ amount|number_format(2, ',', ' ') }} €
                </span>
                <span id="button-loading" class="loading" style="display: none;"></span>
            </button>
        </form>
    </div>
</div>

<script>
    const stripePublicKey = {{ stripe_public_key|default('')|json_encode|raw }};
    let stripe = null;
    let elements;
    let paymentElement;

    if (typeof stripePublicKey === 'string' && stripePublicKey.length > 0 && stripePublicKey.startsWith('pk_')) {
        stripe = Stripe(stripePublicKey);
    }

    async function initializePayment() {
        if (!stripe) {
            return;
        }
        try {
            // Préparer les paramètres pour l'achat direct
            const params = new URLSearchParams();
            params.append('direct_purchase', '1');
            // Récupérer les valeurs du formulaire
            const clientName = document.getElementById('client_name')?.value || 'Client';
            const clientEmail = document.getElementById('client_email')?.value || '';
            params.append('client_name', clientName);
            params.append('client_email', clientEmail);

            // Créer le PaymentIntent
            const response = await fetch('{{ path('app_payment_create_intent', {'id': sale.id}) }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: params
            });

            const { clientSecret, error } = await response.json();

            if (error) {
                showError(error);
                return;
            }

            // Créer les éléments Stripe
            elements = stripe.elements({ clientSecret });

            // Créer l'élément de paiement
            paymentElement = elements.create('payment', {
                layout: 'tabs'
            });

            // Monter l'élément
            paymentElement.mount('#payment-element');

        } catch (error) {
            showError('Erreur lors de l\'initialisation du paiement : ' + error.message);
        }
    }

    const form = document.getElementById('payment-form');
    form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!stripe) return;

        const submitButton = document.getElementById('submit-button');
        const buttonText = document.getElementById('button-text');
        const buttonLoading = document.getElementById('button-loading');

        // Désactiver le bouton
        submitButton.disabled = true;
        buttonText.style.display = 'none';
        buttonLoading.style.display = 'inline-block';

        // Confirmer le paiement
        const { error, paymentIntent } = await stripe.confirmPayment({
            elements,
            confirmParams: {
                return_url: window.location.origin + '{{ path('app_sale_details', {'id': sale.id}) }}',
            },
            redirect: 'if_required'
        });

        if (error) {
            showError(error.message);
            submitButton.disabled = false;
            buttonText.style.display = 'inline';
            buttonLoading.style.display = 'none';
        } else if (paymentIntent && paymentIntent.status === 'succeeded') {
            // Paiement réussi
            showSuccess();
            
            // Confirmer côté serveur
            try {
                const confirmParams = new URLSearchParams({
                    'payment_intent_id': paymentIntent.id,
                });
                
                // Ajouter les informations client pour l'achat direct
                const clientName = document.getElementById('client_name')?.value || '';
                const clientEmail = document.getElementById('client_email')?.value || '';
                confirmParams.append('client_name', clientName);
                confirmParams.append('client_email', clientEmail);
                
                const confirmResponse = await fetch('{{ path('app_payment_confirm') }}', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: confirmParams
                });

                let confirmData;
                try {
                    confirmData = await confirmResponse.json();
                } catch (e) {
                    console.error('Réponse serveur invalide (attendu JSON, reçu HTML?):', e);
                    showError('Le serveur a renvoyé une erreur (page HTML au lieu de JSON). Vérifiez les logs serveur (var/log/) ou la console du navigateur (F12).');
                    submitButton.disabled = false;
                    buttonText.style.display = 'inline';
                    buttonLoading.style.display = 'none';
                    return;
                }

                if (!confirmResponse.ok) {
                    showError(confirmData.error || 'Erreur ' + confirmResponse.status + '. Réessayez ou contactez le support.');
                    submitButton.disabled = false;
                    buttonText.style.display = 'inline';
                    buttonLoading.style.display = 'none';
                    return;
                }

                // Si facture générée, télécharger automatiquement
                if (confirmData.invoice_path) {
                    // Télécharger la facture automatiquement
                    const invoiceUrl = '/' + confirmData.invoice_path;
                    const invoiceLink = document.createElement('a');
                    invoiceLink.href = invoiceUrl;
                    invoiceLink.download = 'facture-' + new Date().getTime() + '.pdf';
                    invoiceLink.style.display = 'none';
                    document.body.appendChild(invoiceLink);
                    invoiceLink.click();
                    setTimeout(() => {
                        document.body.removeChild(invoiceLink);
                    }, 100);
                }

                // Rediriger vers "Mes Achats" après 3 secondes
                setTimeout(() => {
                    window.location.href = '{{ path('app_client_mes_achats') }}';
                }, 3000);
            } catch (err) {
                console.error('Erreur confirmation serveur:', err);
            }
        }
    });

    function showError(message) {
        const errorElement = document.getElementById('error-message');
        errorElement.textContent = message;
        errorElement.classList.add('show');
    }

    function showSuccess() {
        document.getElementById('payment-form').style.display = 'none';
        document.getElementById('success-message').classList.add('show');
    }

    // Initialiser au chargement uniquement si Stripe est configuré
    if (stripe) {
        initializePayment();
    }
</script>
{% endblock %}

