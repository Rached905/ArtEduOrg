{% extends 'base.html.twig' %}

{% block title %}Gestion des Utilisateurs{% endblock %}

{% block stylesheets %}
<style>
    /* En-tête de page amélioré */
    .users-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e9ecef;
    }
    
    .users-header h1 {
        color: #2c3e50;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    /* Onglets de navigation */
    .user-tabs {
        margin-bottom: 2rem;
    }

    .user-tabs .nav-tabs {
        border-bottom: 2px solid #dee2e6;
    }

    .user-tabs .nav-tabs .nav-link {
        border: none;
        border-bottom: 3px solid transparent;
        color: #6c757d;
        font-weight: 500;
        padding: 0.75rem 1.5rem;
        transition: all 0.3s ease;
    }

    .user-tabs .nav-tabs .nav-link:hover {
        border-bottom-color: #0d6efd;
        color: #0d6efd;
        background-color: transparent;
    }

    .user-tabs .nav-tabs .nav-link.active {
        color: #0d6efd;
        border-bottom-color: #0d6efd;
        background-color: transparent;
    }

    /* Cartes statistiques */
    .stats-card {
        border-left: 4px solid;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .stats-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
    }

    .stats-card.clients {
        border-left-color: #0d6efd;
    }

    .stats-card.vendors {
        border-left-color: #198754;
    }

    .stats-card.admins {
        border-left-color: #dc3545;
    }

    .stats-card.total {
        border-left-color: #6c757d;
    }

    .stats-icon {
        font-size: 2.5rem;
        opacity: 0.7;
    }

    /* Badges de rôle améliorés */
    .role-badge {
        padding: 0.375rem 0.75rem;
        border-radius: 0.25rem;
        font-weight: 500;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .role-badge.admin {
        background-color: #dc3545;
        color: white;
    }

    .role-badge.client {
        background-color: #0d6efd;
        color: white;
    }

    .role-badge.vendor {
        background-color: #198754;
        color: white;
    }

    /* Boutons d'action */
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
    }

    .action-buttons form {
        margin: 0;
    }

    .action-buttons .btn {
        padding: 0.375rem 0.75rem;
        border-radius: 0.25rem;
        transition: all 0.2s;
    }

    .action-buttons .btn:hover {
        transform: scale(1.05);
    }

    /* Table améliorée */
    .table-modern {
        border-radius: 0.5rem;
        overflow: hidden;
        box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
    }

    .table-modern thead {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .table-modern thead th {
        border: none;
        padding: 1rem;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.875rem;
        letter-spacing: 0.5px;
    }

    .table-modern tbody tr {
        transition: all 0.2s;
    }

    .table-modern tbody tr:hover {
        background-color: #f8f9fa;
        transform: scale(1.01);
        box-shadow: 0 0.125rem 0.5rem rgba(0,0,0,0.1);
    }

    .table-modern tbody td {
        padding: 1rem;
        vertical-align: middle;
        border-bottom: 1px solid #e9ecef;
    }

    /* Filtres et recherche */
    .filter-section {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        padding: 1.5rem;
        border-radius: 0.5rem;
        margin-bottom: 2rem;
    }

    .search-box {
        position: relative;
    }

    .search-box .form-control {
        padding-left: 2.5rem;
        border-radius: 2rem;
        border: 2px solid #dee2e6;
        transition: all 0.3s;
    }

    .search-box .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }

    .search-box i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #6c757d;
    }

    /* Badge de statut */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .status-indicator {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
    }

    .status-indicator.active {
        background-color: #198754;
        box-shadow: 0 0 0 2px rgba(25, 135, 84, 0.2);
    }

    .status-indicator.inactive {
        background-color: #dc3545;
        box-shadow: 0 0 0 2px rgba(220, 53, 69, 0.2);
    }

    /* Animation de chargement */
    @keyframes shimmer {
        0% { background-position: -1000px 0; }
        100% { background-position: 1000px 0; }
    }

    .loading {
        animation: shimmer 2s infinite;
        background: linear-gradient(to right, #f6f7f8 0%, #edeef1 20%, #f6f7f8 40%, #f6f7f8 100%);
        background-size: 1000px 100%;
    }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <!-- En-tête -->
    <div class="users-header mt-4">
        <div>
            <h1><i class="fas fa-users-cog me-2"></i>Gestion des Utilisateurs</h1>
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}"><i class="fas fa-home"></i> Dashboard</a></li>
                <li class="breadcrumb-item active">Utilisateurs</li>
            </ol>
        </div>
         <div>
            <a href="{{ path('app_users_new') }}" class="btn btn-success">
                <i class="fas fa-plus me-1"></i>Add New User
            </a>
        </div>
    </div>

    <!-- Statistiques -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card stats-card clients h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small text-uppercase mb-1">Clients</div>
                            <div class="h3 mb-0 font-weight-bold">{{ users|filter(u => u.role.value == 'CLIENT')|length }}</div>
                        </div>
                        <div class="stats-icon text-primary">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stats-card vendors h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small text-uppercase mb-1">Vendeurs</div>
                            <div class="h3 mb-0 font-weight-bold">{{ users|filter(u => u.role.value == 'VENDEUR')|length }}</div>
                        </div>
                        <div class="stats-icon text-success">
                            <i class="fas fa-store"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stats-card admins h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small text-uppercase mb-1">Administrateurs</div>
                            <div class="h3 mb-0 font-weight-bold">{{ users|filter(u => u.role.value == 'ADMIN')|length }}</div>
                        </div>
                        <div class="stats-icon text-danger">
                            <i class="fas fa-user-shield"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stats-card total h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small text-uppercase mb-1">Total Utilisateurs</div>
                            <div class="h3 mb-0 font-weight-bold">{{ users|length }}</div>
                        </div>
                        <div class="stats-icon text-secondary">
                            <i class="fas fa-chart-line"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Onglets de navigation -->
    <div class="user-tabs">
        <ul class="nav nav-tabs" id="userTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button">
                    <i class="fas fa-users me-2"></i>Tous les utilisateurs
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="clients-tab" data-bs-toggle="tab" data-bs-target="#clients" type="button">
                    <i class="fas fa-user me-2"></i>Clients
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="vendors-tab" data-bs-toggle="tab" data-bs-target="#vendors" type="button">
                    <i class="fas fa-store me-2"></i>Vendeurs
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="admins-tab" data-bs-toggle="tab" data-bs-target="#admins" type="button">
                    <i class="fas fa-user-shield me-2"></i>Administrateurs
                </button>
            </li>
        </ul>
    </div>

    <!-- Filtres et recherche -->
    <div class="filter-section">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="form-control" id="searchInput" placeholder="Rechercher par nom, email...">
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" id="statusFilter">
                    <option value="">Tous les statuts</option>
                    <option value="active">Actifs</option>
                    <option value="inactive">Inactifs</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
                    <i class="fas fa-redo me-2"></i>Réinitialiser
                </button>
            </div>
        </div>
    </div>

    <!-- Contenu des onglets -->
    <div class="tab-content" id="userTabsContent">
        <!-- Tous les utilisateurs -->
        <div class="tab-pane fade show active" id="all" role="tabpanel">
            {{ _self.renderUserTable(users, 'all') }}
        </div>
        
        <!-- Clients uniquement -->
        <div class="tab-pane fade" id="clients" role="tabpanel">
            {{ _self.renderUserTable(users|filter(u => u.role.value == 'CLIENT'), 'clients') }}
        </div>
        
        <!-- Vendeurs uniquement -->
        <div class="tab-pane fade" id="vendors" role="tabpanel">
            {{ _self.renderUserTable(users|filter(u => u.role.value == 'VENDEUR'), 'vendors') }}
        </div>
        
        <!-- Administrateurs uniquement -->
        <div class="tab-pane fade" id="admins" role="tabpanel">
            {{ _self.renderUserTable(users|filter(u => u.role.value == 'ADMIN'), 'admins') }}
        </div>
    </div>
</div>

<!-- Macro pour le rendu de la table -->
{% macro renderUserTable(userList, tableId) %}
<div class="card table-modern">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="table-{{ tableId }}">
                <thead>
                    <tr>
                        <th><i class="fas fa-hashtag me-2"></i>ID</th>
                        <th><i class="fas fa-envelope me-2"></i>Email</th>
                        <th><i class="fas fa-user me-2"></i>Nom complet</th>
                        <th><i class="fas fa-shield-alt me-2"></i>Rôle</th>
                        <th><i class="fas fa-toggle-on me-2"></i>Statut</th>
                        <th><i class="fas fa-calendar me-2"></i>Créé le</th>
                        <th class="text-center"><i class="fas fa-cog me-2"></i>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in userList %}
                        <tr>
                            <td><strong>#{{ user.id }}</strong></td>
                            <td>
                                <i class="fas fa-envelope text-muted me-2"></i>{{ user.email }}
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle me-2">
                                        <i class="fas fa-user"></i>
                                    </div>
                                    <strong>{{ user.fullname }}</strong>
                                </div>
                            </td>
                            <td>
                                {% if user.role.value == 'ADMIN' %}
                                    <span class="role-badge admin">
                                        <i class="fas fa-user-shield me-1"></i>Admin
                                    </span>
                                {% elseif user.role.value == 'CLIENT' %}
                                    <span class="role-badge client">
                                        <i class="fas fa-user me-1"></i>Client
                                    </span>
                                {% elseif user.role.value == 'VENDEUR' %}
                                    <span class="role-badge vendor">
                                        <i class="fas fa-store me-1"></i>Vendeur
                                    </span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="status-badge">
                                    <span class="status-indicator {{ user.isActive ? 'active' : 'inactive' }}"></span>
                                    <span class="small">{{ user.isActive ? 'Actif' : 'Inactif' }}</span>
                                </div>
                            </td>
                            <td>
                                <small class="text-muted">
                                    <i class="far fa-calendar-alt me-1"></i>
                                    {{ user.createdAt ? user.createdAt|date('d/m/Y') : 'N/A' }}
                                </small>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href="{{ path('app_users_show', {'id': user.id}) }}" 
                                       class="btn btn-sm btn-info" 
                                       title="Voir les détails">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_users_edit', {'id': user.id}) }}" 
                                       class="btn btn-sm btn-warning" 
                                       title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" 
                                          action="{{ path('app_users_delete', {'id': user.id}) }}" 
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer {{ user.fullname }} ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                        <button class="btn btn-sm btn-danger" 
                                                type="submit" 
                                                title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="fas fa-inbox fa-3x text-muted mb-3 d-block"></i>
                                <p class="text-muted mb-0">Aucun utilisateur trouvé dans cette catégorie.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endmacro %}
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialiser DataTables pour chaque table
    const tables = ['all', 'clients', 'vendors', 'admins'];
    const dataTablesInstances = {};
    
    tables.forEach(tableId => {
        const table = document.getElementById('table-' + tableId);
        if (table && table.querySelector('tbody tr:not(:empty)')) {
            try {
                dataTablesInstances[tableId] = new simpleDatatables.DataTable('#table-' + tableId, {
                    searchable: true,
                    fixedHeight: false,
                    perPage: 10,
                    labels: {
                        placeholder: "Rechercher...",
                        perPage: "lignes par page",
                        noRows: "Aucun utilisateur trouvé",
                        info: "Affichage de {start} à {end} sur {rows} utilisateurs"
                    },
                    columns: [
                        { select: 6, sortable: false } // Colonne Actions non triable
                    ]
                });
            } catch (error) {
                console.error('Erreur DataTable pour ' + tableId + ':', error);
            }
        }
    });

    // Recherche personnalisée
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
        searchInput.addEventListener('input', function(e) {
            const activeTab = document.querySelector('.tab-pane.active');
            const tableId = activeTab.id;
            if (dataTablesInstances[tableId]) {
                dataTablesInstances[tableId].search(e.target.value);
            }
        });
    }

    // Filtre par statut
    const statusFilter = document.getElementById('statusFilter');
    if (statusFilter) {
        statusFilter.addEventListener('change', function(e) {
            const activeTab = document.querySelector('.tab-pane.active');
            const table = activeTab.querySelector('table tbody');
            const rows = table.querySelectorAll('tr');
            
            rows.forEach(row => {
                if (e.target.value === '') {
                    row.style.display = '';
                } else {
                    const statusCell = row.querySelector('.status-badge');
                    if (statusCell) {
                        const isActive = statusCell.querySelector('.status-indicator').classList.contains('active');
                        if ((e.target.value === 'active' && isActive) || 
                            (e.target.value === 'inactive' && !isActive)) {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    }
                }
            });
        });
    }

    // Animation de chargement pour les boutons d'action
    document.querySelectorAll('.action-buttons form').forEach(form => {
        form.addEventListener('submit', function(e) {
            const button = this.querySelector('button');
            if (button) {
                button.disabled = true;
                button.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            }
        });
    });

    // Tooltip Bootstrap
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'));
    tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });

    // Animation d'entrée pour les cartes de statistiques
    const statsCards = document.querySelectorAll('.stats-card');
    statsCards.forEach((card, index) => {
        setTimeout(() => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            card.style.transition = 'all 0.5s ease';
            
            setTimeout(() => {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, 50);
        }, index * 100);
    });

    // Confirmation améliorée pour la suppression
    document.querySelectorAll('form[onsubmit*="confirm"]').forEach(form => {
        form.onsubmit = function(e) {
            e.preventDefault();
            const userName = this.getAttribute('action').match(/delete\/(\d+)/);
            
            Swal.fire({
                title: 'Êtes-vous sûr ?',
                text: "Cette action est irréversible !",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Oui, supprimer',
                cancelButtonText: 'Annuler'
            }).then((result) => {
                if (result.isConfirmed) {
                    this.submit();
                }
            });
            
            return false;
        };
    });
});

// Fonction pour réinitialiser les filtres
function resetFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('statusFilter').value = '';
    
    // Déclencher les événements
    document.getElementById('searchInput').dispatchEvent(new Event('input'));
    document.getElementById('statusFilter').dispatchEvent(new Event('change'));
    
    // Toast de confirmation
    showToast('Filtres réinitialisés', 'success');
}

// Fonction pour afficher des notifications
function showToast(message, type = 'info') {
    const toast = document.createElement('div');
    toast.className = `alert alert-${type} position-fixed top-0 end-0 m-3`;
    toast.style.zIndex = '9999';
    toast.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'} me-2"></i>
        ${message}
    `;
    document.body.appendChild(toast);
    
    setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transition = 'opacity 0.5s';
        setTimeout(() => toast.remove(), 500);
    }, 3000);
}

// Export des données (optionnel)
function exportToCSV(tableId) {
    const table = document.getElementById('table-' + tableId);
    let csv = [];
    const rows = table.querySelectorAll('tr');
    
    rows.forEach(row => {
        const cols = row.querySelectorAll('td, th');
        const csvRow = [];
        cols.forEach((col, index) => {
            // Exclure la colonne Actions
            if (index < cols.length - 1) {
                csvRow.push('"' + col.innerText.replace(/"/g, '""') + '"');
            }
        });
        csv.push(csvRow.join(','));
    });
    
    const csvFile = new Blob([csv.join('\n')], { type: 'text/csv' });
    const downloadLink = document.createElement('a');
    downloadLink.download = 'utilisateurs_' + tableId + '_' + new Date().toISOString() + '.csv';
    downloadLink.href = window.URL.createObjectURL(csvFile);
    downloadLink.style.display = 'none';
    document.body.appendChild(downloadLink);
    downloadLink.click();
    document.body.removeChild(downloadLink);
    
    showToast('Export CSV réussi !', 'success');
}
</script>

<!-- SweetAlert2 pour de meilleures confirmations -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
{% endblock %}