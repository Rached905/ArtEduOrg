{% extends 'base.html.twig' %}

{% block title %}Créer un Utilisateur{% endblock %}

{% block body %}
<div class="container-fluid">
    {# Page Header #}
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1>
                    <i class="fas fa-user-plus text-primary me-2"></i>
                    Créer un Nouvel Utilisateur
                </h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('app_users_index') }}">Utilisateurs</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Créer</li>
                    </ol>
                </nav>
            </div>
            <div>
                <a href="{{ path('app_users_index') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>
                    Retour à la liste
                </a>
            </div>
        </div>
    </div>

    {# Main Content #}
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-12">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-user-circle me-2"></i>
                    Informations de l'Utilisateur
                </div>
                <div class="card-body">
                    {# Instructions #}
                    <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
                        <i class="fas fa-info-circle me-3 fs-5"></i>
                        <div>
                            <strong>Information :</strong> Tous les champs sont obligatoires. L'utilisateur recevra un email de confirmation à l'adresse indiquée.
                        </div>
                    </div>

                    {# Form #}
                    {{ include('users/_form.html.twig', {
                        'button_label': 'Créer l\'Utilisateur'
                    }) }}
                </div>
            </div>

            {# Help Card #}
            <div class="card mt-4">
                <div class="card-header bg-light">
                    <i class="fas fa-question-circle me-2"></i>
                    Aide et Conseils
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-primary"><i class="fas fa-shield-alt me-2"></i>Rôles Disponibles</h6>
                            <ul class="small mb-3">
                                <li><strong>Administrateur :</strong> Accès complet au système</li>
                                <li><strong>Gestionnaire :</strong> Gestion des utilisateurs et contenus</li>
                                <li><strong>Utilisateur :</strong> Accès standard aux fonctionnalités</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-primary"><i class="fas fa-key me-2"></i>Sécurité du Mot de Passe</h6>
                            <ul class="small mb-3">
                                <li>Minimum 8 caractères requis</li>
                                <li>Combinez lettres, chiffres et symboles</li>
                                <li>Évitez les mots de passe évidents</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Form validation feedback
        document.querySelector('.user-form')?.addEventListener('submit', function(e) {
            if (!this.checkValidity()) {
                e.preventDefault();
                e.stopPropagation();
            }
            this.classList.add('was-validated');
        });

        // Real-time password strength indicator
        const passwordInput = document.querySelector('input[name*="[password]"]');
        if (passwordInput) {
            passwordInput.addEventListener('input', function() {
                const strength = checkPasswordStrength(this.value);
                updatePasswordStrength(strength);
            });
        }

        function checkPasswordStrength(password) {
            let strength = 0;
            if (password.length >= 8) strength++;
            if (password.match(/[a-z]+/)) strength++;
            if (password.match(/[A-Z]+/)) strength++;
            if (password.match(/[0-9]+/)) strength++;
            if (password.match(/[$@#&!]+/)) strength++;
            return strength;
        }

        function updatePasswordStrength(strength) {
            // You can add a visual indicator here if desired
            console.log('Password strength:', strength);
        }
    </script>
{% endblock %}