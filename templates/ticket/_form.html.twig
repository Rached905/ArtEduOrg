{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
    <div class="row">
        <div class="col-md-12 mb-3">
            {{ form_row(form.event, {
                'attr': {'class': 'form-select'},
                'label': 'Événement',
                'label_attr': {'class': 'form-label fw-bold'}
            }) }}
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            {{ form_row(form.buyerName, {
                'attr': {'class': 'form-control', 'placeholder': 'Nom complet de l\'acheteur'},
                'label': 'Nom de l\'acheteur',
                'label_attr': {'class': 'form-label fw-bold'}
            }) }}
        </div>
        
        <div class="col-md-6 mb-3">
            {{ form_row(form.buyerEmail, {
                'attr': {'class': 'form-control', 'placeholder': 'email@example.com'},
                'label': 'Email de l\'acheteur',
                'label_attr': {'class': 'form-label fw-bold'}
            }) }}
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            {{ form_row(form.price, {
                'attr': {'class': 'form-control', 'step': '0.01', 'min': '0'},
                'label': 'Prix (€)',
                'label_attr': {'class': 'form-label fw-bold'}
            }) }}
        </div>
        
        <div class="col-md-4 mb-3">
            {{ form_row(form.quantity, {
                'attr': {'class': 'form-control', 'min': '1'},
                'label': 'Quantité',
                'label_attr': {'class': 'form-label fw-bold'}
            }) }}
        </div>
        
        <div class="col-md-4 mb-3">
            {{ form_row(form.seatNumber, {
                'attr': {'class': 'form-control', 'placeholder': 'Numéro de siège'},
                'label': 'Numéro de siège',
                'label_attr': {'class': 'form-label fw-bold'}
            }) }}
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 mb-3">
            {{ form_row(form.issuedAt, {
                'attr': {'class': 'form-control'},
                'label': 'Date d\'émission',
                'label_attr': {'class': 'form-label fw-bold'}
            }) }}
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a href="{{ path('app_ticket_index') }}" class="btn btn-secondary">
            <i class="fas fa-times"></i> Annuler
        </a>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> {{ button_label|default('Enregistrer') }}
        </button>
    </div>
{{ form_end(form) }}


