{% extends 'base.html.twig' %}

{% block title %}Nouveau Sponsor{% endblock %}

{% block body %}
<div class="page-header">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="page-title">
                <i class="fas fa-user-plus"></i>
                Créer un nouveau Sponsor
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_sponsor_index') }}">Sponsors</a></li>
                    <li class="breadcrumb-item active">Nouveau</li>
                </ol>
            </nav>
        </div>
        <a href="{{ path('app_sponsor_index') }}" class="btn btn-reset">
            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        {{ include('sponsor/_form.html.twig') }}
    </div>
</div>
{% endblock %}


