{% extends 'base.html.twig' %}

{% block title %}Paramètres de l'application{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4 mt-4">
        <h1 class="mb-0">
            <i class="fas fa-cog me-2"></i>
            Paramètres de l'application
        </h1>
        <a href="{{ path('app_dashboard') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Retour au tableau de bord
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    {% endfor %}

    <div class="card card-modern shadow-sm">
        <div class="card-header">
            <i class="fas fa-sliders-h me-2"></i> Configuration générale
        </div>
        <div class="card-body">
            {{ form_start(form) }}
            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_row(form.siteName) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.contactEmail) }}
                </div>
                <div class="col-12 mb-3">
                    {{ form_row(form.metaDescription) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.itemsPerPage) }}
                </div>
                <div class="col-12 mb-3">
                    {{ form_row(form.maintenanceMode) }}
                </div>
                <div class="col-12 mb-4">
                    {{ form_row(form.footerText) }}
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i> Enregistrer les paramètres
                </button>
                <a href="{{ path('app_dashboard') }}" class="btn btn-secondary">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>

    <div class="alert alert-info mt-4" role="alert">
        <i class="fas fa-info-circle me-2"></i>
        <strong>Mode maintenance :</strong> lorsqu’il est activé, vous pouvez afficher un message aux visiteurs (à gérer dans votre layout si besoin).
        Le nom du site et l’email de contact peuvent être utilisés dans les emails et le pied de page.
    </div>
</div>

<style>
.card-modern { border: none; border-radius: 12px; }
.card-modern .card-header {
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    border-bottom: 2px solid #e9ecef;
    padding: 1.25rem 1.5rem;
    font-weight: 600;
}
</style>
{% endblock %}
