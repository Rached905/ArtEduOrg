{% extends 'base1.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .forgot-password-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px;
        }
        
        .card {
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            border: none;
            max-width: 500px;
            width: 100%;
        }
        
        .card-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 15px 15px 0 0 !important;
            padding: 25px;
            border: none;
        }
        
        .card-header h3 {
            margin: 0;
            font-weight: 600;
        }
        
        .card-body {
            padding: 30px;
        }
        
        .form-label {
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
        }
        
        .form-control {
            border-radius: 10px;
            border: 2px solid #e0e0e0;
            padding: 12px 15px;
            transition: all 0.3s;
        }
        
        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }
        
        .btn {
            border-radius: 10px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
        }
        
        .btn-secondary {
            background-color: #6c757d;
            border: none;
        }
        
        .btn-success {
            background: linear-gradient(135deg, #56ab2f 0%, #a8e063 100%);
            border: none;
        }
        
        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(86, 171, 47, 0.4);
        }
        
        .alert {
            border-radius: 10px;
            border: none;
        }
        
        .step-indicator {
            margin-bottom: 20px;
            text-align: center;
        }
        
        .step-indicator span {
            display: inline-block;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: #e0e0e0;
            color: #999;
            line-height: 40px;
            margin: 0 10px;
            font-weight: 600;
        }
        
        .step-indicator span.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        
        .step-indicator span.completed {
            background-color: #28a745;
            color: white;
        }
        
        .back-link {
            text-align: center;
            margin-top: 20px;
        }
        
        .back-link a {
            color: #667eea;
            text-decoration: none;
            font-weight: 500;
        }
        
        .back-link a:hover {
            text-decoration: underline;
        }
        
        .loading {
            display: none;
            text-align: center;
            margin-top: 15px;
        }
        
        .spinner-border {
            width: 2rem;
            height: 2rem;
        }
    </style>
{% endblock %}

{% block body %}
<div class="forgot-password-container">
    <div class="card">
        <div class="card-header">
            <h3>🔐 Réinitialisation du mot de passe</h3>
        </div>
        <div class="card-body">
            <!-- Indicateur d'étapes -->
            <div class="step-indicator">
                <span id="indicator1" class="active">1</span>
                <span id="indicator2">2</span>
                <span id="indicator3">3</span>
            </div>

            <!-- Étape 1: Demander l'email -->
            <div id="step1">
                <h5 class="mb-3">📧 Entrez votre email</h5>
                <p class="text-muted">Nous vous enverrons un code de vérification</p>
                <form id="emailForm">
                    <div class="mb-3">
                        <label for="email" class="form-label">Adresse email</label>
                        <input 
                            type="email" 
                            class="form-control" 
                            id="email" 
                            name="email" 
                            placeholder="exemple@email.com"
                            required
                        >
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        Envoyer le code
                    </button>
                </form>
                <div class="loading" id="loading1">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Chargement...</span>
                    </div>
                </div>
            </div>

            <!-- Étape 2: Vérifier le code -->
            <div id="step2" style="display: none;">
                <h5 class="mb-3">🔢 Vérifier le code</h5>
                <p class="text-muted">Un code à 6 chiffres a été envoyé à <strong id="displayEmail"></strong></p>
                <form id="codeForm">
                    <div class="mb-3">
                        <label for="code" class="form-label">Code de vérification</label>
                        <input 
                            type="text" 
                            class="form-control text-center" 
                            id="code" 
                            name="code" 
                            placeholder="000000"
                            required 
                            maxlength="6"
                            pattern="[0-9]{6}"
                            style="font-size: 24px; letter-spacing: 10px;"
                        >
                        <small class="form-text text-muted">Le code expire dans 15 minutes</small>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 mb-2">
                        Vérifier le code
                    </button>
                    <button type="button" class="btn btn-secondary w-100" id="backToStep1">
                        ← Retour
                    </button>
                </form>
                <div class="loading" id="loading2">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Chargement...</span>
                    </div>
                </div>
            </div>

            <!-- Étape 3: Nouveau mot de passe -->
            <div id="step3" style="display: none;">
                <h5 class="mb-3">🔑 Nouveau mot de passe</h5>
                <p class="text-muted">Choisissez un mot de passe sécurisé</p>
                <form id="resetForm">
                    <div class="mb-3">
                        <label for="password" class="form-label">Nouveau mot de passe</label>
                        <input 
                            type="password" 
                            class="form-control" 
                            id="password" 
                            name="password" 
                            placeholder="Minimum 6 caractères"
                            required 
                            minlength="6"
                        >
                    </div>
                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Confirmer le mot de passe</label>
                        <input 
                            type="password" 
                            class="form-control" 
                            id="confirmPassword" 
                            placeholder="Retapez votre mot de passe"
                            required 
                            minlength="6"
                        >
                    </div>
                    <button type="submit" class="btn btn-success w-100">
                        ✓ Réinitialiser le mot de passe
                    </button>
                </form>
                <div class="loading" id="loading3">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">Chargement...</span>
                    </div>
                </div>
            </div>

            <!-- Messages -->
            <div id="message" class="mt-3"></div>

            <!-- Lien de retour à la connexion -->
            <div class="back-link">
                <a href="{{ path('app_login') }}">← Retour à la connexion</a>
            </div>
        </div>
    </div>
</div>

<script>
    let userEmail = '';
    let verificationCode = '';

    // Étape 1: Envoyer l'email
    document.getElementById('emailForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        userEmail = document.getElementById('email').value;
        
        showLoading('loading1', true);
        
        try {
            const response = await fetch('{{ path('forgot_password') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({ email: userEmail })
            });
            
            const data = await response.json();
            showLoading('loading1', false);
            
            if (response.ok) {
                showMessage('✓ Code envoyé avec succès à votre email!', 'success');
                updateStepIndicator(2);
                document.getElementById('displayEmail').textContent = userEmail;
                document.getElementById('step1').style.display = 'none';
                document.getElementById('step2').style.display = 'block';
            } else {
                showMessage('✗ ' + (data.message || 'Erreur lors de l\'envoi'), 'danger');
            }
        } catch (error) {
            showLoading('loading1', false);
            showMessage('✗ Erreur de connexion au serveur', 'danger');
        }
    });

    // Étape 2: Vérifier le code
    document.getElementById('codeForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        verificationCode = document.getElementById('code').value;
        
        if (verificationCode.length !== 6) {
            showMessage('✗ Le code doit contenir 6 chiffres', 'warning');
            return;
        }
        
        showLoading('loading2', true);
        
        try {
            const response = await fetch('{{ path('verify_code') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({ 
                    email: userEmail,
                    code: verificationCode 
                })
            });
            
            const data = await response.json();
            showLoading('loading2', false);
            
            if (response.ok) {
                showMessage('✓ Code vérifié avec succès!', 'success');
                updateStepIndicator(3);
                document.getElementById('step2').style.display = 'none';
                document.getElementById('step3').style.display = 'block';
            } else {
                showMessage('✗ ' + (data.message || 'Code invalide ou expiré'), 'danger');
            }
        } catch (error) {
            showLoading('loading2', false);
            showMessage('✗ Erreur de connexion au serveur', 'danger');
        }
    });

    // Étape 3: Réinitialiser le mot de passe
    document.getElementById('resetForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirmPassword').value;
        
        if (password.length < 6) {
            showMessage('✗ Le mot de passe doit contenir au moins 6 caractères', 'warning');
            return;
        }
        
        if (password !== confirmPassword) {
            showMessage('✗ Les mots de passe ne correspondent pas', 'danger');
            return;
        }
        
        showLoading('loading3', true);
        
        try {
            const response = await fetch('{{ path('reset_password') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({ 
                    email: userEmail,
                    password: password,
                    code: verificationCode 
                })
            });
            
            const data = await response.json();
            showLoading('loading3', false);
            
            if (response.ok) {
                showMessage('✓ Mot de passe réinitialisé avec succès! Redirection vers la connexion...', 'success');
                setTimeout(() => {
                    window.location.href = '{{ path('app_login') }}';
                }, 2000);
            } else {
                showMessage('✗ ' + (data.message || 'Erreur lors de la réinitialisation'), 'danger');
            }
        } catch (error) {
            showLoading('loading3', false);
            showMessage('✗ Erreur de connexion au serveur', 'danger');
        }
    });

    // Retour à l'étape 1
    document.getElementById('backToStep1').addEventListener('click', () => {
        document.getElementById('step2').style.display = 'none';
        document.getElementById('step1').style.display = 'block';
        document.getElementById('code').value = '';
        updateStepIndicator(1);
        clearMessage();
    });

    // Fonction pour afficher les messages
    function showMessage(text, type) {
        const messageDiv = document.getElementById('message');
        messageDiv.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show" role="alert">
            ${text}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>`;
        
        // Auto-hide après 5 secondes (sauf succès)
        if (type !== 'success') {
            setTimeout(() => {
                clearMessage();
            }, 5000);
        }
    }

    // Fonction pour effacer les messages
    function clearMessage() {
        document.getElementById('message').innerHTML = '';
    }

    // Fonction pour afficher/masquer le loading
    function showLoading(loadingId, show) {
        const loadingElement = document.getElementById(loadingId);
        if (loadingElement) {
            loadingElement.style.display = show ? 'block' : 'none';
        }
    }

    // Fonction pour mettre à jour l'indicateur d'étapes
    function updateStepIndicator(step) {
        // Réinitialiser tous les indicateurs
        document.getElementById('indicator1').className = '';
        document.getElementById('indicator2').className = '';
        document.getElementById('indicator3').className = '';
        
        // Marquer les étapes complétées et actives
        for (let i = 1; i < step; i++) {
            document.getElementById('indicator' + i).className = 'completed';
        }
        document.getElementById('indicator' + step).className = 'active';
    }

    // Auto-focus sur le champ de code
    document.getElementById('code').addEventListener('input', function(e) {
        this.value = this.value.replace(/[^0-9]/g, '');
    });
</script>
{% endblock %}