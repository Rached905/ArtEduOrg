{% extends 'base.html.twig' %}

{% block title %}Créer un Avis{% endblock %}

{% block body %}
<div class="page-header">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="page-title">
                <i class="fas fa-star"></i>
                Créer un Avis
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Dashboard</a></li>
                    {% if eventId %}
                        <li class="breadcrumb-item"><a href="{{ path('app_event_show', {'id': eventId}) }}">Événement</a></li>
                    {% else %}
                        <li class="breadcrumb-item"><a href="{{ path('app_event_review_index') }}">Avis</a></li>
                    {% endif %}
                    <li class="breadcrumb-item active" aria-current="page">Nouveau</li>
                </ol>
            </nav>
        </div>
        {% if eventId %}
            <a href="{{ path('app_event_show', {'id': eventId}) }}" class="btn btn-reset">
                <i class="fas fa-arrow-left me-2"></i>Retour à l'événement
            </a>
        {% else %}
            <a href="{{ path('app_event_review_index') }}" class="btn btn-reset">
                <i class="fas fa-arrow-left me-2"></i>Retour à la liste
            </a>
        {% endif %}
    </div>
</div>

<div class="stat-card">
    {{ include('event_review/_form.html.twig', {'button_label': 'Créer l\'avis'}) }}
</div>
{% endblock %}


