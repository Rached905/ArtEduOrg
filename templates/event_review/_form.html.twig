{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

<div class="row">
    <div class="col-md-12 mb-3">
        {{ form_row(form.event, {
            'attr': {'class': 'form-select'},
            'label': 'Événement',
            'label_attr': {'class': 'form-label fw-bold'}
        }) }}
    </div>
</div>

<div class="row">
    <div class="col-md-12 mb-3">
        <label class="form-label fw-bold">Note <span class="text-danger">*</span></label>
        <div class="star-rating-container">
            <div class="star-rating" id="starRating">
                {% for i in 1..5 %}
                    <i class="far fa-star star-icon" data-rating="{{ i }}" style="font-size: 2rem; color: #ffc107; cursor: pointer; margin-right: 5px; user-select: none; -webkit-user-select: none; -moz-user-select: none; -ms-user-select: none;" role="button" tabindex="0" aria-label="Noter {{ i }} étoile{{ i > 1 ? 's' : '' }}"></i>
                {% endfor %}
            </div>
            {{ form_widget(form.rating, {'attr': {'class': 'd-none', 'id': 'rating-input'}}) }}
            <div class="invalid-feedback d-block">
                {{ form_errors(form.rating) }}
            </div>
            <small class="text-muted d-block mt-2">Cliquez sur les étoiles pour noter (1 à 5 étoiles)</small>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12 mb-3">
        {{ form_row(form.comment, {
            'attr': {'class': 'form-control'},
            'label': 'Commentaire',
            'label_attr': {'class': 'form-label fw-bold'}
        }) }}
    </div>
</div>

<div class="d-flex justify-content-end gap-2 mt-4">
    {% if eventId is defined and eventId %}
        <a href="{{ path('app_event_show', {'id': eventId}) }}" class="btn btn-secondary">
            <i class="fas fa-times"></i> Annuler
        </a>
    {% else %}
        <a href="{{ path('app_event_review_index') }}" class="btn btn-secondary">
            <i class="fas fa-times"></i> Annuler
        </a>
    {% endif %}
    <button type="submit" class="btn btn-success">
        <i class="fas fa-save"></i> {{ button_label|default('Enregistrer') }}
    </button>
</div>

{{ form_end(form) }}

<style>
.star-rating-container {
    padding: 15px;
    background: #f8f9fa;
    border-radius: 8px;
    border: 1px solid #dee2e6;
}

.star-rating {
    display: flex;
    align-items: center;
    gap: 5px;
}

.star-icon {
    transition: all 0.2s ease;
}

.star-icon:hover {
    transform: scale(1.2);
}

.star-icon.active,
.star-icon.filled {
    color: #ffc107 !important;
}

.star-icon.filled::before {
    content: "\f005"; /* Font Awesome filled star */
    font-family: "Font Awesome 6 Free";
    font-weight: 900;
}
</style>

<script>
(function() {
    'use strict';
    
    function initStarRating() {
        const starContainer = document.getElementById('starRating');
        if (!starContainer) {
            console.warn('Star rating container not found');
            return;
        }
        
        const stars = starContainer.querySelectorAll('.star-icon');
        if (stars.length === 0) {
            console.warn('No stars found');
            return;
        }
        
        // Trouver le champ input de rating - plusieurs méthodes pour être sûr
        let ratingInput = document.getElementById('rating-input');
        if (!ratingInput) {
            ratingInput = document.querySelector('input[name="{{ form.rating.vars.full_name }}"]');
        }
        if (!ratingInput) {
            // Essayer avec un sélecteur plus générique
            ratingInput = document.querySelector('input[type="number"][name*="rating"]');
        }
        if (!ratingInput) {
            // Dernière tentative : chercher dans le formulaire
            const form = starContainer.closest('form');
            if (form) {
                ratingInput = form.querySelector('input[type="number"]');
            }
        }
        
        if (!ratingInput) {
            console.error('Rating input field not found');
            return;
        }
        
        // Initialiser les étoiles selon la valeur actuelle
        const currentRating = ratingInput.value ? parseInt(ratingInput.value) : 0;
        if (currentRating > 0) {
            updateStars(stars, currentRating);
        }
        
        // Ajouter les événements sur chaque étoile
        stars.forEach((star, index) => {
            const rating = index + 1; // 1-based rating
            
            // Click event
            star.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                ratingInput.value = rating;
                ratingInput.dispatchEvent(new Event('change', { bubbles: true }));
                updateStars(stars, rating);
                // Retirer l'erreur de validation si présente
                const errorElement = starContainer.closest('.mb-3').querySelector('.invalid-feedback');
                if (errorElement) {
                    errorElement.style.display = 'none';
                }
            });
            
            // Support pour le clavier (accessibilité)
            star.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    ratingInput.value = rating;
                    ratingInput.dispatchEvent(new Event('change', { bubbles: true }));
                    updateStars(stars, rating);
                }
            });
            
            // Mouse enter (hover)
            star.addEventListener('mouseenter', function() {
                highlightStars(stars, rating);
            });
        });
        
        // Mouse leave sur le conteneur
        starContainer.addEventListener('mouseleave', function() {
            const currentValue = ratingInput.value ? parseInt(ratingInput.value) : 0;
            if (currentValue > 0) {
                updateStars(stars, currentValue);
            } else {
                clearStars(stars);
            }
        });
    }
    
    function updateStars(stars, rating) {
        stars.forEach((star, index) => {
            const starRating = index + 1;
            if (starRating <= rating) {
                star.classList.remove('far');
                star.classList.add('fas', 'filled', 'active');
                star.style.color = '#ffc107';
            } else {
                star.classList.remove('fas', 'filled', 'active');
                star.classList.add('far');
                star.style.color = '#ffc107';
            }
        });
    }
    
    function highlightStars(stars, rating) {
        stars.forEach((star, index) => {
            const starRating = index + 1;
            if (starRating <= rating) {
                star.style.color = '#ffc107';
                star.style.transform = 'scale(1.2)';
            } else {
                star.style.color = '#ddd';
                star.style.transform = 'scale(1)';
            }
        });
    }
    
    function clearStars(stars) {
        stars.forEach(star => {
            star.classList.remove('fas', 'filled', 'active');
            star.classList.add('far');
            star.style.color = '#ffc107';
            star.style.transform = 'scale(1)';
        });
    }
    
    // Initialiser quand le DOM est prêt
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initStarRating);
    } else {
        // DOM déjà chargé
        initStarRating();
    }
})();
</script>


